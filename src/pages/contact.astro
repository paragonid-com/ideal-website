---
/**
 * /contact — страница Contact.
 *
 * Структура:
 *   ContactHero  — заголовок "Start your wellness transformation" + форма (Name/Email/Phone/Message)
 *   ContactInfo  — часы работы + адрес + телефон (данные из site.ts)
 *   TrustBadges  — бейджи доверия
 *   NewIn2026    — промо EXOMIND (переиспользован с главной)
 *
 * Дублирующая вторая форма "Start Your Wellness Transformation" удалена:
 * она повторяла заголовок и поля из ContactHero. Вместо неё — ContactInfo
 * с практической информацией (когда открыто, где, как позвонить).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactHero from '../components/contact/ContactHero.astro';
import ContactInfo from '../components/contact/ContactInfo.astro';
import LocationBlock from '../components/LocationBlock.astro';
import TrustBadges from '../components/TrustBadges.astro';
---

<BaseLayout
  title="Contact | Ideal Medical & Wellness"
  description="Get in touch with Ideal Medical & Wellness in Aventura, Florida. View our hours, location, and phone, or send us a message."
>
  <ContactHero />
  <ContactInfo />
  <LocationBlock />
  <TrustBadges />
</BaseLayout>
