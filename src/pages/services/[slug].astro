---
/**
 * /services/[slug] — динамический маршрут страниц услуг.
 *
 * Читает Content Collection 'services' и рендерит общий шаблон.
 * Страницы с draft: true исключаются из getStaticPaths (не генерируются в build).
 *
 * Гибридная архитектура (сессии 4-5): один шаблон умеет рендерить страницы
 * разной структуры (Weight Loss / hormone / emsculpt / exomind / …) через
 * условный рендер опциональных секций. Какие секции у страницы есть —
 * определяется наличием соответствующего поля во frontmatter.
 *
 * Эталонный порядок секций:
 *   ServiceHero
 *   ServiceCTABand
 *   ServiceWhatIs            (если whatIsBody)             — Weight Loss
 *   ServiceSimpleWhatIs      (если simpleWhatIs)           — emsculpt
 *   ServiceCTABand           (если был whatIs или simpleWhatIs)
 *   ServiceTwoColumnText     (если twoColumnText)          — exomind
 *   ServiceTextWithPhoto[]   (before-common-signs)         — hormone
 *   ServiceBenefits          (если benefits)               — Weight Loss
 *   ServiceCommonSigns       (если commonSigns)            — hormone
 *   ServiceCategoriesGrid    (categoriesGrids[0])          — emsculpt
 *   ServiceVideoEmbed        (если videoEmbed)             — emsculpt, exomind
 *   ServiceGoldBanner        (midGoldBanner1 — центр)      — exomind
 *   ServiceFullWidthImage[]  (after-gold-banner-1)         — exomind
 *   ServiceTextWithPhoto[]   (before-conditions)           — exomind
 *   ServiceConditionsList    (если conditionsList)         — exomind
 *   ServiceVideoEmbed        (если videoEmbed2 — видео #2) — exomind
 *   ServiceGoldBanner        (midGoldBanner2 — центр #2)   — exomind
 *   ServiceExtendedDescription (если extendedDescription)  — emsculpt
 *   ServiceCTABand           (если был extendedDescription)
 *   ServiceWhoFor            (если whoForBullets)          — Weight Loss
 *   ServiceRoadmap           (если roadmap)                — hormone
 *   ServiceTextWithPhoto[]   (after-roadmap)               — hormone
 *   ServiceCategoriesGrid    (categoriesGrids[1])          — emsculpt
 *   ServiceBeforeAfter       (если beforeAfter)            — emsculpt
 *   ServiceResults           (если resultsBody)            — Weight Loss
 *   ServiceWhyTrust          (если whyTrust)               — hormone
 *   ServiceGoldBanner        (goldBanner — после WhyTrust) — hormone
 *   ServiceExperience        (если experience)             — hormone
 *   ServiceFAQ               (если faq)
 *   NewIn2026                (всегда)
 *   StartYourTransformation  (всегда)
 *
 * Каждая страница берёт от этого порядка только те секции, что у неё
 * заполнены, поэтому Weight Loss/hormone/emsculpt не сломаны.
 *
 * Примечание про gold-баннеры: hormone использует ТОЛЬКО `goldBanner`
 * (после WhyTrust). exomind использует ТОЛЬКО `midGoldBanner1` и
 * `midGoldBanner2` (центральные позиции, обычно с CTA). emsculpt не
 * использует ни одного.
 */

import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceHero from '../../components/services/ServiceHero.astro';
import ServiceCTABand from '../../components/services/ServiceCTABand.astro';
import ServiceWhatIs from '../../components/services/ServiceWhatIs.astro';
import ServiceSimpleWhatIs from '../../components/services/ServiceSimpleWhatIs.astro';
import ServiceTwoColumnText from '../../components/services/ServiceTwoColumnText.astro';
import ServiceExtendedDescription from '../../components/services/ServiceExtendedDescription.astro';
import ServiceBenefits from '../../components/services/ServiceBenefits.astro';
import ServiceCommonSigns from '../../components/services/ServiceCommonSigns.astro';
import ServiceTextWithPhoto from '../../components/services/ServiceTextWithPhoto.astro';
import ServiceCategoriesGrid from '../../components/services/ServiceCategoriesGrid.astro';
import ServiceVideoEmbed from '../../components/services/ServiceVideoEmbed.astro';
import ServiceFullWidthImage from '../../components/services/ServiceFullWidthImage.astro';
import ServiceConditionsList from '../../components/services/ServiceConditionsList.astro';
import ServiceBeforeAfter from '../../components/services/ServiceBeforeAfter.astro';
import ServiceWhoFor from '../../components/services/ServiceWhoFor.astro';
import ServiceRoadmap from '../../components/services/ServiceRoadmap.astro';
import ServiceWhyTrust from '../../components/services/ServiceWhyTrust.astro';
import ServiceGoldBanner from '../../components/services/ServiceGoldBanner.astro';
import ServiceExperience from '../../components/services/ServiceExperience.astro';
import ServiceResults from '../../components/services/ServiceResults.astro';
import ServiceFAQ from '../../components/services/ServiceFAQ.astro';
import ServicePatientNotice from '../../components/services/ServicePatientNotice.astro';
import StartYourTransformation from '../../components/sections/StartYourTransformation.astro';

export async function getStaticPaths() {
  const services = await getCollection('services', ({ data }) => !data.draft);
  return services.map((service) => ({
    params: { slug: service.id },
    props: { service },
  }));
}

const { service } = Astro.props;
const { data } = service;

// Удобные локальные ссылки на массив categoriesGrids (если есть)
const firstCategoriesGrid = data.categoriesGrids?.[0];
const secondCategoriesGrid = data.categoriesGrids?.[1];

// twoColumnSections (emsella) — массив, фильтруем по позиции
const twoColAfterWhatIs = (data.twoColumnSections ?? []).filter(
  (s) => s.position === 'after-whatis'
);
const twoColAfterGrid = (data.twoColumnSections ?? []).filter(
  (s) => s.position === 'after-categories-grid'
);

// beforeAfter position: 'after-video-1' (emface) рендерится сразу после
// videoEmbed; 'late' (default, emsculpt) — после secondCategoriesGrid.
const beforeAfterAfterVideo1 =
  data.beforeAfter && data.beforeAfter.position === 'after-video-1'
    ? data.beforeAfter
    : undefined;
const beforeAfterLate =
  data.beforeAfter && data.beforeAfter.position !== 'after-video-1'
    ? data.beforeAfter
    : undefined;

// videoEmbed2 position: 'after-second-grid' (emface) рендерится после
// secondCategoriesGrid; 'before-second-grid' (default, exomind) — раньше.
const videoEmbed2BeforeGrid =
  data.videoEmbed2 && data.videoEmbed2.position !== 'after-second-grid'
    ? data.videoEmbed2
    : undefined;
const videoEmbed2AfterGrid =
  data.videoEmbed2 && data.videoEmbed2.position === 'after-second-grid'
    ? data.videoEmbed2
    : undefined;

// Группируем textWithPhotoBlocks по позиции для удобного рендера
const blocksBeforeCommonSigns = (data.textWithPhotoBlocks ?? []).filter(
  (b) => b.position === 'before-common-signs'
);
const blocksAfterRoadmap = (data.textWithPhotoBlocks ?? []).filter(
  (b) => b.position === 'after-roadmap'
);
const blocksBeforeConditions = (data.textWithPhotoBlocks ?? []).filter(
  (b) => b.position === 'before-conditions'
);

// fullWidthImages по позиции
const fullWidthAfterGoldBanner1 = (data.fullWidthImages ?? []).filter(
  (b) => b.position === 'after-gold-banner-1'
);
const fullWidthAfterCommonSigns = (data.fullWidthImages ?? []).filter(
  (b) => b.position === 'after-common-signs'
);

// midGoldBanner1 / midGoldBanner2 / goldBanner могут быть строкой или объектом
// — нормализуем
type GoldBannerData = { text: string; ctaLabel?: string; ctaHref?: string };
function normalizeBanner(
  b: string | { text: string; ctaLabel?: string; ctaHref?: string } | undefined
): GoldBannerData | undefined {
  if (!b) return undefined;
  if (typeof b === 'string') return { text: b };
  return b;
}
const midGoldBanner1 = normalizeBanner(data.midGoldBanner1);
const midGoldBanner2 = normalizeBanner(data.midGoldBanner2);
const goldBanner = normalizeBanner(data.goldBanner);
---

<BaseLayout
  title={data.seoTitle}
  description={data.seoDescription}
  pageType="service"
  serviceName={data.heroTitle?.replace(/\n/g, ' ')}
  serviceDescription={data.seoDescription}
  faq={data.faq}
>
  <ServiceHero
    title={data.heroTitle}
    lead={data.heroLead}
    image={data.heroImage}
    imageAlt={data.heroImageAlt}
    showStar={data.stars?.hero}
    mobileStacked={data.heroMobileStacked}
    mobileImagePosition={data.heroMobileImagePosition}
    ctaLabel={data.heroCtaLabel}
    ctaHref={data.heroCtaHref}
    ctaHideOnMobile={data.heroCtaHideOnMobile}
    theme={data.heroTheme}
    strongScrim={data.heroStrongScrim}
  />

  {!data.suppressDefaultCtas && <ServiceCTABand overlap={data.overlapCtas} />}

  {/* Opt-in straddle CTA сразу после Hero (hormone шов Hero/WhatIs y≈814).
     Независим от suppressDefaultCtas: hormone глушит дефолты и возвращает
     только нужные швы. Default false → другие страницы не затронуты. */}
  {data.ctaAfterHero && <ServiceCTABand overlap={data.overlapCtas} />}

  {/* Long-form "What is X?" (Weight Loss формат: фото + многоабзацный текст) */}
  {data.whatIsTitle && data.whatIsImage && data.whatIsBody && (
    <>
      <ServiceWhatIs
        title={data.whatIsTitle}
        image={data.whatIsImage}
        imageAlt={data.whatIsImageAlt || ''}
        body={data.whatIsBody}
        showStar={data.stars?.whatIs}
        sectionHeight={data.whatIsHeight}
        gridColsClass={data.whatIsGridCols}
        align={data.whatIsAlign}
        headingClass={data.whatIsHeadingClass}
        bodyClass={data.whatIsBodyClass}
        mobileTextFirst={data.whatIsMobileTextFirst}
        imageSide={data.whatIsImageSide}
        imageZoomOut={data.whatIsImageZoomOut}
        imageContain={data.whatIsImageContain}
        imageMobile={data.whatIsImageMobile}
        imageAspectClass={data.whatIsImageAspect}
        imagePadded={data.whatIsImagePadded}
        imageRounded={data.whatIsImageRounded}
      />
      {/* CTA после what-is — кроме emsella, где следом идёт two-col
         'after-whatis' со своим завершающим CTA (иначе двойной баннер). */}
      {twoColAfterWhatIs.length === 0 && !data.suppressDefaultCtas && <ServiceCTABand overlap={data.overlapCtas} />}
    </>
  )}

  {/* Короткий "What is X?" без фото (emsculpt) */}
  {data.simpleWhatIs && (
    <>
      <ServiceSimpleWhatIs
        title={data.simpleWhatIs.title}
        body={data.simpleWhatIs.body}
      />
      <ServiceCTABand overlap={data.overlapCtas} />
    </>
  )}

  {/* Двухколоночный текст (exomind: WHAT IS + WHO IS A GOOD CANDIDATE) */}
  {data.twoColumnText && (
    <ServiceTwoColumnText
      left={data.twoColumnText.left}
      right={data.twoColumnText.right}
      alignBodies={data.twoColumnText.alignBodies}
    />
  )}{data.ctaAfterTwoColumnText && <ServiceCTABand overlap={data.overlapCtas} />}

  {/* Two-column секции 'after-whatis' (emsella: What to Expect / Book Your Treatment) */}
  {twoColAfterWhatIs.map((s) => (
    <>
      <ServiceTwoColumnText
        heading={s.heading}
        headingClass={s.headingClass}
        background={s.background}
        left={s.left}
        right={s.right}
        intro={s.intro}
        footer={s.footer}
      />
      <ServiceCTABand overlap={data.overlapCtas} />
    </>
  ))}

  {/* Text+Photo блоки перед Common Signs (hormone "Reclaiming Yourself") */}
  {blocksBeforeCommonSigns.map((block) => (
    <ServiceTextWithPhoto
      title={block.title}
      body={block.body}
      image={block.image}
      imageAlt={block.imageAlt}
      imageSide={block.imageSide}
      bullets={block.bullets}
      bulletStyle={block.bulletStyle}
      tail={block.tail}
      showStar={block.star}
      sectionHeight={block.sectionHeight}
      align={block.align}
      headingClass={block.headingClass}
      bodyClass={block.bodyClass}
      imageZoomOut={block.imageZoomOut}
      imagePadded={block.imagePadded}
    />
  ))}

  {/* Opt-in straddle CTA между Reclaiming и Common Signs (hormone шов y≈2799). */}
  {data.ctaBeforeCommonSigns && <ServiceCTABand overlap={data.overlapCtas} />}

  {/* Сетка преимуществ (Weight Loss: icon+title+desc; Peptide: icon+title 3x3) */}
  {data.benefitsTitle && data.benefits && (
    <>
      <ServiceBenefits
        title={data.benefitsTitle}
        intro={data.benefitsIntro}
        benefits={data.benefits}
        iconOnly={data.benefitsIconOnly}
        topRowCount={data.benefitsTopRowCount}
        showStar={data.stars?.benefits}
      />
      {!data.suppressDefaultCtas && <ServiceCTABand overlap={data.overlapCtas} />}
    </>
  )}

  {/* Common Signs grid (hormone) */}
  {data.commonSigns && (
    <>
      <ServiceCommonSigns
        title={data.commonSigns.title}
        intro={data.commonSigns.intro}
        items={data.commonSigns.items}
        showStar={data.stars?.commonSigns}
      />
      {/* Full-width image между Common Signs и Roadmap (hormone, Figma 1:3462) */}
      {fullWidthAfterCommonSigns.map((b) => (
        <ServiceFullWidthImage image={b.image} imageAlt={b.imageAlt} todo={b.todo} />
      ))}
      <ServiceCTABand overlap={data.overlapCtas} />
    </>
  )}

  {/* Первая Categories Grid (emsculpt "What is For" / emsella incontinence) */}
  {firstCategoriesGrid && (
    <ServiceCategoriesGrid
      title={firstCategoriesGrid.title}
      titleClass={firstCategoriesGrid.titleClass}
      background={firstCategoriesGrid.background}
      items={firstCategoriesGrid.items}
      imageAspectClass={firstCategoriesGrid.imageAspectClass}
    />
  )}

  {/* Video embed сразу после первой grid (emsella: BTL Emsella mechanism,
     Figma 1:5400). Идёт перед CTA и Sexual Wellness. */}
  {data.videoEmbed && data.videoEmbed.position === 'after-first-grid' && (
    <ServiceVideoEmbed
      url={data.videoEmbed.url}
      posterImage={data.videoEmbed.posterImage}
      posterAlt={data.videoEmbed.posterAlt}
      flush={data.videoEmbed.flush}
      fullBleed={data.videoEmbed.fullBleed}
    />
  )}

  {/* CTA после первой grid — только когда дальше идёт after-categories-grid
     two-col (паттерн emsella, Figma 1:5169). emface/emsculpt не затрагиваются. */}
  {firstCategoriesGrid && twoColAfterGrid.length > 0 && <ServiceCTABand overlap={data.overlapCtas} />}

  {/* Two-column секции 'after-categories-grid' (emsella: Sexual Wellness — heading + фото) */}
  {twoColAfterGrid.map((s) => (
    <>
      <ServiceTwoColumnText
        heading={s.heading}
        headingClass={s.headingClass}
        background={s.background}
        left={s.left}
        right={s.right}
        intro={s.intro}
        footer={s.footer}
      />
      <ServiceCTABand overlap={data.overlapCtas} />
    </>
  ))}

  {/* Video embed #1 (emsculpt, exomind, emface) — поздняя позиция (default) */}
  {data.videoEmbed && data.videoEmbed.position !== 'after-first-grid' && (
    <ServiceVideoEmbed
      url={data.videoEmbed.url}
      posterImage={data.videoEmbed.posterImage}
      posterAlt={data.videoEmbed.posterAlt}
      flush={data.videoEmbed.flush}
      fullBleed={data.videoEmbed.fullBleed}
    />
  )}

  {/* Before / After сразу после video #1 (emface — перед treatments-grid) */}
  {beforeAfterAfterVideo1 && (
    <ServiceBeforeAfter
      title={beforeAfterAfterVideo1.title}
      items={beforeAfterAfterVideo1.items}
      carousel={beforeAfterAfterVideo1.carousel}
      caption={beforeAfterAfterVideo1.caption}
    />
  )}

  {/* Gold banner #1 в центре (exomind — с CTA, между videoEmbed и conditionsList) */}
  {midGoldBanner1 && (
    <ServiceGoldBanner
      text={midGoldBanner1.text}
      ctaLabel={midGoldBanner1.ctaLabel}
      ctaHref={midGoldBanner1.ctaHref}
      variant="cream"
    />
  )}

  {/* Straddle CTA на шве gold-banner-1 / device image (exomind, Figma 1:3161) */}
  {midGoldBanner1 && <ServiceCTABand overlap={data.overlapCtas} />}

  {/* Full-width image после первого gold banner (exomind: фото устройства) */}
  {fullWidthAfterGoldBanner1.map((b) => (
    <ServiceFullWidthImage image={b.image} imageAlt={b.imageAlt} todo={b.todo} />
  ))}

  {/* Text+Photo блоки перед conditions list
     (exomind: HOW EXOMIND WORKS, WHY CHOOSE IDEAL) */}
  {blocksBeforeConditions.map((block) => (
    <ServiceTextWithPhoto
      title={block.title}
      body={block.body}
      image={block.image}
      imageAlt={block.imageAlt}
      imageSide={block.imageSide}
      bullets={block.bullets}
      bulletStyle={block.bulletStyle}
      tail={block.tail}
      showStar={block.star}
      sectionHeight={block.sectionHeight}
      align={block.align}
      headingClass={block.headingClass}
      bodyClass={block.bodyClass}
      imageZoomOut={block.imageZoomOut}
      imagePadded={block.imagePadded}
    />
  ))}

  {/* CTA перед conditions list (exomind, Figma 1:2907) — opt-in флагом */}
  {data.ctaBeforeConditionsList && <ServiceCTABand overlap={data.overlapCtas} />}

  {/* Conditions list (exomind: WHAT CAN EXOMIND IMPROVE?) */}
  {data.conditionsList && (
    <ServiceConditionsList
      title={data.conditionsList.title}
      items={data.conditionsList.items}
      caption={data.conditionsList.caption}
    />
  )}

  {/* Video embed #2 — позиция 'before-second-grid' (exomind testimonial) */}
  {videoEmbed2BeforeGrid && (
    <ServiceVideoEmbed
      url={videoEmbed2BeforeGrid.url}
      posterImage={videoEmbed2BeforeGrid.posterImage}
      posterAlt={videoEmbed2BeforeGrid.posterAlt}
      flush={videoEmbed2BeforeGrid.flush}
      fullBleed={videoEmbed2BeforeGrid.fullBleed}
    />
  )}

  {/* CTA после видео #2, перед gold banner #2 (exomind, Figma 1:2913) — opt-in */}
  {data.ctaAfterVideo2 && <ServiceCTABand overlap={data.overlapCtas} />}

  {/* Gold banner #2 в центре (exomind — повторный с CTA) */}
  {midGoldBanner2 && (
    <ServiceGoldBanner
      text={midGoldBanner2.text}
      ctaLabel={midGoldBanner2.ctaLabel}
      ctaHref={midGoldBanner2.ctaHref}
      variant="cream"
    />
  )}

  {/* Straddle CTA на шве gold-banner-2 / FAQ (exomind, Figma 1:2910) */}
  {midGoldBanner2 && <ServiceCTABand overlap={data.overlapCtas} />}

  {/* Extended description (emsculpt "MORE FOR LESS IN BODY SHAPING") */}
  {data.extendedDescription && (
    <>
      <ServiceExtendedDescription
        title={data.extendedDescription.title}
        body={data.extendedDescription.body}
      />
      <ServiceCTABand overlap={data.overlapCtas} />
    </>
  )}

  {/* Who is For (Weight Loss). Буллеты опциональны: peptide в Figma идёт
     сплошными абзацами без списка (узлы 1:3887). */}
  {data.whoForTitle && data.whoForImage && data.whoForLead && (
    <ServiceWhoFor
      title={data.whoForTitle}
      image={data.whoForImage}
      imageAlt={data.whoForImageAlt || ''}
      lead={data.whoForLead}
      bullets={data.whoForBullets ?? []}
      showStar={data.stars?.whoFor}
      sectionHeight={data.whoForHeight}
      gridColsClass={data.whoForGridCols}
      align={data.whoForAlign}
      headingClass={data.whoForHeadingClass}
      bodyClass={data.whoForBodyClass}
      imageMinH={data.whoForImageMinH}
      imageAspectClass={data.whoForImageAspect}
    />
  )}

  {/* Roadmap (hormone) */}
  {data.roadmap && (
    <ServiceRoadmap
      title={data.roadmap.title}
      intro={data.roadmap.intro}
      items={data.roadmap.items}
      showStar={data.stars?.roadmap}
    />
  )}

  {/* Text+Photo блоки после Roadmap (если в будущем понадобятся) */}
  {blocksAfterRoadmap.map((block) => (
    <ServiceTextWithPhoto
      title={block.title}
      body={block.body}
      image={block.image}
      imageAlt={block.imageAlt}
      imageSide={block.imageSide}
      bullets={block.bullets}
      bulletStyle={block.bulletStyle}
      tail={block.tail}
      showStar={block.star}
      sectionHeight={block.sectionHeight}
      align={block.align}
      headingClass={block.headingClass}
      bodyClass={block.bodyClass}
      imageZoomOut={block.imageZoomOut}
      imagePadded={block.imagePadded}
    />
  ))}

  {/* Вторая Categories Grid (emsculpt "Customize" / emface "Treatments Address") */}
  {secondCategoriesGrid && (
    <ServiceCategoriesGrid
      title={secondCategoriesGrid.title}
      titleClass={secondCategoriesGrid.titleClass}
      background={secondCategoriesGrid.background}
      items={secondCategoriesGrid.items}
      imageAspectClass={secondCategoriesGrid.imageAspectClass}
    />
  )}

  {/* Video embed #2 — позиция 'after-second-grid' (emface — после treatments-grid) */}
  {videoEmbed2AfterGrid && (
    <ServiceVideoEmbed
      url={videoEmbed2AfterGrid.url}
      posterImage={videoEmbed2AfterGrid.posterImage}
      posterAlt={videoEmbed2AfterGrid.posterAlt}
      flush={videoEmbed2AfterGrid.flush}
      fullBleed={videoEmbed2AfterGrid.fullBleed}
    />
  )}

  {/* Before / After — позиция 'late' (emsculpt, после secondGrid) */}
  {beforeAfterLate && (
    <ServiceBeforeAfter
      title={beforeAfterLate.title}
      items={beforeAfterLate.items}
      carousel={beforeAfterLate.carousel}
      caption={beforeAfterLate.caption}
    />
  )}

  {/* The Results (Weight Loss) */}
  {data.resultsBody && (
    <ServiceResults
      title={data.resultsTitle || 'THE RESULTS'}
      body={data.resultsBody}
      showStar={data.stars?.results}
    />
  )}

  {/* Why Trust (hormone) */}
  {data.whyTrust && (
    <ServiceWhyTrust
      title={data.whyTrust.title}
      body={data.whyTrust.body}
      image={data.whyTrust.image}
      imageAlt={data.whyTrust.imageAlt}
      showStar={data.stars?.whyTrust}
    />
  )}

  {/* Gold pull-quote banner (hormone — после WhyTrust, перед Experience) */}
  {goldBanner && (
    <ServiceGoldBanner
      text={goldBanner.text}
      ctaLabel={goldBanner.ctaLabel}
      ctaHref={goldBanner.ctaHref}
    />
  )}

  {/* CTA между gold pull-quote и Experience (hormone, Figma band y6891) — opt-in */}
  {data.ctaAfterGoldBanner && <ServiceCTABand overlap={data.overlapCtas} />}

  {/* Experience (hormone — DNA фото + текст + телефон + CTA) */}
  {data.experience && (
    <ServiceExperience
      title={data.experience.title}
      body={data.experience.body}
      image={data.experience.image}
      imageAlt={data.experience.imageAlt}
      phone={data.experience.phone}
      showStar={data.stars?.experience}
    />
  )}

  {/* CTA прямо перед FAQ (emsculpt Figma 1:5573, emface 1:6327) — opt-in.
     overlap управляется overlapCtas (emsculpt=straddle; emface без флага=обычный band). */}
  {data.ctaBeforeFaq && <ServiceCTABand overlap={data.overlapCtas} />}

  {/* FAQ */}
  {data.faq && data.faq.length > 0 && <ServiceFAQ faq={data.faq} />}

  {/* Patient Notice & Disclaimer — LegitScript/FTC/FDA. Рендерится по умолчанию
      на всех страницах услуг; opt-out через suppressPatientNotice. */}
  {!data.suppressPatientNotice && <ServicePatientNotice />}

  <StartYourTransformation show="form" />
</BaseLayout>
