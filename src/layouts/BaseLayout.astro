---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { SITE } from '../data/site';

interface Props {
  title: string;
  description?: string;
  /** Включать ли Header. По умолчанию true. Для лендингов без шапки можно отключить. */
  header?: boolean;
  /** Включать ли Footer. По умолчанию true. */
  footer?: boolean;
  /** Toggle GHL/LeadConnector chat widget. Default true. */
  chatWidget?: boolean;
  /** OG/Twitter превью-картинка (путь от корня или абсолютный URL). */
  ogImage?: string;
  /** Тип страницы для og:type и structured data. */
  pageType?: 'website' | 'service' | 'article';
  /** FAQ для FAQPage schema (массив {question, answer}). */
  faq?: { question: string; answer: string }[];
  /** Имя/описание услуги для Service schema. */
  serviceName?: string;
  serviceDescription?: string;
  /** Метаданные статьи для BlogPosting schema. */
  article?: {
    title: string;
    description?: string;
    image?: string;
    datePublished?: string;
    dateModified?: string;
    author?: string;
  };
}

const {
  title,
  description = SITE.description,
  header = true,
  footer = true,
  chatWidget = true,
  ogImage = SITE.ogImage,
  pageType = 'website',
  faq,
  serviceName,
  serviceDescription,
  article,
} = Astro.props;

// Канонический URL текущей страницы относительно production-домена
// (Astro.url может быть localhost при dev/preview — нормализуем на SITE.url).
const canonical = new URL(Astro.url.pathname, SITE.url).href.replace(/\/$/, '') || SITE.url;
const ogImageAbs = ogImage.startsWith('http') ? ogImage : `${SITE.url}${ogImage}`;
const ogType = pageType === 'article' ? 'article' : 'website';

// --- BreadcrumbList (SEO P2) ---
// Авто-сборка из pathname: Home > [Blog >] <Текущая страница>.
// /services/ не имеет индексной страницы, поэтому промежуточный уровень
// для услуг не выводится. На главной крошки не эмитятся (length < 2).
// Имя текущей страницы — из <title> до первого разделителя (' | ', ' — ').
const crumbName = title.split(/ \| | — /)[0].trim();
const pathParts = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumb = [
  { name: 'Home', item: SITE.url },
  ...(pathParts[0] === 'blog' && pathParts.length > 1
    ? [{ name: 'Blog', item: `${SITE.url}/blog` }]
    : []),
  ...(pathParts.length > 0 ? [{ name: crumbName }] : []),
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {/* Favicons / иконки (исходная иконка-«атом» с оригинального сайта) */}
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#8d7431" />

    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {/* Open Graph (соцсети/мессенджеры — превью при шеринге) */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />

    {/* Twitter card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    {/* Manrope (body/UI) + Poppins (геометрический sans для брендового
        wordmark EXOMIND) с Google Fonts. preconnect к обоим хостам
        (fonts.googleapis.com — CSS, fonts.gstatic.com — woff2) сокращает
        задержку соединения. */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700&family=Poppins:wght@300;500;700&display=swap"
    />
    <title>{title}</title>

    <SchemaOrg
      type={pageType}
      canonical={canonical}
      breadcrumb={breadcrumb}
      faq={faq}
      serviceName={serviceName}
      serviceDescription={serviceDescription}
      article={article}
    />
  </head>
  <body class="bg-white text-gold">
    {header && <Header />}
    <main>
      <slot />
    </main>
    {footer && <Footer />}

    {/* GoHighLevel / LeadConnector chat widget (sitewide). is:inline keeps
        Astro from bundling the third-party loader and preserves data-* attrs.
        Launcher color, avatar, header and welcome copy are set in the GHL
        dashboard (widget appearance), not here. */}
    {chatWidget && (
      <script
        is:inline
        src="https://beta.leadconnectorhq.com/loader.js"
        data-resources-url="https://beta.leadconnectorhq.com/chat-widget/loader.js"
        data-widget-id="6a27d24f9372a70f7d54ef59"
      ></script>
    )}
  </body>
</html>
