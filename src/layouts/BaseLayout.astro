---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  /** Включать ли Header. По умолчанию true. Для лендингов без шапки можно отключить. */
  header?: boolean;
  /** Включать ли Footer. По умолчанию true. */
  footer?: boolean;
}

const {
  title,
  description = 'Ideal Medical & Wellness — premier medical spa and wellness center in Aventura, Florida.',
  header = true,
  footer = true,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {/* Manrope (body/UI шрифт) с Google Fonts. preconnect к обоим хостам
        (fonts.googleapis.com — CSS, fonts.gstatic.com — woff2) сокращает
        задержку соединения. Перенесён сюда из @import в global.css, где он
        стоял после @font-face и ломал порядок CSS (build-warning). */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700&display=swap"
    />
    <title>{title}</title>
  </head>
  <body class="bg-white text-gold">
    {header && <Header />}
    <main>
      <slot />
    </main>
    {footer && <Footer />}
  </body>
</html>
