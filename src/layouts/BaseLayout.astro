---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  /** Включать ли Header. По умолчанию true. Для лендингов без шапки можно отключить. */
  header?: boolean;
  /** Включать ли Footer. По умолчанию true. */
  footer?: boolean;
}

const {
  title,
  description = 'Ideal Medical & Wellness — premier medical spa and wellness center in Aventura, Florida.',
  header = true,
  footer = true,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="bg-white text-gold">
    {header && <Header />}
    <main>
      <slot />
    </main>
    {footer && <Footer />}
  </body>
</html>
