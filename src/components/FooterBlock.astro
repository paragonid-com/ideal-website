---
/**
 * FooterBlock — содержимое подвала страницы (полный лейаут).
 *
 * Колонки услуг берутся НАПРЯМУЮ из navigation.ts (mainNav) — единый источник:
 *   - Wellness Services (7)
 *   - Aesthetic Services (4 BTL-устройства)
 *   - About Us → колонка «Company»
 * Группировка nav после сессии 16 уже совпадает с дизайном подвала, поэтому
 * перегруппировка не нужна.
 *
 * Фон-градиент задаётся обёрткой Footer.astro. NAP (адрес/телефон) — в брендовой
 * колонке для локального SEO/доверия. Соцсети — placeholder-URL (data-todo).
 *
 * Примечание: вариант 'compact' (старое overlay-меню) больше не используется —
 * оверлей заменён десктоп-баром в сессии 16. Компонент рендерит только подвал.
 */
import { mainNav, bookingCta } from '../data/navigation';
import { SITE } from '../data/site';

interface Props {
  /** Совместимость со старым вызовом; футер всегда рендерит полный лейаут. */
  variant?: 'compact' | 'full';
}
// eslint-disable-next-line no-unused-vars
const { variant: _variant = 'full' } = Astro.props;

const address = {
  name: SITE.legalName,
  street: `${SITE.address.street}, ${SITE.address.suite}`,
  city: `${SITE.address.city}, ${SITE.address.region} ${SITE.address.postalCode}`,
  phone: SITE.phoneDisplay,
};
const tel = `tel:${address.phone.replace(/[^\d+]/g, '')}`;

const group = (label: string) => mainNav.find((g) => g.label === label)?.items ?? [];
const wellness = group('Wellness Services');
const aesthetic = group('Aesthetic Services');
const company = group('About Us');

const legal = [
  { label: 'Terms', href: '/terms' },
  { label: 'Privacy', href: '/privacy' },
];

// Соцсети — реальные URL из site.ts (единый источник, совпадает со schema sameAs).
const socials = [
  { label: 'Facebook', href: SITE.socials.facebook },
  { label: 'Instagram', href: SITE.socials.instagram },
  { label: 'YouTube', href: SITE.socials.youtube },
];

const year = new Date().getFullYear();
---

<div>
  <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-[1.6fr_1fr_1fr_1.3fr] lg:gap-12">
    {/* Brand + address + socials */}
    <div class="flex flex-col gap-5">
      <img
        src="/assets/images/logo-ideal.svg"
        alt="IDEAL Medical and Wellness"
        width="194"
        height="62"
        class="h-auto w-[194px]"
      />
      <img src="/assets/images/star-sign.svg" alt="" width="43" height="50" class="h-[50px] w-[43px]" />
      <address class="not-italic font-sans text-[14px] leading-relaxed text-[#2e2a20]">
        {address.name}
        <br />
        {address.street}, {address.city}
        <br />
        <a href={tel} class="mt-2 inline-block font-semibold text-[#6f5a24] hover:underline">
          {address.phone}
        </a>
      </address>
      <ul class="flex flex-row gap-3">
        {
          socials.map((s) => (
            <li>
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={s.label}
                class="flex h-[42px] w-[42px] items-center justify-center rounded-full bg-gold text-cream transition-opacity hover:opacity-80"
              >
                {s.label === 'Facebook' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07c0 6.02 4.39 11.01 10.13 11.93v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.69.24 2.69.24v2.97h-1.52c-1.49 0-1.96.93-1.96 1.89v2.25h3.33l-.53 3.49h-2.8V24C19.61 23.08 24 18.09 24 12.07Z" />
                  </svg>
                )}
                {s.label === 'Instagram' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16Zm0 3.31a4.59 4.59 0 1 0 0 9.18 4.59 4.59 0 0 0 0-9.18Zm0 7.57a2.98 2.98 0 1 1 0-5.96 2.98 2.98 0 0 1 0 5.96Zm5.84-7.77a1.07 1.07 0 1 1-2.14 0 1.07 1.07 0 0 1 2.14 0Z" />
                  </svg>
                )}
                {s.label === 'YouTube' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M23.5 6.2a3 3 0 0 0-2.12-2.12C19.5 3.57 12 3.57 12 3.57s-7.5 0-9.38.51A3 3 0 0 0 .5 6.2C0 8.07 0 12 0 12s0 3.93.5 5.8a3 3 0 0 0 2.12 2.12c1.88.51 9.38.51 9.38.51s7.5 0 9.38-.51a3 3 0 0 0 2.12-2.12C24 15.93 24 12 24 12s0-3.93-.5-5.8ZM9.6 15.6V8.4l6.2 3.6-6.2 3.6Z" />
                  </svg>
                )}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    {/* Wellness Services */}
    <nav aria-label="Wellness Services">
      <h3 class="font-heading text-[20px] uppercase tracking-[0.04em] text-[#6f5a24]">Wellness Services</h3>
      <ul class="mt-5 flex flex-col gap-[9px]">
        {
          wellness.map((l) => (
            <li>
              <a href={l.href} class="font-sans text-[15px] text-[#2e2a20] hover:text-[#6f5a24] hover:underline">
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    {/* Aesthetic Services + Company */}
    <nav aria-label="Aesthetic Services and company">
      <h3 class="font-heading text-[20px] uppercase tracking-[0.04em] text-[#6f5a24]">Aesthetic Services</h3>
      <ul class="mt-5 flex flex-col gap-[9px]">
        {
          aesthetic.map((l) => (
            <li>
              <a href={l.href} class="font-sans text-[15px] text-[#2e2a20] hover:text-[#6f5a24] hover:underline">
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
      <h3 class="mt-7 font-heading text-[20px] uppercase tracking-[0.04em] text-[#6f5a24]">Company</h3>
      <ul class="mt-5 flex flex-col gap-[9px]">
        {
          company.map((l) => (
            <li>
              <a href={l.href} class="font-sans text-[15px] text-[#2e2a20] hover:text-[#6f5a24] hover:underline">
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    {/* Stay in touch */}
    <div>
      <h3 class="font-heading text-[20px] uppercase tracking-[0.04em] text-[#6f5a24]">Stay in Touch</h3>
      <p class="mt-5 font-sans text-[14px] leading-relaxed text-[#2e2a20]">
        Join our newsletter for updates and offers.
      </p>
      <form class="mt-4 flex flex-col gap-3" data-todo="newsletter-integration">
        <input
          type="email"
          name="email"
          required
          placeholder="your@email.com"
          class="border-b border-[#6f5a24] bg-transparent py-2 font-sans text-[#2e2a20] placeholder:text-[#2e2a20]/50 focus:outline-none"
        />
        <button type="submit" class="btn-gold w-fit">JOIN NOW</button>
      </form>
      <a
        href={bookingCta.href}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-gold mt-4 inline-block"
      >
        {bookingCta.label}
      </a>
      <a
        href={SITE.financing.href}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 block font-sans text-[14px] font-semibold text-[#6f5a24] underline-offset-2 hover:underline"
      >
        {SITE.financing.label} — flexible monthly payments &rarr;
      </a>
    </div>
  </div>

  {/* Bottom bar */}
  <div class="mt-12 flex flex-col gap-3 border-t border-[#6f5a24]/30 pt-6 font-sans text-[13px] text-[#5a4f33] sm:flex-row sm:items-center sm:justify-between">
    <span>©{year} Ideal Medical and Wellness. All rights reserved.</span>
    <span class="flex gap-5">
      {
        legal.map((l) => (
          <a href={l.href} class="hover:text-[#6f5a24] hover:underline">
            {l.label}
          </a>
        ))
      }
    </span>
  </div>
</div>
