---
/**
 * ServiceTwoColumnText — двухколоночная секция: заголовок+текст слева,
 * заголовок+буллеты+хвост справа. Без фото.
 *
 * Используется на странице exomind (узлы Figma 1:2888 и 1:2889):
 *   - Слева (x=147 y=930): "WHAT IS EXOMIND?" + многоабзацный body
 *   - Справа (x=940 y=930): "WHO IS A GOOD CANDIDATE FOR EXOMIND?"
 *     + intro + 5 буллетов с маркером "_" + хвост-параграф
 *
 * Композиционно: 2 колонки grid, каждая независима. Можно использовать
 * для любой "сравнительной" пары блоков (What is X? / Who is X for?)
 * на одной странице без чередования с фото.
 */

interface ColumnData {
  title: string;
  body?: string;
  bullets?: string[];
  /** 'dash' (— маркер, default) или 'plain' (без маркера, лейбл до «:» жирным). */
  bulletStyle?: 'dash' | 'plain';
  tail?: string;
  /** Опц. фото над колонкой (emsella Sexual Wellness) */
  image?: string;
  imageAlt?: string;
}

interface Props {
  left: ColumnData;
  right: ColumnData;
  /** Опц. общий заголовок над обеими колонками (emsella Sexual Wellness) */
  heading?: string;
  /** Класс размера общего заголовка. Default `text-h1 leading-tight`.
   *  emsella «EMSELLA FOR SEXUAL WELLNESS» — меньше (~36px, Figma 1:5162). */
  headingClass?: string;
  /** Фон секции: cream (default) или gold */
  background?: 'cream' | 'gold';
  /** Опц. лид-абзац под заголовком, над колонками (HTML — emsella Intimate
   *  Wellness compliance-оговорка). */
  intro?: string;
  /** Опц. абзац под колонками (HTML — emsella ссылка на Sexual Health). */
  footer?: string;
  /** Десктоп: зарезервировать равную высоту под оба заголовка (lg:min-h-[3lh]),
   *  чтобы тела колонок начинались на одной линии. Default false. */
  alignBodies?: boolean;
}

const { left, right, heading, headingClass = 'text-h1 leading-tight', background = 'cream', intro, footer, alignBodies = false } = Astro.props;

// Десктоп-резерв высоты заголовка (выравнивание начала тел колонок).
const titleAlign = alignBodies ? ' lg:min-h-[3lh]' : '';

/** Для bulletStyle='plain': лейбл до первого «:» рендерим жирным. */
function splitLabel(b: string): { label: string | null; rest: string } {
  const idx = b.indexOf(':');
  if (idx === -1) return { label: null, rest: b };
  return { label: b.slice(0, idx + 1), rest: b.slice(idx + 1).replace(/^\s+/, '') };
}

const bgStyle =
  background === 'gold'
    ? 'background: radial-gradient(ellipse at center, #faf8eb 0%, #d2bea3 70%, #b89a76 100%);'
    : 'background-color: #eae4d2;';

function paras(s?: string): string[] {
  return (s ?? '').split(/\n{2,}/).map((p) => p.trim()).filter(Boolean);
}

const leftParas = paras(left.body);
const leftTail = paras(left.tail);
const rightParas = paras(right.body);
const rightTail = paras(right.tail);
---

<section
  class="w-full py-24"
  data-section="service-two-column-text"
  style={bgStyle}
>
  <div class="mx-auto max-w-design px-[7.55%]">
    {heading && (
      <h2 class={`font-heading uppercase text-gold mb-12 ${headingClass}`}>
        {heading}
      </h2>
    )}{intro && <div class="mb-12 max-w-[1100px] font-sans text-body-lg text-gold leading-relaxed [&_strong]:font-semibold" set:html={intro} />}
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
    {/* Левая колонка */}
    <div>
      {left.image && (
        <div class="aspect-[783/522] w-full overflow-hidden rounded-md mb-8">
          <img
            src={left.image}
            alt={left.imageAlt || ''}
            class="block h-full w-full object-cover"
            loading="lazy"
          />
        </div>
      )}
      <h2 class={`font-heading text-h1 uppercase text-gold leading-tight${titleAlign}`}>
        {left.title.split('\n').map((line, i, arr) => (
          <>
            {line}
            {i < arr.length - 1 && <br />}
          </>
        ))}
      </h2>

      <div class="mt-10 space-y-6 font-sans text-body-lg text-gold leading-relaxed">
        {leftParas.map((p) => (
          <p>
            {p.split('\n').map((line, i, arr) => (
              <>
                {line}
                {i < arr.length - 1 && <br />}
              </>
            ))}
          </p>
        ))}
        {left.bullets && left.bullets.length > 0 && (
          left.bulletStyle === 'plain' ? (
            <div class="mt-4 space-y-4">
              {left.bullets.map((b) => {
                const { label, rest } = splitLabel(b);
                return (
                  <p>{label && <strong class="font-semibold">{label} </strong>}{rest}</p>
                );
              })}
            </div>
          ) : (
            <ul class="mt-4 space-y-3">
              {left.bullets.map((b) => (
                <li class="flex gap-3">
                  <span aria-hidden="true" class="select-none flex-shrink-0">—</span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          )
        )}
        {leftTail.map((p) => <p>{p}</p>)}
      </div>
    </div>

    {/* Правая колонка */}
    <div>
      {right.image && (
        <div class="aspect-[783/522] w-full overflow-hidden rounded-md mb-8">
          <img
            src={right.image}
            alt={right.imageAlt || ''}
            class="block h-full w-full object-cover"
            loading="lazy"
          />
        </div>
      )}
      <h2 class={`font-heading text-h1 uppercase text-gold leading-tight${titleAlign}`}>
        {right.title.split('\n').map((line, i, arr) => (
          <>
            {line}
            {i < arr.length - 1 && <br />}
          </>
        ))}
      </h2>

      <div class="mt-10 space-y-6 font-sans text-body-lg text-gold leading-relaxed">
        {rightParas.map((p) => (
          <p>
            {p.split('\n').map((line, i, arr) => (
              <>
                {line}
                {i < arr.length - 1 && <br />}
              </>
            ))}
          </p>
        ))}
        {right.bullets && right.bullets.length > 0 && (
          right.bulletStyle === 'plain' ? (
            <div class="mt-4 space-y-4">
              {right.bullets.map((b) => {
                const { label, rest } = splitLabel(b);
                return (
                  <p>{label && <strong class="font-semibold">{label} </strong>}{rest}</p>
                );
              })}
            </div>
          ) : (
            <ul class="mt-4 space-y-3">
              {right.bullets.map((b) => (
                <li class="flex gap-3">
                  <span aria-hidden="true" class="select-none flex-shrink-0">—</span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          )
        )}
        {rightTail.map((p) => <p>{p}</p>)}
      </div>
    </div>
    </div>{footer && <div class="mt-12 max-w-[1100px] font-sans text-body-lg text-gold leading-relaxed [&_a]:underline [&_a]:underline-offset-2 hover:[&_a]:opacity-80" set:html={footer} />}
  </div>
</section>
