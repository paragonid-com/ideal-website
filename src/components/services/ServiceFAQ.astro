---
/**
 * ServiceFAQ — секция "Common FAQs" с аккордеоном.
 *
 * Структура (узлы Figma 1:1668-1:1684 для Weight Loss):
 *  - Заголовок "COMMON FAQs" (слева, h2)
 *  - Список вопросов, каждый с разделителем-линией снизу и стрелкой "›" справа
 *  - 5 вопросов на Weight Loss
 *
 * 💡 В Figma все вопросы свёрнуты, ответы текстом не указаны.
 *    Используется нативный <details>/<summary> для аккордеона:
 *    - Не нужно JS
 *    - Доступно (a11y из коробки)
 *    - Поисковики индексируют контент даже свёрнутый
 *
 * ⚠️ Тексты ответов придут от клиента (помечено data-todo).
 */

interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  faq: FAQ[];
}

import { SITE } from '../../data/site';
const { faq } = Astro.props;
---

<section
  class="w-full bg-gold py-24"
  data-section="service-faq"
>
  <div class="mx-auto max-w-design px-[7.55%]">
    <div class="text-center">
      <h2 class="font-heading text-[clamp(28px,3vw,48px)] uppercase text-cream leading-tight">
        Frequently Asked Questions
      </h2>
      <p class="mx-auto mt-5 max-w-[760px] font-sans text-body-lg text-cream/90 leading-relaxed">
        Please reach out to <a href="/contact" class="underline underline-offset-2 hover:opacity-80">{SITE.name}</a> if you cannot find an answer to your question.
      </p>
    </div>

    <ul class="mx-auto mt-14 max-w-[900px]">
      {faq.map((item, i) => (
        <li
          class={`border-t border-cream/40 ${i === faq.length - 1 ? 'border-b' : ''}`}
        >
          <details class="group">
            <summary
              class="cursor-pointer list-none py-6 text-left
                     hover:opacity-80 transition-opacity
                     [&::-webkit-details-marker]:hidden"
            >
              {/* Flex-обёртка ВНУТРИ summary: Safari/WebKit игнорирует
                  display:flex на самом <summary>, из-за чего вопросы
                  визуально центрировались на iPad. Обёртка-div решает это. */}
              <div class="flex items-center justify-between gap-8 text-left
                          font-sans text-[28px] text-cream leading-tight">
                <span class="text-left">{item.question}</span>
                {/* Стрелка › — поворачивается на 90° при раскрытии */}
                <svg
                  class="flex-shrink-0 transition-transform duration-200 group-open:rotate-90"
                  width="40"
                  height="20"
                  viewBox="0 0 55 27"
                  fill="none"
                  aria-hidden="true"
                >
                  <path d="M2 2L27.5 24.5L53 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
              </div>
            </summary>
            {item.answer.includes('<') ? (
              <div
                class="pb-6 pr-16 font-sans text-body-lg text-cream leading-relaxed [&_a]:underline [&_a]:underline-offset-2 hover:[&_a]:opacity-80"
                set:html={item.answer}
              />
            ) : (
              <div
                class="pb-6 pr-16 font-sans text-body-lg text-cream leading-relaxed"
                data-todo={!item.answer.trim() ? 'faq-answer-from-client' : undefined}
              >
                {item.answer || '— ответ будет добавлен клиентом —'}
              </div>
            )}
          </details>
        </li>
      ))}
    </ul>
  </div>
</section>
