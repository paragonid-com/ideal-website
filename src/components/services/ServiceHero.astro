---
/**
 * ServiceHero — Hero страницы услуги.
 *
 * Десктоп (lg+): полноширинное фото-фон (1920×814 Figma) + текст-оверлей слева.
 *
 * Мобайл: по умолчанию — тот же оверлей (короче). Опция `mobileStacked` (hormone):
 * на мобайле фото показывается отдельным баннером сверху (object-cover,
 * фокус на докторе через `mobileImagePosition`) — зум аут, доктор и что он делает
 * видны целиком, — а текст идёт ПОД фото на cream-фоне и хорошо читается.
 */

import { bookingCta } from '../../data/navigation.ts';

interface Props {
  title: string;
  lead: string;
  image: string;
  imageAlt: string;
  showStar?: boolean;
  /** Мобайл: фото баннером сверху, текст снизу (вместо оверлея). Default false. */
  mobileStacked?: boolean;
  /** object-position фото в мобильном баннере (фокус на докторе). Default object-center. */
  mobileImagePosition?: string;
  /** Opt-in: текст кнопки CTA внутри hero (Figma peptide узел 1:3906 «BOOK NOW»).
   *  Если не задан — кнопка не рендерится (weight-loss/hormone не затронуты:
   *  у них CTA идёт отдельным straddle-band на шве). */
  ctaLabel?: string;
  /** Ссылка кнопки. Default — bookingCta.href (централизованный Boulevard-URL). */
  ctaHref?: string;
  /** Скрыть in-hero CTA на мобайле (< lg). Нужно когда сразу после hero идёт
   *  straddle BOOK APPOINTMENT и на стопке две кнопки дублируются (emsella).
   *  Default false — десктоп всегда показывает кнопку. */
  ctaHideOnMobile?: boolean;
  /** object-position фото на ДЕСКТОПЕ (lg, не-stacked hero). Default 'object-right'
   *  (как было). Напр. 'object-[right_top]' — показать верх кадра, чтобы не
   *  срезать голову субъекта. Другие страницы не затронуты. */
  desktopImagePosition?: string;
  /** Тема фото-фона: 'light' (светлое фото, тёмный текст + cream-скрим — default,
   *  как peptide/iv/bloodwork) или 'dark' (тёмное фото, напр. regenerative pipette:
   *  светлый lead + тёмный скрим на десктоп-оверлее; gold-заголовок работает на обоих).
   *  В stacked-режиме мобильный текст лежит на cream и остаётся тёмным независимо от темы. */
  theme?: 'light' | 'dark';
  /** Opt-in: усилить десктоп-скрим под текстом для «busy»/светлых фото, где
   *  стандартный лёгкий cream-скрим не даёт читабельности (emsculpt/exomind/
   *  hormone — субъект фото заходит в текстовую колонку). Меняет ТОЛЬКО lg-стопы
   *  градиента; мобайл и прочие страницы не затрагиваются. Default false. */
  strongScrim?: boolean;
}

const {
  title, lead, image, imageAlt, showStar = false,
  mobileStacked = false,
  mobileImagePosition = 'object-center',
  desktopImagePosition = 'object-right',
  ctaLabel,
  ctaHref = bookingCta.href,
  ctaHideOnMobile = false,
  theme = 'light',
  strongScrim = false,
} = Astro.props;
const isDark = theme === 'dark';
const lines = title.split('\n');

const sectionClass = mobileStacked
  ? 'relative w-full overflow-hidden bg-cream lg:h-[814px]'
  : 'relative h-[600px] sm:h-[640px] lg:h-[814px] w-full overflow-hidden bg-white';

const imgClass = mobileStacked
  ? `block w-full h-[300px] sm:h-[380px] object-cover ${mobileImagePosition} lg:absolute lg:inset-0 lg:h-full lg:${desktopImagePosition}`
  : `absolute inset-0 h-full w-full object-cover ${desktopImagePosition}`;

const scrimClass = mobileStacked
  ? (isDark
      ? 'hidden lg:block absolute inset-0 z-[1] bg-gradient-to-r from-black/70 via-black/30 to-transparent'
      : `hidden lg:block absolute inset-0 z-[1] bg-gradient-to-r ${strongScrim ? 'from-cream/95 via-cream/70' : 'from-cream/55 via-cream/10'} to-transparent`)
  : (isDark
      ? 'absolute inset-0 z-[1] bg-gradient-to-r from-black/75 via-black/40 to-transparent'
      : `absolute inset-0 z-[1] bg-gradient-to-r from-cream/85 via-cream/45 to-transparent ${strongScrim ? 'lg:from-cream/95 lg:via-cream/70' : 'lg:from-cream/55 lg:via-cream/10'}`);

/* Цвет lead: на тёмной теме — светлый на десктоп-оверлее; в stacked-режиме
   мобильный текст на cream остаётся тёмным (lg: переключает на светлый). */
const leadColorClass = isDark
  ? (mobileStacked ? 'text-[#5a4f33] lg:text-[#efe7d4]' : 'text-[#efe7d4]')
  : 'text-[#5a4f33]';

const wrapClass = mobileStacked
  ? 'relative z-10 mx-auto max-w-design px-[7.55%] lg:h-full'
  : 'relative z-10 mx-auto h-full max-w-design px-[7.55%]';

const innerClass = mobileStacked
  ? 'flex flex-col justify-center py-12 lg:py-0 lg:h-full'
  : 'flex h-full flex-col justify-center pt-[80px] lg:pt-0';
---

<section class={sectionClass} data-section="service-hero">
  <img
    src={image}
    alt={imageAlt}
    class={imgClass}
    loading="eager"
    decoding="async"
  />

  {/* Скрим под текстом (на оверлее). В stacked-режиме на мобайле не нужен —
      текст лежит на cream-фоне ниже фото. */}
  <div class={scrimClass} aria-hidden="true"></div>

  <div class={wrapClass}>
    <div class={innerClass}>
      <h1 class="font-heading text-h1 uppercase text-gold leading-tight">
        {lines.map((line, i) => (
          <>
            {line}
            {i < lines.length - 1 && <br />}
          </>
        ))}
      </h1>

      <p class={`mt-[27px] max-w-[632px] font-sans text-body-lg ${leadColorClass} leading-relaxed`}>
        {lead}
      </p>

      {showStar && (
        <img
          src="/assets/images/star-sign.svg"
          alt=""
          width="43"
          height="50"
          class="mt-[21px] h-[50px] w-[43px]"
        />
      )}

      {ctaLabel && (
        <a
          href={ctaHref}
          target="_blank"
          rel="noopener noreferrer"
          class={['btn-gold mt-8 self-start min-w-[195px]', ctaHideOnMobile && 'max-lg:hidden'].filter(Boolean).join(' ')}
        >
          {ctaLabel}
        </a>
      )}
    </div>
  </div>
</section>
