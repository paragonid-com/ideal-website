---
/**
 * ServiceHero — Hero страницы услуги.
 *
 * Десктоп (lg+): полноширинное фото-фон (1920×814 Figma) + текст-оверлей слева.
 *
 * Мобайл: по умолчанию — тот же оверлей (короче). Опция `mobileStacked` (hormone):
 * на мобайле фото показывается отдельным баннером сверху (object-cover,
 * фокус на докторе через `mobileImagePosition`) — зум аут, доктор и что он делает
 * видны целиком, — а текст идёт ПОД фото на cream-фоне и хорошо читается.
 */

import { bookingCta } from '../../data/navigation.ts';

interface Props {
  title: string;
  lead: string;
  image: string;
  imageAlt: string;
  showStar?: boolean;
  /** Мобайл: фото баннером сверху, текст снизу (вместо оверлея). Default false. */
  mobileStacked?: boolean;
  /** object-position фото в мобильном баннере (фокус на докторе). Default object-center. */
  mobileImagePosition?: string;
  /** Opt-in: текст кнопки CTA внутри hero (Figma peptide узел 1:3906 «BOOK NOW»).
   *  Если не задан — кнопка не рендерится (weight-loss/hormone не затронуты:
   *  у них CTA идёт отдельным straddle-band на шве). */
  ctaLabel?: string;
  /** Ссылка кнопки. Default — bookingCta.href (централизованный Boulevard-URL). */
  ctaHref?: string;
}

const {
  title, lead, image, imageAlt, showStar = false,
  mobileStacked = false,
  mobileImagePosition = 'object-center',
  ctaLabel,
  ctaHref = bookingCta.href,
} = Astro.props;
const lines = title.split('\n');

const sectionClass = mobileStacked
  ? 'relative w-full overflow-hidden bg-cream lg:h-[814px]'
  : 'relative h-[600px] sm:h-[640px] lg:h-[814px] w-full overflow-hidden bg-white';

const imgClass = mobileStacked
  ? `block w-full h-[300px] sm:h-[380px] object-cover ${mobileImagePosition} lg:absolute lg:inset-0 lg:h-full lg:object-right`
  : 'absolute inset-0 h-full w-full object-cover object-right';

const scrimClass = mobileStacked
  ? 'hidden lg:block absolute inset-0 z-[1] bg-gradient-to-r from-cream/55 via-cream/10 to-transparent'
  : 'absolute inset-0 z-[1] bg-gradient-to-r from-cream/85 via-cream/45 to-transparent lg:from-cream/55 lg:via-cream/10';

const wrapClass = mobileStacked
  ? 'relative z-10 mx-auto max-w-design px-[7.55%] lg:h-full'
  : 'relative z-10 mx-auto h-full max-w-design px-[7.55%]';

const innerClass = mobileStacked
  ? 'flex flex-col justify-center py-12 lg:py-0 lg:h-full'
  : 'flex h-full flex-col justify-center pt-[80px] lg:pt-0';
---

<section class={sectionClass} data-section="service-hero">
  <img
    src={image}
    alt={imageAlt}
    class={imgClass}
    loading="eager"
    decoding="async"
  />

  {/* Скрим под текстом (на оверлее). В stacked-режиме на мобайле не нужен —
      текст лежит на cream-фоне ниже фото. */}
  <div class={scrimClass} aria-hidden="true"></div>

  <div class={wrapClass}>
    <div class={innerClass}>
      <h1 class="font-heading text-h1 uppercase text-gold leading-tight">
        {lines.map((line, i) => (
          <>
            {line}
            {i < lines.length - 1 && <br />}
          </>
        ))}
      </h1>

      <p class="mt-[27px] max-w-[632px] font-sans text-body-lg text-[#5a4f33] leading-relaxed">
        {lead}
      </p>

      {showStar && (
        <img
          src="/assets/images/star-sign.svg"
          alt=""
          width="43"
          height="50"
          class="mt-[21px] h-[50px] w-[43px]"
        />
      )}

      {ctaLabel && (
        <a
          href={ctaHref}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-gold mt-8 self-start min-w-[195px]"
        >
          {ctaLabel}
        </a>
      )}
    </div>
  </div>
</section>
