---
/**
 * ServiceHero — Hero страницы услуги.
 *
 * Структура (узлы Figma 1:1485-1:1509 для Weight Loss):
 *  - Полноширинное фото (1920×814 в Figma)
 *  - Текст слева:
 *      * H1, 2 строки, font-heading, 62px, x=145 y=224
 *      * Подзаголовок-параграф, x=145 y=389 width=632
 *      * (на главной тут была кнопка BOOK NOW — на странице услуги кнопки нет,
 *         CTA-band идёт ниже отдельным компонентом)
 *
 * Высота 814px (меньше чем главная — 1079px).
 */

interface Props {
  /** Заголовок — поддерживает \n для переноса */
  title: string;
  /** Лид-параграф */
  lead: string;
  /** Путь к фото в /public/ (большое фоновое) */
  image: string;
  /** Alt для фото */
  imageAlt: string;
  /** Показать gold-звезду под lead (specialty-страницы, Figma) */
  showStar?: boolean;
}

const { title, lead, image, imageAlt, showStar = false } = Astro.props;
// Разбиваем title на строки по \n чтобы отрисовать через <br/>
const lines = title.split('\n');
---

<section
  class="relative h-[600px] sm:h-[640px] lg:h-[814px] w-full overflow-hidden bg-white"
  data-section="service-hero"
>
  <img
    src={image}
    alt={imageAlt}
    class="absolute inset-0 h-full w-full object-cover object-right"
    loading="eager"
    decoding="async"
  />

  {/* Скрим под текстом: на мобиле фото короче и текст ложится на детальную
      часть кадра — кремовый градиент слева повышает контраст золотого текста.
      На десктопе слабее (текст и так лежит на спокойной зоне слева). */}
  <div
    class="absolute inset-0 z-[1] bg-gradient-to-r from-cream/85 via-cream/45 to-transparent lg:from-cream/55 lg:via-cream/10"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 mx-auto h-full max-w-design px-[7.55%]">
    <div class="flex h-full flex-col justify-center pt-[80px] lg:pt-0">
      <h1 class="font-heading text-h1 uppercase text-gold leading-tight">
        {lines.map((line, i) => (
          <>
            {line}
            {i < lines.length - 1 && <br />}
          </>
        ))}
      </h1>

      <p class="mt-[27px] max-w-[632px] font-sans text-body-lg text-[#5a4f33] leading-relaxed">
        {lead}
      </p>

      {showStar && (
        <img
          src="/assets/images/star-sign.svg"
          alt=""
          width="43"
          height="50"
          class="mt-[21px] h-[50px] w-[43px]"
        />
      )}
    </div>
  </div>
</section>
