---
/**
 * ServiceIconRow — ряд «иконка + подпись» (фичи/преимущества).
 *
 * Нативная пересборка нижнего ряда BTL-баннера (Non-Invasive No Downtime /
 * Proactive & Corrective Procedure / Quick Procedure). Иконки — вырезанные
 * круглые BTL-иконки (прозрачный фон), подписи — нативный текст.
 */
import { imgDim } from '../../data/imageDimensions';
interface Item {
  icon: string;
  label: string;
}
interface Props {
  items: Item[];
}
const { items } = Astro.props;
---

<section class="w-full bg-cream pb-20 pt-4" data-section="service-icon-row">
  <div class="mx-auto max-w-design px-[7.55%]">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-x-8 gap-y-10 max-w-[900px] mx-auto">
      {items.map((it) => (
        <div class="flex flex-col items-center text-center">
          <img
            src={it.icon}
            alt=""
            width={imgDim(it.icon)?.w}
            height={imgDim(it.icon)?.h}
            class="h-[88px] w-[88px]"
            loading="lazy"
          />
          <p class="mt-4 font-sans text-[clamp(15px,1.25vw,18px)] text-[#5a4f33] leading-snug whitespace-pre-line">{it.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
