---
/**
 * ServiceBeforeAfter — галерея до/после.
 *
 * Используется на странице emsculpt (узел Figma 1:5559 Image 90 — placeholder
 * 1598×654). На макете виден один кадр с двумя фото бок-о-бок
 * (BEFORE | AFTER EMSCULPT!) и caption под ним
 * "X months after the last treatment, courtesy of Suzanne Kilmer, M.D."
 *
 * Стрелки (узлы 1:5505 Path 18, 1:5506 Path 19) намекают на возможность
 * листать несколько кейсов — но в данных только один. На случай, если придёт
 * несколько кейсов, делаем простой стэк по вертикали (без слайдера, чтобы
 * не тянуть JS-зависимость; если клиент попросит — добавим потом).
 *
 * Контент-модель:
 *   {
 *     title?: "",   // на текущей странице emsculpt — нет заголовка над галереей
 *     items: [
 *       {
 *         beforeImage: "/assets/.../before-1.webp",
 *         afterImage: "/assets/.../after-1.webp",
 *         caption: "3 months after the last treatment...",
 *         alt: "Patient 1 abdomen before and after Emsculpt Neo"
 *       },
 *       ...
 *     ]
 *   }
 */

interface BeforeAfterItem {
  /** Режим «одна композит-картинка» (emsculpt, Figma 1:5559): готовый кадр
   *  BEFORE | AFTER с уже впечатанными подписями и caption — рендерим как есть,
   *  без накладных бейджей и без отдельного caption. */
  image?: string;
  /** Классический режим «два фото» (бейджи рисует компонент). */
  beforeImage?: string;
  afterImage?: string;
  caption?: string;
  alt: string;
}

interface Props {
  title?: string;
  items: BeforeAfterItem[];
  /** Горизонтальная карусель (scroll-snap + стрелки) вместо вертикального стека.
   *  Для emsculpt: набор готовых BEFORE|AFTER композит-карточек (live BTL «BA cards»). */
  carousel?: boolean;
  /** Опц. подпись под всей галереей (мелкая, по центру — атрибуция/результаты). */
  caption?: string;
}

import { imgDim } from '../../data/imageDimensions';
const { title, items, carousel = false, caption } = Astro.props;
---

<section
  class="w-full bg-cream py-16"
  data-section="service-before-after"
>
  <div class="mx-auto max-w-design px-[7.55%]">
    {title && (
      <h2 class="font-heading text-h1 uppercase text-gold leading-tight text-center mb-12">
        {title}
      </h2>
    )}

    {carousel ? (
      <div class="relative max-lg:-mx-[7.55vw]" data-ba-carousel>
        <div
          class="ba-track flex snap-x snap-mandatory overflow-x-auto scroll-smooth gap-6 pb-2"
          data-ba-track
        >
          {items.map((item) => (
            <figure class="snap-center shrink-0 w-full">
              <img
                src={item.image ?? item.beforeImage}
                alt={item.alt}
                class="block w-full aspect-[1400/573] object-contain rounded-md bg-white"
                loading="lazy"
              />
              {!item.image && item.caption && (
                <figcaption class="mt-4 text-center font-sans text-[16px] text-gold leading-relaxed">
                  {item.caption}
                </figcaption>
              )}
            </figure>
          ))}
        </div>

        {items.length > 1 && (
          <>
            <button
              type="button"
              data-ba-prev
              aria-label="Previous result"
              class="absolute left-2 top-1/2 -translate-y-1/2 z-10 hidden lg:grid h-11 w-11 place-items-center rounded-full bg-gold text-cream text-2xl leading-none shadow-md transition-colors hover:bg-[#6f5b26]"
            >‹</button>
            <button
              type="button"
              data-ba-next
              aria-label="Next result"
              class="absolute right-2 top-1/2 -translate-y-1/2 z-10 hidden lg:grid h-11 w-11 place-items-center rounded-full bg-gold text-cream text-2xl leading-none shadow-md transition-colors hover:bg-[#6f5b26]"
            >›</button>
          </>
        )}
      </div>
    ) : (
    <div class="space-y-12">
      {items.map((item) => (
        <figure>
          {item.image ? (
            /* Композит-кадр (emsculpt): подписи + caption уже в самой картинке */
            <img
              src={item.image}
              alt={item.alt}
              width={imgDim(item.image)?.w}
              height={imgDim(item.image)?.h}
              class="block w-full max-w-[1598px] mx-auto rounded-md"
              loading="lazy"
            />
          ) : (
          <div class="grid grid-cols-2 gap-1 max-w-[1598px] mx-auto bg-white">
            {/* BEFORE */}
            <div class="relative aspect-[4/3]">
              <img
                src={item.beforeImage}
                alt={`Before — ${item.alt}`}
                class="block h-full w-full object-cover"
                loading="lazy"
              />
              <span class="absolute top-4 left-4 font-sans text-[18px] uppercase tracking-wider text-gold bg-cream/80 px-3 py-1 rounded">
                Before
              </span>
            </div>
            {/* AFTER */}
            <div class="relative aspect-[4/3]">
              <img
                src={item.afterImage}
                alt={`After — ${item.alt}`}
                class="block h-full w-full object-cover"
                loading="lazy"
              />
              <span class="absolute top-4 left-4 font-sans text-[18px] uppercase tracking-wider text-gold bg-cream/80 px-3 py-1 rounded">
                After
              </span>
            </div>
          </div>
          )}
          {!item.image && item.caption && (
            <figcaption class="mt-4 text-center font-sans text-[16px] text-gold leading-relaxed">
              {item.caption}
            </figcaption>
          )}
        </figure>
      ))}
    </div>
    )}{caption && <p class="mt-8 text-center font-sans text-[clamp(13px,0.94vw,16px)] italic text-gold/80 mx-auto max-w-[900px]">{caption}</p>}
  </div>

  {carousel && (
    <script is:inline>
      (function () {
        var mq = window.matchMedia('(max-width: 1023px)');
        document.querySelectorAll('[data-ba-carousel]').forEach(function (root) {
          var track = root.querySelector('[data-ba-track]');
          var prev = root.querySelector('[data-ba-prev]');
          var next = root.querySelector('[data-ba-next]');
          if (!track) return;
          function step(dir) { track.scrollBy({ left: dir * track.clientWidth, behavior: 'smooth' }); }
          if (prev) prev.addEventListener('click', function () { step(-1); });
          if (next) next.addEventListener('click', function () { step(1); });

          // Mobile-only auto-rotation. Native touch-swipe (overflow-x scroll-snap)
          // stays enabled; auto-rotation pauses on interaction and resumes when idle.
          var timer = null, resumeT = null;
          function atEnd() { return track.scrollLeft + track.clientWidth >= track.scrollWidth - 4; }
          function advance() { if (atEnd()) track.scrollTo({ left: 0, behavior: 'smooth' }); else step(1); }
          function start() { if (!timer && mq.matches) timer = setInterval(advance, 3500); }
          function stop() { if (timer) { clearInterval(timer); timer = null; } }
          function bump() { stop(); clearTimeout(resumeT); resumeT = setTimeout(start, 6000); }
          ['pointerdown', 'touchstart', 'wheel'].forEach(function (ev) {
            track.addEventListener(ev, bump, { passive: true });
          });
          function sync() { if (mq.matches) start(); else stop(); }
          if (mq.addEventListener) mq.addEventListener('change', sync);
          else if (mq.addListener) mq.addListener(sync);
          sync();
        });
      })();
    </script>
  )}
</section>

<style>
  .ba-track { scrollbar-width: none; -ms-overflow-style: none; }
  .ba-track::-webkit-scrollbar { display: none; }
</style>
