---
/**
 * ServiceRoadmap — 2-колоночный список шагов / roadmap.
 *
 * Используется на странице hormone (узлы Figma 1:3239, 1:3310, 1:3329, 1:3355):
 *  - Центрированный заголовок ("FROM SYMPTOM TO SOLUTION: / YOUR ROADMAP TO VITALITY")
 *  - Центрированный интро-параграф (5 строк)
 *  - 2 колонки по 2-3 шага в каждой. Каждый шаг = uppercase заголовок + body.
 *
 * Фон cream (под gold-фоном Common Signs, как раз граница между секциями).
 *
 * Контент-модель:
 *   {
 *     title: "From Symptom to Solution:\nYour Roadmap to Vitality",
 *     intro: "Now that we've identified...",
 *     items: [
 *       { title: "The Discovery: ...", body: "We don't guess..." },
 *       ...
 *     ]
 *   }
 */

interface RoadmapItem {
  title: string;
  body: string;
}

interface Props {
  title: string;
  intro: string;
  items: RoadmapItem[];
  showStar?: boolean;
}

const { title, intro, items, showStar = false } = Astro.props;
const titleLines = title.split('\n');
---

<section
  class="w-full bg-white py-16 lg:py-0 lg:h-[1142px] lg:flex lg:items-center"
  data-section="service-roadmap"
>
  <div class="mx-auto w-full max-w-design px-[7.55%]">
    <div class="text-center">
      {showStar && (
        <img
          src="/assets/images/star-sign.svg"
          alt=""
          width="43"
          height="50"
          class="mx-auto mb-6 h-[50px] w-[43px]"
        />
      )}
      <h2 class="font-heading text-h1 uppercase text-gold leading-tight">
        {titleLines.map((line, i) => (
          <>
            {line}
            {i < titleLines.length - 1 && <br />}
          </>
        ))}
      </h2>

      <p class="mx-auto mt-6 max-w-[900px] font-sans text-body-lg text-[#5a4f33] leading-relaxed">
        {intro}
      </p>
    </div>

    <ul class="mt-14 grid grid-cols-1 lg:grid-cols-2 gap-x-16 gap-y-10 max-w-[1760px] mx-auto">
      {items.map((item) => (
        <li class="font-sans text-body-lg text-[#5a4f33] leading-relaxed">
          <h3 class="font-sans font-semibold uppercase tracking-wide text-gold">
            {item.title}
          </h3>
          <p class="mt-2">{item.body}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
