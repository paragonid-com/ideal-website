---
/**
 * ServiceTextWithPhoto — универсальная "текст + фото" секция.
 *
 * Базовая структура:
 *   - Заголовок (3-4 строки)
 *   - Многоабзацный body
 *   - Фото
 *
 * Опциональное расширение (для exomind: HOW EXOMIND WORKS и WHY CHOOSE):
 *   - bullets: список пунктов
 *   - bulletStyle: 'dash' | 'number' (default 'dash' — _, для нумерованного 1_ 2_ 3_)
 *   - tail: текст-параграф после буллетов (заключение)
 *
 * Если bullets заданы — body становится "введением" перед списком,
 * затем рендерится список, затем (опционально) tail. Без bullets компонент
 * работает как раньше — просто body как многоабзацный текст.
 *
 * Используется для блоков, которые структурно похожи на ServiceWhoFor /
 * ServiceWhyTrust, но не подходят ни под один из них:
 *
 *   - hormone: "RECLAIMING YOURSELF: A NEW STANDARD FOR YOUR HEALTH"
 *     (узлы Figma 1:3257, 1:3283, 1:3370 — фото справа)
 *   - exomind: "HOW EXOMIND WORKS?" (фото слева, нумерованный список)
 *   - exomind: "WHY CHOOSE IDEAL MEDICAL & WELLNESS FOR EXOMIND?"
 *     (фото справа, dash-список с заключительным параграфом)
 *
 * Поддерживает `imageSide: 'left' | 'right'`.
 */

interface Props {
  title: string;
  body: string;
  image: string;
  imageAlt: string;
  /** Где фото — слева или справа. Default 'right'. */
  imageSide?: 'left' | 'right';
  /** Опциональный буллет-список под body */
  bullets?: string[];
  /** Стиль маркеров для буллетов: dash (default) или number. */
  bulletStyle?: 'dash' | 'number';
  /** Опциональный заключительный параграф после буллетов */
  tail?: string;
  /** Показать gold-звезду top-right у заголовка (hormone Reclaiming) */
  showStar?: boolean;
}

const {
  title,
  body,
  image,
  imageAlt,
  imageSide = 'right',
  bullets,
  bulletStyle = 'dash',
  tail,
  showStar = false,
} = Astro.props;
const titleLines = title.split('\n');
const paragraphs = body.split(/\n{2,}/).map((p) => p.trim()).filter(Boolean);
const tailParas = (tail ?? '').split(/\n{2,}/).map((p) => p.trim()).filter(Boolean);

const textOrderClass = imageSide === 'left' ? 'lg:order-2' : 'lg:order-1';
const imageOrderClass = imageSide === 'left' ? 'lg:order-1' : 'lg:order-2';
---

<section
  class="w-full bg-cream"
  data-section="service-text-with-photo"
>
  <div class="mx-auto max-w-design grid grid-cols-1 lg:grid-cols-2 items-center min-h-[800px]">
    {/* Текст */}
    <div class={`px-[7.55%] py-24 ${textOrderClass}`}>
      <div class="flex items-start justify-between gap-4">
        <h2 class="font-heading text-h1 uppercase text-gold leading-tight">
          {titleLines.map((line, i) => (
            <>
              {line}
              {i < titleLines.length - 1 && <br />}
            </>
          ))}
        </h2>
        {showStar && (
          <img
            src="/assets/images/star-sign.svg"
            alt=""
            width="43"
            height="50"
            class="mt-1 h-[50px] w-[43px] flex-shrink-0"
          />
        )}
      </div>

      <div class="mt-12 max-w-[660px] space-y-6 font-sans text-body-lg text-gold leading-relaxed">
        {paragraphs.map((p) => <p>{p}</p>)}

        {bullets && bullets.length > 0 && (
          <ul class="mt-4 space-y-3">
            {bullets.map((b, i) => (
              <li class="flex gap-3">
                <span aria-hidden="true" class="select-none flex-shrink-0 font-sans text-body-lg leading-relaxed">
                  {bulletStyle === 'number' ? `${i + 1}.` : '—'}
                </span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        )}

        {tailParas.map((p) => <p>{p}</p>)}
      </div>
    </div>

    {/* Фото */}
    <div class={`relative h-full min-h-[600px] ${imageOrderClass}`}>
      <img
        src={image}
        alt={imageAlt}
        class="block h-full w-full object-cover"
        loading="lazy"
      />
    </div>
  </div>
</section>
