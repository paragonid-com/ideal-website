---
/**
 * ServiceWhatIs — секция "What is X?".
 *
 * Структура (узлы Figma 1:1500, 1:1510, 1:1549 для Weight Loss):
 *  - Слева: фото (clip-path 1:1545: x=0 y=895 w=923 h=939)
 *  - Справа: заголовок "What is Medical Weight Loss?" (x=1002 y=890)
 *           + длинный многоабзацный текст (x=1002 y=1076 width=693)
 *
 * Высота секции в Figma ~1100px (с фоном cream сверху, под Hero).
 *
 * Body — многоабзацный текст, абзацы разделены пустой строкой (\n\n).
 */

interface Props {
  title: string;
  image: string;
  imageAlt: string;
  body: string;
  /** Показать gold-звезду справа от заголовка (Figma Peptide узел 1:3865). */
  showStar?: boolean;
  /** Класс высоты секции на lg. Default — прежнее поведение (min-h-940).
   *  hormone передаёт точную высоту Figma `lg:h-[1083px]` (узлы 814→1897). */
  sectionHeight?: string;
}

const { title, image, imageAlt, body, showStar = false, sectionHeight = 'lg:min-h-[940px]' } = Astro.props;
const lines = title.split('\n');
// Разбиваем body на абзацы
const paragraphs = body.split(/\n{2,}/).map(p => p.trim()).filter(Boolean);
---

<section
  class="w-full bg-cream"
  data-section="service-what-is"
>
  <div class={`mx-auto max-w-design grid grid-cols-1 lg:grid-cols-2 items-center ${sectionHeight}`}>
    {/* Левая колонка — фото на всю высоту секции */}
    <div class="relative h-[320px] md:h-[480px] lg:h-full">
      <img
        src={image}
        alt={imageAlt}
        class="block h-full w-full object-cover"
        loading="lazy"
      />
    </div>

    {/* Правая колонка — текст */}
    <div class="relative px-[7.55%] py-24">
      <h2 class="font-heading text-h1 uppercase text-gold leading-tight">
        {lines.map((line, i) => (
          <>
            {line}
            {i < lines.length - 1 && <br />}
          </>
        ))}
      </h2>

      {showStar && (
        <img
          src="/assets/images/star-sign.svg"
          alt=""
          width="43"
          height="50"
          class="mt-6 h-[50px] w-[43px]"
        />
      )}

      <div class="mt-12 space-y-6 max-w-[693px] font-sans text-body-lg text-[#5a4f33] leading-relaxed">
        {paragraphs.map((p) => {
          const innerLines = p.split('\n');
          // Если все строки абзаца начинаются с "_ " — это буллет-список
          // (соглашение Figma: "_" = маркер). Рендерим <ul> с "—".
          const isBulletBlock =
            innerLines.length > 0 && innerLines.every((l) => l.trim().startsWith('_ '));
          if (isBulletBlock) {
            return (
              <ul class="space-y-3">
                {innerLines.map((l) => (
                  <li class="flex gap-3">
                    <span aria-hidden="true" class="select-none flex-shrink-0">—</span>
                    <span>{l.trim().replace(/^_\s+/, '')}</span>
                  </li>
                ))}
              </ul>
            );
          }
          return (
            <p>
              {innerLines.map((line, i) => (
                <>
                  {line}
                  {i < innerLines.length - 1 && <br />}
                </>
              ))}
            </p>
          );
        })}
      </div>
    </div>
  </div>
</section>
