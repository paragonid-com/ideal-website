---
/**
 * ServiceWhatIs — секция "What is X?".
 *
 * Структура (узлы Figma 1:1500, 1:1510, 1:1549 для Weight Loss):
 *  - Слева: фото (clip-path 1:1545: x=0 y=895 w=923 h=939)
 *  - Справа: заголовок "What is Medical Weight Loss?" (x=1002 y=890)
 *           + длинный многоабзацный текст (x=1002 y=1076 width=693)
 *
 * Высота секции в Figma ~1100px (с фоном cream сверху, под Hero).
 *
 * Body — многоабзацный текст, абзацы разделены пустой строкой (\n\n).
 */

interface Props {
  title: string;
  image: string;
  imageAlt: string;
  body: string;
  /** Показать gold-звезду справа от заголовка (Figma Peptide узел 1:3865). */
  showStar?: boolean;
  /** Класс высоты/пропорции секции на lg. Default — прежнее поведение
   *  (min-h-940). hormone передаёт `lg:aspect-[1920/1083]` (узлы 814→1897),
   *  чтобы высота блока всегда была пропорциональна ширине как в Figma. */
  sectionHeight?: string;
  /** Класс раскладки колонок на lg. Default `lg:grid-cols-2` (50/50).
   *  hormone сужает фото: `lg:grid-cols-[44fr_56fr]`. */
  gridColsClass?: string;
  /** Вертикальное выравнивание колонок. Default `items-center`.
   *  hormone — `items-stretch` (фото на всю высоту, текст сверху как в Figma). */
  align?: string;
  /** Класс размера заголовка. Default `text-h1`. hormone передаёт
   *  vw-масштабируемый `text-[clamp(28px,3.23vw,62px)]`, чтобы заголовок всегда
   *  умещался в 5 строк и блок держал пропорцию Figma на любой ширине. */
  headingClass?: string;
  /** Класс размера body-текста. Default `text-body-lg`. hormone передаёт
   *  vw-масштабируемый `text-[clamp(16px,1.09vw,21px)]`, чтобы и текст
   *  масштабировался пропорционально и блок держал пропорцию Figma. */
  bodyClass?: string;
  /** На мобайле показать сначала текст, потом фото (Default — фото сверху). */
  mobileTextFirst?: boolean;
}

const {
  title, image, imageAlt, body, showStar = false,
  sectionHeight = 'lg:min-h-[940px]',
  gridColsClass = 'lg:grid-cols-2',
  align = 'items-center',
  headingClass = 'text-h1 leading-tight',
  bodyClass = 'text-body-lg leading-relaxed',
  mobileTextFirst = false,
} = Astro.props;
// На мобайле меняем порядок колонок (текст сверху), на lg — как в DOM (фото слева).
const imgOrder = mobileTextFirst ? 'max-lg:order-2' : '';
const textOrder = mobileTextFirst ? 'max-lg:order-1' : '';
const lines = title.split('\n');
// Разбиваем body на абзацы
const paragraphs = body.split(/\n{2,}/).map(p => p.trim()).filter(Boolean);
---

<section
  class="w-full bg-cream"
  data-section="service-what-is"
>
  <div class={`mx-auto max-w-design grid grid-cols-1 ${gridColsClass} ${align} ${sectionHeight}`}>
    {/* Левая колонка — фото на всю высоту секции */}
    <div class={`relative h-[320px] md:h-[480px] lg:h-full lg:min-h-0 ${imgOrder}`}>
      <img
        src={image}
        alt={imageAlt}
        class="block h-full w-full object-cover"
        loading="lazy"
      />
    </div>

    {/* Правая колонка — текст. При align=items-stretch (hormone) колонка
        тянется на всю высоту, текст ложится сверху — как в Figma. */}
    <div class={`relative px-[7.55%] py-16 ${textOrder}`}>
      <h2 class={`font-heading ${headingClass} uppercase text-gold`}>
        {lines.map((line, i) => (
          <>
            {line}
            {i < lines.length - 1 && <br />}
          </>
        ))}
      </h2>

      {showStar && (
        <img
          src="/assets/images/star-sign.svg"
          alt=""
          width="43"
          height="50"
          class="mt-6 h-[50px] w-[43px]"
        />
      )}

      <div class={`mt-12 space-y-6 max-w-[693px] font-sans ${bodyClass} text-[#5a4f33]`}>
        {paragraphs.map((p) => {
          const innerLines = p.split('\n');
          // Если все строки абзаца начинаются с "_ " — это буллет-список
          // (соглашение Figma: "_" = маркер). Рендерим <ul> с "—".
          const isBulletBlock =
            innerLines.length > 0 && innerLines.every((l) => l.trim().startsWith('_ '));
          if (isBulletBlock) {
            return (
              <ul class="space-y-3">
                {innerLines.map((l) => (
                  <li class="flex gap-3">
                    <span aria-hidden="true" class="select-none flex-shrink-0">—</span>
                    <span>{l.trim().replace(/^_\s+/, '')}</span>
                  </li>
                ))}
              </ul>
            );
          }
          return (
            <p>
              {innerLines.map((line, i) => (
                <>
                  {line}
                  {i < innerLines.length - 1 && <br />}
                </>
              ))}
            </p>
          );
        })}
      </div>
    </div>
  </div>
</section>
