---
/**
 * ServiceGoldBanner — full-width баннер с заголовком (pull-quote).
 *
 * variant='gold' (DEFAULT — прежнее поведение, байт-в-байт):
 *   фон gold, текст cream. hormone pull-quote (1:3245/1:3467) и любые баннеры
 *   с кремовой кнопкой-CTA.
 * variant='cream' (exomind midGoldBanner1/2, Figma 1:3155/1:3158):
 *   фон cream, центрированный ЗОЛОТОЙ заголовок (text-[clamp] uppercase).
 *   CTA у exomind-баннеров рендерится ОТДЕЛЬНЫМ ServiceCTABand (#dbba5f
 *   straddle) в [slug].astro, поэтому здесь ctaLabel для cream обычно не задаётся.
 *
 * Контент: text (с \n), опц. ctaLabel/ctaHref (кремовая кнопка — только gold).
 */
interface Props {
  text: string;
  ctaLabel?: string;
  ctaHref?: string;
  /** 'gold' (default) | 'cream' (exomind — фон cream, золотой заголовок). */
  variant?: 'gold' | 'cream';
}

const {
  text,
  ctaLabel,
  ctaHref = 'https://www.joinblvd.com/b/ideal-medical-and-wellness/widget#/visit-type',
  variant = 'gold',
} = Astro.props;
const lines = text.split('\n');
const isCream = variant === 'cream';
---

<section
  class:list={[
    isCream ? 'w-full bg-cream' : 'w-full bg-gold',
    isCream
      ? 'py-16 lg:py-24'
      : (ctaLabel ? 'py-20' : 'py-14 lg:py-10 lg:min-h-[294px] lg:flex lg:items-center'),
  ]}
  data-section="service-gold-banner"
>
  <div class="mx-auto w-full max-w-design px-[4%] lg:px-[7.55%] text-center">
    <p
      class:list={[
        isCream ? 'font-heading text-gold' : 'font-heading text-cream',
        isCream
          ? 'text-[clamp(26px,3.23vw,62px)] uppercase leading-tight'
          : (ctaLabel ? 'text-h1 uppercase leading-tight' : 'text-[clamp(19px,3.28vw,72px)] leading-[1.15]'),
      ]}
    >
      {lines.map((line, i) => (
        <>
          {line}
          {i < lines.length - 1 && <br />}
        </>
      ))}
    </p>

    {ctaLabel && (
      <a
        href={ctaHref}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-10 inline-block bg-cream text-gold font-sans uppercase tracking-wider text-[18px] px-12 py-4"
      >
        {ctaLabel}
      </a>
    )}
  </div>
</section>
