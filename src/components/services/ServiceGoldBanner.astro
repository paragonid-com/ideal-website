---
/**
 * ServiceGoldBanner — full-width баннер с pull-quote на gold-фоне.
 *
 * Используется на:
 *  - hormone (узлы Figma 1:3245 Rectangle 102 + 1:3467 text):
 *      Фон gold (1920×294), центрированный текст, ~38-44px font-heading.
 *  - exomind (узлы Figma 1:3155 заголовок + 1:2904 CTA-кнопка):
 *      То же + кнопка BOOK APPOINTMENT внутри/под текстом.
 *
 * Контент-модель:
 *   - text: строка (поддерживает \n для переноса) — обязательное
 *   - ctaLabel, ctaHref: опциональная кнопка под текстом
 */

interface Props {
  text: string;
  /** Опционально: текст кнопки под баннером */
  ctaLabel?: string;
  /** Опционально: куда ведёт кнопка (default — booking-виджет Boulevard) */
  ctaHref?: string;
}

const {
  text,
  ctaLabel,
  ctaHref = 'https://www.joinblvd.com/b/ideal-medical-and-wellness/widget#/visit-type',
} = Astro.props;
const lines = text.split('\n');
---

<section
  class:list={[
    'w-full bg-gold',
    // hormone pull-quote (без CTA) — точная высота Figma 294px (Rect 102),
    // текст по центру на 2 строки. exomind-баннеры (с CTA) — прежний py-20.
    ctaLabel ? 'py-20' : 'py-14 lg:py-0 lg:h-[294px] lg:flex lg:items-center',
  ]}
  data-section="service-gold-banner"
>
  <div class="mx-auto w-full max-w-design px-[7.55%] text-center">
    <p
      class:list={[
        'font-heading text-cream',
        // exomind-баннеры (с CTA) — крупный h1-стиль uppercase как в Figma;
        // hormone pull-quote (без CTA) — Optima ~62px (Figma 1:3467), sentence-case.
        ctaLabel ? 'text-h1 uppercase leading-tight' : 'text-h1 leading-[1.15]',
      ]}
    >
      {lines.map((line, i) => (
        <>
          {line}
          {i < lines.length - 1 && <br />}
        </>
      ))}
    </p>

    {ctaLabel && (
      <a
        href={ctaHref}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-10 inline-block bg-cream text-gold font-sans uppercase tracking-wider text-[18px] px-12 py-4"
      >
        {ctaLabel}
      </a>
    )}
  </div>
</section>
