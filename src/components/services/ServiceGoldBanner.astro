---
/**
 * ServiceGoldBanner — full-width баннер с pull-quote на gold-фоне.
 *
 * Используется на:
 *  - hormone (узлы Figma 1:3245 Rectangle 102 + 1:3467 text):
 *      Фон gold (1920×294), центрированный текст, ~38-44px font-heading.
 *  - exomind (узлы Figma 1:3155 заголовок + 1:2904 CTA-кнопка):
 *      То же + кнопка BOOK APPOINTMENT внутри/под текстом.
 *
 * Контент-модель:
 *   - text: строка (поддерживает \n для переноса) — обязательное
 *   - ctaLabel, ctaHref: опциональная кнопка под текстом
 */

interface Props {
  text: string;
  /** Опционально: текст кнопки под баннером */
  ctaLabel?: string;
  /** Опционально: куда ведёт кнопка (default '#book') */
  ctaHref?: string;
}

const { text, ctaLabel, ctaHref = '#book' } = Astro.props;
const lines = text.split('\n');
---

<section
  class="w-full bg-gold py-20"
  data-section="service-gold-banner"
>
  <div class="mx-auto max-w-design px-[7.55%] text-center">
    <p
      class:list={[
        'font-heading text-cream',
        // exomind-баннеры (с CTA) — крупный h1-стиль как в Figma;
        // hormone pull-quote (без CTA) — прежний более мелкий размер.
        ctaLabel ? 'text-h1 uppercase leading-tight' : 'text-[38px] md:text-[44px] leading-snug',
      ]}
    >
      {lines.map((line, i) => (
        <>
          {line}
          {i < lines.length - 1 && <br />}
        </>
      ))}
    </p>

    {ctaLabel && (
      <a
        href={ctaHref}
        data-todo="booking-system"
        class="mt-10 inline-block bg-cream text-gold font-sans uppercase tracking-wider text-[18px] px-12 py-4"
      >
        {ctaLabel}
      </a>
    )}
  </div>
</section>
