---
/**
 * ServiceBenefits — сетка карточек преимуществ.
 *
 * Структура (узлы Figma для Weight Loss 1:1550 + 1:1600-1612 + 1:1615-1619):
 *  - Заголовок секции (центрирован, 2 строки)
 *  - Интро-параграф под ним
 *  - Сетка карточек: иконка + заголовок (2 строки) + описание (3-7 строк)
 *
 * 🎯 Решение по layout (из ревью всех 11 страниц):
 *    Используется единая сетка 3 колонки auto-flow для упрощения контент-модели.
 *    Эталон Weight Loss в Figma имеет асимметрию "2 сверху + 3 снизу" — здесь
 *    реализован вариант "3 сверху + 2 снизу" (с центровкой нижнего ряда).
 *    Это визуально близкий вариант, который автоматически работает для 3-6
 *    элементов на любой странице без необходимости описывать каждый layout.
 *
 *    Страницы со специфичной структурой (hormone, emsculpt, exomind, emface,
 *    emsella) пока в draft: true — для них нужны отдельные шаблоны.
 *
 * Иконка — Astro ImageMetadata из src/assets/services/*, обрабатывается
 * через Astro Image для оптимизации.
 *
 * Фон секции — золотой gradient (см. узел 1:1495 GOLD BACK), у нас простой
 * tailwind bg-gold/[оттенок]. Подберём ниже.
 */

import { Image } from 'astro:assets';

interface Benefit {
  title: string;
  description?: string;
  icon: any; // ImageMetadata из Astro Image
  iconAlt?: string;
}

interface Props {
  title: string;
  intro?: string;
  benefits: Benefit[];
  /** Peptide-режим: icon + title без description, сетка 3x3. */
  iconOnly?: boolean;
  /** Показать gold-звезду над заголовком (Figma Peptide узел 1:3878). */
  showStar?: boolean;
}

const { title, intro, benefits, iconOnly = false, showStar = false } = Astro.props;
const titleLines = title.split('\n');
---

<section
  class="relative w-full py-24 overflow-hidden"
  data-section="service-benefits"
  style="background: radial-gradient(ellipse at center, #faf8eb 0%, #d2bea3 70%, #b89a76 100%);"
>
  <div class="mx-auto max-w-design px-[7.55%]">
    <div class="text-center">
      {showStar && (
        <img
          src="/assets/images/star-sign.svg"
          alt=""
          width="43"
          height="50"
          class="mx-auto mb-6 h-[50px] w-[43px]"
        />
      )}

      <h2 class="font-heading text-h1 uppercase text-gold leading-tight">
        {titleLines.map((line, i) => (
          <>
            {line}
            {i < titleLines.length - 1 && <br />}
          </>
        ))}
      </h2>

      {intro && (
        <p class="mx-auto mt-8 max-w-[779px] font-sans text-body-lg text-gold leading-relaxed">
          {intro}
        </p>
      )}
    </div>

    {/* flex flex-wrap с justify-center: 3+3 (6), 3+2 (5), 3+3+3 (9 icon-only). */}
    <ul class={`flex flex-wrap justify-center ${iconOnly ? 'mt-16 gap-x-8 gap-y-20' : 'mt-20 gap-x-8 gap-y-16'}`}>
      {benefits.map((b) => (
        <li class="flex flex-col items-center text-center w-full sm:w-[calc(50%-1rem)] lg:w-[calc(33.333%-1.34rem)] max-w-[400px]">
          <div class={iconOnly ? 'h-[112px] w-[112px] flex items-center justify-center' : 'h-[104px] w-[104px] flex items-center justify-center'}>
            <Image
              src={b.icon}
              alt={b.iconAlt || b.title}
              width={iconOnly ? 112 : 104}
              height={iconOnly ? 112 : 104}
              class="h-full w-full object-contain"
            />
          </div>
          <h3 class={`font-heading uppercase text-gold leading-tight ${iconOnly ? 'mt-6 text-[22px] max-w-[300px]' : 'mt-6 text-[28px]'}`}>
            {b.title}
          </h3>
          {!iconOnly && b.description && (
            <p class="mt-4 font-sans text-[18px] text-gold leading-relaxed">
              {b.description}
            </p>
          )}
        </li>
      ))}
    </ul>
  </div>
</section>
