---
/**
 * ServiceWhyTrust — текст слева + фото команды справа.
 *
 * Используется на странице hormone (узлы Figma 1:3262, 1:3290, 1:3372):
 *  - Слева: заголовок "WHY TRUST IDEAL MEDICAL AND WELLNESS?" (3 строки)
 *           + многоабзацный body (660px ширина)
 *  - Справа: фото команды (960×791, узел 1:3380 rs=w_1200,h_1200)
 *
 * Фон cream. Очень похоже структурно на ServiceWhoFor (текст+фото), но:
 *  - нет буллет-списка
 *  - другой заголовок
 *  - body может быть многоабзацным
 *
 * Намеренно сделан отдельным компонентом, чтобы не плодить optional-поля
 * в ServiceWhoFor (там bullets уже обязательны для Weight Loss).
 */

interface Props {
  title: string;
  body: string;
  image: string;
  imageAlt: string;
  showStar?: boolean;
}

const { title, body, image, imageAlt, showStar = false } = Astro.props;
const titleLines = title.split('\n');
const paragraphs = body.split(/\n{2,}/).map((p) => p.trim()).filter(Boolean);
---

<section
  class="w-full bg-cream"
  data-section="service-why-trust"
>
  <div class="mx-auto max-w-design grid grid-cols-1 lg:grid-cols-2 items-center lg:aspect-[1920/759]">
    {/* Левая колонка — заголовок + body */}
    <div class="px-[7.55%] py-12 lg:py-0">
      <div class="flex items-start justify-between gap-4">
        <h2 class="font-heading text-[clamp(28px,3.23vw,62px)] uppercase text-gold leading-[1.1]">
          {titleLines.map((line, i) => (
            <>
              {line}
              {i < titleLines.length - 1 && <br />}
            </>
          ))}
        </h2>
        {showStar && (
          <img
            src="/assets/images/star-sign.svg"
            alt=""
            width="43"
            height="50"
            class="mt-1 h-[50px] w-[43px] flex-shrink-0"
          />
        )}
      </div>

      <div class="mt-[clamp(20px,2.86vw,55px)] max-w-[660px] space-y-[clamp(14px,1.46vw,28px)] font-sans text-[clamp(16px,1.09vw,21px)] text-[#5a4f33] leading-[1.4]">
        {paragraphs.map((p) => <p>{p}</p>)}
      </div>
    </div>

    {/* Правая колонка — фото. Высота блока задана aspect-[1920/759] на сетке,
        поэтому на lg фото тянется на всю высоту блока (h-full) и совпадает по
        пропорции с Figma (960×759) → все четверо видны, верх/низ блока = верх/низ
        фото. На мобайле (stacked) держим собственный aspect-ratio. */}
    <div class="relative w-full aspect-[960/759] lg:aspect-auto lg:h-full max-lg:min-h-[320px]">
      <img
        src={image}
        alt={imageAlt}
        class="block h-full w-full object-cover"
        loading="lazy"
      />
    </div>
  </div>
</section>
