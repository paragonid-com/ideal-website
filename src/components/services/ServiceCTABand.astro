---
/**
 * ServiceCTABand — band с кнопкой BOOK APPOINTMENT.
 *
 * Два варианта:
 *  1) overlap=false (DEFAULT, прежнее поведение) — кремовый band, py-12,
 *     центрированная пилюля bg-gold/text-cream. Используется всеми прочими
 *     страницами услуг без изменений.
 *  2) overlap=true (hormone и далее) — «straddle»: контейнер нулевой высоты,
 *     пилюля #dbba5f / текст #8d7431, центр ровно на шве между секциями
 *     (половина в верхней, половина в нижней), как в Figma. Band НЕ добавляет
 *     вертикальной высоты странице — соседние секции стыкуются вплотную.
 *
 * Цвета straddle-пилюли — из Figma (Rectangle 93 fill #dbba5f, текст 1:3434
 * #8d7431, Manrope Bold ~30px, полностью скруглённая). Ширина 488px (Figma).
 *
 * Кнопка ведёт на bookingCta.href из data/navigation.ts.
 */
import { bookingCta } from '../../data/navigation.ts';

interface Props {
  /** straddle-вариант (см. описание). Default false. */
  overlap?: boolean;
  /** Опц. переопределить текст кнопки. Default "BOOK APPOINTMENT". */
  label?: string;
  /** Опц. переопределить ссылку кнопки. Default bookingCta.href. */
  href?: string;
}
const { overlap = false, label = 'BOOK APPOINTMENT', href = bookingCta.href } = Astro.props;
---

{overlap ? (
  <div
    class="relative z-20 flex h-0 items-center justify-center w-full max-md:px-[7.55%]"
    data-section="service-cta-band"
  >
    <a
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center bg-[#dbba5f] text-[#8d7431] font-sans font-bold uppercase tracking-wider rounded-full
             md:min-w-[488px] max-md:w-full py-4 px-12 max-md:px-6 text-[20px] md:text-[30px] shadow-sm hover:brightness-[0.97] transition"
    >
      {label}
    </a>
  </div>
) : (
  <section class="w-full bg-cream py-12 flex justify-center max-md:px-[7.55%]" data-section="service-cta-band">
    <a
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center bg-gold text-cream font-sans uppercase tracking-wider rounded-full
             md:min-w-[488px] max-md:w-full py-4 px-12 max-md:px-6 text-[24px] hover:opacity-90 transition-opacity"
    >
      {label}
    </a>
  </section>
)}
