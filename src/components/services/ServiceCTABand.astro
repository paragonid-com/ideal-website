---
/**
 * ServiceCTABand — узкий band с кнопкой BOOK APPOINTMENT.
 * На каждой странице услуги в Figma встречается 3 раза:
 *  - после Hero (узлы для weight-loss: 1:1685)
 *  - после What is X (1:1688)
 *  - после Benefits (1:1691)
 *
 * Кнопка ведёт на bookingCta.href из data/navigation.ts.
 *
 * ⚠️ Параметры из Figma (узлы 1:1685-1693):
 *   - Контейнер 488×63
 *   - Текст "BOOK APPOINTMENT" — 24px, центрирован, padding ~30px вертикально
 *   - Фон золотой, текст cream
 */
import { bookingCta } from '../../data/navigation.ts';
---

<section class="w-full bg-cream py-12 flex justify-center" data-section="service-cta-band">
  <a
    href={bookingCta.href}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center justify-center bg-gold text-cream font-sans uppercase tracking-wider rounded-full
           min-w-[488px] py-4 px-12 text-[24px] hover:opacity-90 transition-opacity"
  >
    BOOK APPOINTMENT
  </a>
</section>
