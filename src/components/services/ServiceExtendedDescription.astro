---
/**
 * ServiceExtendedDescription — большой текстовый блок описания услуги без фото.
 *
 * Используется на странице emsculpt (узлы Figma 1:5451, 1:5454):
 *  - Заголовок по центру, 2 строки ("EMSCULPT NEOTM / MORE FOR LESS IN BODY SHAPING")
 *  - Большой многоабзацный текст под ним, ширина ~1120px, выравнен по центру.
 *
 * Фон cream.
 */

interface Props {
  title: string;
  body: string;
}

const { title, body } = Astro.props;
const titleLines = title.split('\n');
const paragraphs = body.split(/\n{2,}/).map((p) => p.trim()).filter(Boolean);
---

<section
  class="w-full bg-cream py-24"
  data-section="service-extended-description"
>
  <div class="mx-auto max-w-design px-[7.55%] flex flex-col items-center text-center">
    <h2 class="font-heading text-h1 uppercase text-gold leading-tight">
      {titleLines.map((line, i) => (
        <>
          {line}
          {i < titleLines.length - 1 && <br />}
        </>
      ))}
    </h2>

    <img src="/assets/images/star-sign.svg" alt="" width="43" height="50" class="mt-7 h-[44px] w-[38px]" />

    <div class="mx-auto mt-8 max-w-[1000px] space-y-5 font-sans text-body-lg text-[#5a4f33] leading-relaxed">
      {paragraphs.map((p) => <p>{p}</p>)}
    </div>
  </div>
</section>
