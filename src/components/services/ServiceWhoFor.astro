---
/**
 * ServiceWhoFor — секция "Who is X For?".
 *
 * Структура (узлы Figma 1:1620, 1:1623, 1:1628, 1:1647 для Weight Loss):
 *  - Слева (x=140 y=3496):
 *      * Заголовок "Who is Medical Weight Loss For?" (2 строки)
 *      * Лид-текст: пояснение + строка "You may be the ideal candidate ... if:"
 *      * Буллет-список с критериями (4 пункта на Weight Loss)
 *  - Справа (x=925 y=3276): большое фото (996×1203)
 *
 * Высота секции в Figma ~1000px.
 */

interface Props {
  title: string;
  image: string;
  imageAlt: string;
  lead: string;
  bullets: string[];
  /** Показать gold-звезду справа от заголовка (Figma Peptide узел 1:3900). */
  showStar?: boolean;
  /** Класс высоты/пропорции секции на lg. Default — прежнее min-h-[1000px].
   *  weight-loss передаёт '' — высоту задаёт фото-колонка (см. imageAspectClass). */
  sectionHeight?: string;
  /** Класс раскладки колонок на lg. Default `lg:grid-cols-2`. */
  gridColsClass?: string;
  /** Вертикальное выравнивание колонок. Default `items-center`. */
  align?: string;
  /** Класс размера заголовка. Default `text-h1 leading-tight`. */
  headingClass?: string;
  /** Класс размера lead/буллетов. Default `text-body-lg leading-relaxed`. */
  bodyClass?: string;
  /** Класс min-h фото-колонки. Default `lg:min-h-[700px]`. В aspect-режиме — ''. */
  imageMinH?: string;
  /** Если задан (напр. `lg:aspect-[996/993]`) — фото-колонка держит свою пропорцию
   *  на lg (object-cover кропит исходник), и ИМЕННО фото задаёт высоту секции.
   *  Это надёжно держит Figma-пропорцию на всех ширинах. Заменяет `lg:h-full`. */
  imageAspectClass?: string;
}

const {
  title, image, imageAlt, lead, bullets, showStar = false,
  sectionHeight = 'lg:min-h-[1000px]',
  gridColsClass = 'lg:grid-cols-2',
  align = 'items-center',
  headingClass = 'text-h1 leading-tight',
  bodyClass = 'text-body-lg leading-relaxed',
  imageMinH = 'lg:min-h-[700px]',
  imageAspectClass = '',
} = Astro.props;
const titleLines = title.split('\n');
const leadParas = lead.split(/\n{2,}/).map(p => p.trim()).filter(Boolean);
/* В aspect-режиме (imageAspectClass задан) фото-колонка держит свою пропорцию и
 * сама задаёт высоту секции; иначе — прежнее поведение (lg:h-full + min-h). */
const imageColClass = imageAspectClass
  ? `relative h-[320px] md:h-[480px] lg:h-auto ${imageAspectClass}`
  : `relative h-[320px] md:h-[480px] lg:h-full ${imageMinH}`;
---

<section
  class="w-full bg-cream"
  data-section="service-who-for"
>
  <div class={`mx-auto max-w-design grid grid-cols-1 ${gridColsClass} ${align} ${sectionHeight}`}>
    {/* Левая колонка — заголовок, lead, буллеты */}
    <div class="relative px-[7.55%] py-24">
      <h2 class={`font-heading ${headingClass} uppercase text-gold`}>
        {titleLines.map((line, i) => (
          <>
            {line}
            {i < titleLines.length - 1 && <br />}
          </>
        ))}
      </h2>

      {showStar && (
        <img
          src="/assets/images/star-sign.svg"
          alt=""
          width="43"
          height="50"
          class="mt-6 h-[50px] w-[43px]"
        />
      )}

      <div class={`mt-12 max-w-[685px] space-y-6 font-sans ${bodyClass} text-gold`}>
        {leadParas.map((p) => <p>{p}</p>)}
      </div>

      <ul class={`mt-8 space-y-6 max-w-[685px] font-sans ${bodyClass} text-gold`}>
        {bullets.map((b) => (
          <li class="flex gap-4">
            <span aria-hidden="true" class="select-none text-[24px] leading-[1.2]">•</span>
            <span>{b}</span>
          </li>
        ))}
      </ul>
    </div>

    {/* Правая колонка — фото */}
    <div class={imageColClass}>
      <img
        src={image}
        alt={imageAlt}
        class="block h-full w-full object-cover"
        loading="lazy"
      />
    </div>
  </div>
</section>
