---
/**
 * ServiceConditionsList — секция с центрированным списком на gold-фоне.
 * exomind (узлы Figma 1:2903 eyebrow + 1:3144 список).
 *
 * Структура:
 *   - eyebrow-заголовок (верхний-левый, ~24px, Figma 1:2903)
 *   - центрированный список крупным шрифтом (~58px Optima, плотный шаг 55px,
 *     Figma 1:3144)
 *   - опц. caption под списком (compliance-подпись)
 */
interface Props {
  title: string;
  items: string[];
  /** Опц. подпись под списком (мелкая, по центру). */
  caption?: string;
  /** Опц. центрировать eyebrow-заголовок (по умолчанию слева). Default false. */
  titleCentered?: boolean;
}

const { title, items, caption, titleCentered = false } = Astro.props;
---

<section
  class="w-full bg-gold/30 py-24"
  data-section="service-conditions-list"
>
  <div class="mx-auto max-w-design px-[7.55%]">
    <p class={`font-sans text-[clamp(18px,1.25vw,24px)] tracking-wider text-gold uppercase${titleCentered ? ' text-center' : ''}`}>
      {title}
    </p>

    <ul class="mt-16 text-center">
      {items.map((it) => (
        <li class="font-heading text-[clamp(32px,3.02vw,58px)] uppercase text-gold leading-[0.95]">
          {it}
        </li>
      ))}
    </ul>

    {caption && (
      <p class="mt-12 text-center font-sans text-[clamp(13px,0.94vw,18px)] italic text-gold/80">
        {caption}
      </p>
    )}
  </div>
</section>
