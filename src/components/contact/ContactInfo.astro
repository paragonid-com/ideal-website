---
/**
 * ContactInfo — инфо-блок на странице Contact: часы работы + адрес + телефон.
 *
 * Заменяет дублирующую вторую форму "Start Your Wellness Transformation",
 * которая повторяла заголовок и поля из ContactHero. На contact-странице
 * посетителю нужны практические данные (когда открыто, где, как позвонить),
 * а не вторая копия той же формы.
 *
 * Данные берутся из src/data/site.ts (единый источник NAP/часов), чтобы
 * адрес/телефон/часы не расходились со structured data и футером.
 *
 * Зависит от src/data/site.ts (добавлен в SEO-патче). Применять после него.
 */
import { SITE } from '../../data/site';

// Человекочитаемое время: "09:00" → "9:00 AM"
function fmt(t: string): string {
  const [h, m] = t.split(':').map(Number);
  const period = h >= 12 ? 'PM' : 'AM';
  const hr = h % 12 === 0 ? 12 : h % 12;
  return m === 0 ? `${hr}:00 ${period}` : `${hr}:${String(m).padStart(2, '0')} ${period}`;
}

// Сворачиваем дни в диапазоны: ['Monday'..'Friday'] → "Mon – Fri"
const ABBR: Record<string, string> = {
  Monday: 'Mon', Tuesday: 'Tue', Wednesday: 'Wed', Thursday: 'Thu',
  Friday: 'Fri', Saturday: 'Sat', Sunday: 'Sun',
};
function dayRange(days: readonly string[]): string {
  if (days.length === 1) return ABBR[days[0]];
  return `${ABBR[days[0]]} – ${ABBR[days[days.length - 1]]}`;
}

const allDays = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];
const openDays = new Set(SITE.openingHours.flatMap((h) => h.days as readonly string[]));
const closedDays = allDays.filter((d) => !openDays.has(d));

const hoursRows = [
  ...SITE.openingHours.map((h) => ({
    label: dayRange(h.days),
    value: `${fmt(h.opens)} – ${fmt(h.closes)}`,
  })),
  ...(closedDays.length
    ? [{ label: dayRange(closedDays), value: 'Closed' }]
    : []),
];

const { street, city, region, postalCode } = SITE.address;
const mapsQuery = encodeURIComponent(`${SITE.legalName}, ${street}, ${city}, ${region} ${postalCode}`);
const mapsHref = `https://www.google.com/maps/search/?api=1&query=${mapsQuery}`;
---

<section class="w-full bg-cream" data-section="contact-info">
  <div class="mx-auto max-w-design px-[7.55%] pb-24">
    <div class="border-t border-gold/25 pt-16 grid grid-cols-1 gap-12 md:grid-cols-3">
      {/* Hours */}
      <div>
        <h2 class="font-heading text-[28px] uppercase text-gold">Hours</h2>
        <dl class="mt-6 space-y-3 font-sans text-[18px] text-gold">
          {hoursRows.map((row) => (
            <div class="flex justify-between gap-6">
              <dt class="whitespace-nowrap">{row.label}</dt>
              <dd class="text-right">{row.value}</dd>
            </div>
          ))}
        </dl>
      </div>

      {/* Location */}
      <div>
        <h2 class="font-heading text-[28px] uppercase text-gold">Location</h2>
        <address class="mt-6 not-italic font-sans text-[18px] leading-relaxed text-gold">
          {SITE.legalName}<br />
          {street}<br />
          {city}, {region} {postalCode}
        </address>
        <a
          href={mapsHref}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-block font-sans text-[16px] uppercase tracking-[0.12em] text-gold underline underline-offset-4 transition-opacity hover:opacity-70"
        >
          Get Directions
        </a>
      </div>

      {/* Phone */}
      <div>
        <h2 class="font-heading text-[28px] uppercase text-gold">Phone</h2>
        <p class="mt-6 font-sans text-[18px] text-gold">
          <a
            href={`tel:${SITE.telephone}`}
            class="transition-opacity hover:opacity-70"
          >
            {SITE.phoneDisplay}
          </a>
        </p>
      </div>
    </div>
  </div>
</section>
