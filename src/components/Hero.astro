---
/**
 * Hero — главная секция домашней страницы. Реальный слайдер.
 *
 * Источник в Figma: file jmzQqLFWpZXSII6xTkgCgu, nodeId 1:3 (HOME).
 * Токены: H1 Optima 62px #8d7431; Body Manrope 21px; Btn 195×45 #eae4d2/#8d7431.
 * Левый отступ ≈ 145/1920 = 7.55%.
 *
 * СЛАЙДЫ (эксперимент): 1) текущее фото DNA, 2) новое фото (рассвет/йога),
 * 3) видео (пара на закате). Новое фото и видео отгрейдены под тёплую
 * золотисто-кремовую тональность сайта (как hero-dna): тёплый баланс,
 * понижена насыщенность, поднята яркость, кремово-золотой wash.
 * ⚠️ Фото hero-sunrise-v1 — comp Stocksy с ВИДИМЫМ вотермарком: только для
 *    превью, требует лицензии/замены. Видео без вотермарка.
 *
 * Логика слайдера: автосмена (фото 7с, видео дольше), клик по сегментам,
 * пауза при hover/focus, prefers-reduced-motion. Видео играет только когда
 * его слайд активен (иначе pause), muted+loop+playsinline.
 */

const bookHref =
  'https://www.joinblvd.com/b/ideal-medical-and-wellness/widget#/visit-type';

interface Slide {
  headingLines: [string, string];
  body: string;
  cta: { href: string; label: string };
  image?: string;       // фон-картинка (или poster для видео)
  video?: string;       // если задано — рендерим <video>
  durationMs?: number;  // время показа слайда (по умолчанию 7000)
}

const content = {
  headingLines: ['Live Better, Longer,', 'and Happier.'] as [string, string],
  body:
    'Concierge medical and wellness care in Aventura, built around your ' +
    'bloodwork and your goals. Hormone optimization, medical weight loss, ' +
    'peptide therapy, and advanced aesthetics — all under one roof.',
  cta: { href: bookHref, label: 'BOOK NOW' },
};

const slides: Slide[] = [
  { ...content, image: '/assets/images/hero-dna.webp' },
  { ...content, image: '/assets/images/hero-sunrise-v1.webp' },
  {
    ...content,
    video: '/assets/video/hero-couple-v1.mp4',
    image: '/assets/images/hero-couple-v1-poster.webp',
    durationMs: 13000,
  },
];
---

<section
  class="group relative h-screen min-h-[620px] w-full overflow-hidden bg-white"
  data-hero
  aria-roledescription="carousel"
  aria-label="Hero"
>
  {slides.map((s, i) => (
    <div
      data-slide
      data-index={i}
      data-duration={s.durationMs ?? 7000}
      aria-hidden={i === 0 ? 'false' : 'true'}
      class={`absolute inset-0 transition-opacity duration-700 ${
        i === 0 ? 'opacity-100' : 'opacity-0 pointer-events-none'
      }`}
    >
      {/* Фон: видео или картинка. object-cover — на весь экран. */}
      {s.video ? (
        <video
          data-hero-video
          class="absolute inset-0 h-full w-full object-cover"
          src={s.video}
          poster={s.image}
          muted
          loop
          playsinline
          preload="auto"
          aria-hidden="true"
          tabindex="-1"
        ></video>
      ) : (
        <img
          src={s.image}
          alt=""
          class="absolute inset-0 h-full w-full object-cover"
          width="1920"
          height="1080"
          loading={i === 0 ? 'eager' : 'lazy'}
          decoding="async"
        />
      )}

      {/* Скрим читабельности: высветляет левую часть под текстом. */}
      <div
        class="pointer-events-none absolute inset-0"
        style="background: linear-gradient(90deg, rgba(255,255,255,0.62) 0%, rgba(255,255,255,0.34) 30%, rgba(255,255,255,0) 60%);"
        aria-hidden="true"
      ></div>

      <div class="relative z-10 mx-auto h-full max-w-design px-[7.55%]">
        <div class="flex h-full flex-col justify-center pb-[6vh] pt-[88px]">
          {i === 0 ? (
            <h1 class="font-heading text-h1 uppercase text-gold [text-shadow:0_1px_0_rgba(255,255,255,0.45)]">
              {s.headingLines[0]}<br />{s.headingLines[1]}
            </h1>
          ) : (
            <p class="font-heading text-h1 uppercase text-gold [text-shadow:0_1px_0_rgba(255,255,255,0.45)]">
              {s.headingLines[0]}<br />{s.headingLines[1]}
            </p>
          )}

          <p class="mt-[27px] max-w-[540px] font-sans text-body-lg leading-relaxed text-[#5a4f33]">
            {s.body}
          </p>

          <img
            src="/assets/images/star-sign.svg"
            alt=""
            width="43"
            height="50"
            class="mt-[21px] h-[50px] w-[43px]"
            aria-hidden="true"
          />

          <a
            href={s.cta.href}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-gold mt-[64px] w-[195px] h-[45px]"
          >
            {s.cta.label}
          </a>
        </div>
      </div>
    </div>
  ))}

  {/* Индикатор слайдера — по сегменту на слайд. Кликабельные. */}
  <div
    class="absolute bottom-[40px] right-[7.55%] z-20 flex gap-3"
    role="tablist"
    aria-label="Choose hero slide"
  >
    {slides.map((_, i) => (
      <button
        type="button"
        data-hero-dot
        data-index={i}
        role="tab"
        aria-label={`Show slide ${i + 1} of ${slides.length}`}
        aria-selected={i === 0 ? 'true' : 'false'}
        class="h-[3px] w-[36px] bg-gold/30 transition-colors aria-selected:bg-gold"
      ></button>
    ))}
  </div>
</section>

<script>
  document.querySelectorAll('[data-hero]').forEach((root) => {
    const slides = Array.from(root.querySelectorAll('[data-slide]'));
    const dots = Array.from(root.querySelectorAll('[data-hero-dot]'));
    if (slides.length <= 1) return;

    const durations = slides.map(
      (sl) => parseInt(sl.getAttribute('data-duration') || '7000', 10)
    );
    let current = 0;
    let timer: number | undefined;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function syncVideo(n: number) {
      slides.forEach((sl, i) => {
        const v = sl.querySelector('video') as HTMLVideoElement | null;
        if (!v) return;
        if (i === n) {
          try { v.currentTime = 0; const p = v.play(); if (p) p.catch(() => {}); } catch {}
        } else {
          v.pause();
        }
      });
    }

    function show(next: number) {
      const n = ((next % slides.length) + slides.length) % slides.length;
      slides.forEach((sl, i) => {
        const active = i === n;
        sl.classList.toggle('opacity-100', active);
        sl.classList.toggle('opacity-0', !active);
        sl.classList.toggle('pointer-events-none', !active);
        sl.setAttribute('aria-hidden', active ? 'false' : 'true');
      });
      dots.forEach((d, i) => d.setAttribute('aria-selected', i === n ? 'true' : 'false'));
      current = n;
      syncVideo(n);
    }
    function scheduleNext() {
      stop();
      if (reduceMotion) return;
      timer = window.setTimeout(() => {
        show(current + 1);
        scheduleNext();
      }, durations[current]);
    }
    function stop() {
      if (timer) window.clearTimeout(timer);
    }

    dots.forEach((dot, i) =>
      dot.addEventListener('click', () => {
        show(i);
        scheduleNext();
      })
    );

    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', scheduleNext);
    root.addEventListener('focusin', stop);
    root.addEventListener('focusout', scheduleNext);

    syncVideo(0);
    scheduleNext();
  });
</script>
