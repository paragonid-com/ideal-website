---
/**
 * Footer — обёртка для нижней части страницы.
 * Использует общий блок FooterBlock в варианте 'full'.
 */
import FooterBlock from './FooterBlock.astro';
---

<footer class="relative w-full bg-cream pt-24 pb-12">
  <div class="mx-auto max-w-design px-[7.55%]">
    <FooterBlock variant="full" />
  </div>
</footer>
