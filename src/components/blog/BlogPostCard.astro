---
/**
 * BlogPostCard — одна карточка в сетке Blog и в блоке "Continue Reading".
 *
 * Структура (узлы Figma 1:6797 + 1:6594 + 1:6550 + 1:6574):
 *  - Фото (горизонтальное, пейзажное) — кликабельное, лёгкий zoom на hover
 *  - Заголовок (uppercase font-heading, gold) — подчёркивается на hover
 *  - Описание (font-sans, ограничено 4 строками для ровной сетки)
 *  - Кнопка "READ MORE" (gold pill)
 */

interface Props {
  title: string;
  description: string;
  image: string;
  imageAlt: string;
  href: string;
  /** Компактный режим для блока похожих статей внизу страницы поста */
  compact?: boolean;
}

const { title, description, image, imageAlt, href, compact = false } = Astro.props;
---

<article class="group flex flex-col">
  <a href={href} class="block overflow-hidden">
    <div class="relative w-full aspect-[771/299] overflow-hidden">
      <img
        src={image}
        alt={imageAlt}
        loading="lazy"
        class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
      />
    </div>
  </a>

  <h2
    class={`mt-6 font-heading uppercase text-gold leading-tight ${
      compact ? 'text-[28px]' : 'text-[40px]'
    }`}
  >
    <a href={href} class="decoration-2 underline-offset-4 group-hover:underline">
      {title}
    </a>
  </h2>

  <p class="post-card-desc mt-4 max-w-[642px] font-sans text-body-lg text-gold leading-relaxed">
    {description}
  </p>

  <a href={href} class="btn-gold mt-6 self-start min-w-[216px]">
    READ MORE
  </a>
</article>

<style>
  /* Ограничиваем описание 4 строками, чтобы карточки в сетке были ровными */
  .post-card-desc {
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
