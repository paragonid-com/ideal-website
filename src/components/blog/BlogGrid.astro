---
/**
 * BlogGrid — сетка постов на странице Blog.
 *
 * Читает Content Collection 'posts' (импортировано со старого сайта
 * idealmedwell.com) и рендерит карточку на каждый пост. Посты с draft: true
 * исключены. Ссылки ведут на /blog/<slug>.
 */
import { getCollection } from 'astro:content';
import BlogPostCard from './BlogPostCard.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft);

// Сортировка: по publishDate (новые сверху), затем по заголовку.
posts.sort((a, b) => {
  const da = a.data.publishDate?.getTime() ?? 0;
  const db = b.data.publishDate?.getTime() ?? 0;
  if (db !== da) return db - da;
  return a.data.title.localeCompare(b.data.title);
});
---

<section class="w-full bg-cream py-24" data-section="blog-grid">
  <div class="mx-auto max-w-design px-[7.55%]">
    <ul class="grid grid-cols-1 gap-16 lg:grid-cols-2">
      {posts.map((post) => (
        <li>
          <BlogPostCard
            title={post.data.title}
            description={post.data.description}
            image={post.data.heroImage}
            imageAlt={post.data.heroImageAlt}
            href={`/blog/${post.id}`}
          />
        </li>
      ))}
    </ul>
  </div>
</section>
