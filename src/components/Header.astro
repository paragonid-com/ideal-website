---
/**
 * Header — единый компонент для всех страниц сайта.
 *
 * Состоит из трёх частей:
 *   1. Mobile top-bar (<header>, `< lg`) — лого слева + burger справа.
 *      Лежит поверх контента (absolute), на десктопе скрыт (`lg:hidden`),
 *      т.к. на `lg+` навигацию несёт постоянная панель ниже.
 *   2. Desktop nav bar (#desktop-nav, `lg+`) — ПОСТОЯННАЯ горизонтальная
 *      панель: лого слева, 3 категории-триггера с hover/click мега-меню,
 *      CTA «BOOK APPOINTMENT» справа. Sticky + auto-hide: прячется при
 *      скролле вниз, появляется при скролле вверх, всегда видна у самого
 *      верха. Фон — сплошной белый (контраст gold-на-white ≈ AA 4.5:1;
 *      любая прозрачность под текстом уронила бы контраст ниже AA).
 *   3. Mobile menu (#mobile-menu, `< lg`) — двухуровневый drill-down
 *      (Вариант C, сессия 14). НЕ ТРОГАЕТСЯ. На десктопе force-hidden.
 *
 * Источник в Figma (мобильное меню / лого / burger):
 *   menu-1 (1:1963) … лого 1:268, burger 1:144.
 * Десктоп-панель — по handoff-спеке «Desktop Navigation Redesign».
 *
 * Доступность десктоп-меню: disclosure-паттерн (триггеры = <button>
 * с aria-haspopup/aria-expanded/aria-controls; пункты = обычные ссылки,
 * НЕ role="menu"). Открытие по hover (с задержкой закрытия) И по
 * click/Enter/Space (touch + клавиатура). Esc закрывает и возвращает
 * фокус на триггер; клик/фокус снаружи закрывает; выбор пункта уводит
 * на страницу. prefers-reduced-motion — без transition.
 */

import { mainNav, bookingCta, type NavGroup } from '../data/navigation.ts';

// Нормализуем pathname: '/x' и '/x/' — одна страница.
const rawPath = Astro.url.pathname;
const currentPath = rawPath.length > 1 && rawPath.endsWith('/')
  ? rawPath.slice(0, -1)
  : rawPath;

function isItemCurrent(href: string): boolean {
  const normalized = href.length > 1 && href.endsWith('/') ? href.slice(0, -1) : href;
  return normalized === currentPath;
}

function isGroupActive(group: NavGroup): boolean {
  if (group.href && isItemCurrent(group.href)) return true;
  return Boolean(group.items?.some((item) => isItemCurrent(item.href)));
}

// Раздел, реально содержащий текущую страницу (для подсветки активной
// категории в десктоп-панели и current-page в мобильном меню).
const activeGroupLabel = mainNav.find(isGroupActive)?.label;
---

{/* === MOBILE TOP BAR (< lg) === лого + burger, поверх контента. */}
<header
  class="absolute inset-x-0 top-0 z-40 mx-auto flex max-w-design items-center justify-between px-[7.55%] pt-8 lg:hidden"
>
  <a href="/" class="block" aria-label="IDEAL Medical and Wellness — home">
    <img
      src="/assets/images/logo-ideal.svg"
      alt="IDEAL Medical and Wellness"
      width="194"
      height="62"
      class="h-auto w-[194px]"
    />
  </a>

  <button
    id="menu-toggle"
    type="button"
    class="block rounded-full bg-black/35 p-3 text-white backdrop-blur-sm transition-colors hover:bg-black/50 [filter:drop-shadow(0_2px_4px_rgba(0,0,0,0.3))]"
    aria-label="Open menu"
    aria-controls="mobile-menu"
    aria-expanded="false"
  >
    {/* Burger из 4 линий — 1:1 из Figma (узел 1:144). */}
    <svg
      width="32"
      height="38"
      viewBox="0 0 64.4344 124.434"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <path d="M0 52.2172H64.4344" stroke="currentColor" stroke-width="6" stroke-linecap="round" />
      <path d="M0 32.2172H64.4344" stroke="currentColor" stroke-width="6" stroke-linecap="round" />
      <path d="M0 72.2172H64.4344" stroke="currentColor" stroke-width="6" stroke-linecap="round" />
      <path d="M0 92.2172H64.4344" stroke="currentColor" stroke-width="6" stroke-linecap="round" />
    </svg>
  </button>
</header>

{/* === DESKTOP NAV BAR (lg+) === постоянная sticky-панель с мега-меню. */}
<div
  id="desktop-nav"
  class="fixed inset-x-0 top-0 z-40 hidden border-b border-gold/15 bg-white lg:block"
>
  <div class="mx-auto max-w-design px-[7.55%]">
    {/* relative — якорь для абсолютных мега-панелей (top-full под баром). */}
    <div class="relative flex h-[88px] items-center">
      {/* Лого. Явные width/height (ratio 194:62 ≈ 3.14) — SVG имеет
          preserveAspectRatio="none", без фикс. размера тянется. */}
      <a href="/" class="block shrink-0" aria-label="IDEAL Medical and Wellness — home">
        <img
          src="/assets/images/logo-ideal.svg"
          alt="IDEAL Medical and Wellness"
          width="144"
          height="46"
          class="block h-[46px] w-[144px]"
        />
      </a>

      {/* Триггеры категорий */}
      <nav class="ml-16 flex h-full items-stretch" aria-label="Primary">
        <ul class="flex h-full items-stretch gap-[46px]">
          {mainNav.map((group: NavGroup, idx: number) => {
            const isActive = group.label === activeGroupLabel;
            const panelId = `megapanel-${idx}`;
            const twoCols = (group.items?.length ?? 0) > 6;
            return (
              <li class="relative flex h-full items-center" data-mega-group={group.label}>
                <button
                  type="button"
                  class="mega-trigger inline-flex items-center gap-1.5 whitespace-nowrap py-2 font-sans text-[14px] font-semibold uppercase tracking-[0.09em] text-gold outline-none transition-colors focus-visible:ring-2 focus-visible:ring-gold-bright/60"
                  data-mega-trigger={group.label}
                  data-active={isActive ? 'true' : undefined}
                  aria-haspopup="true"
                  aria-expanded="false"
                  aria-controls={panelId}
                >
                  <span>{group.label}</span>
                  <svg
                    class="mega-caret h-2.5 w-2.5 text-gold-bright transition-transform"
                    viewBox="0 0 10 6"
                    fill="none"
                    aria-hidden="true"
                  >
                    <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </button>

                {/* Мега-панель: открывается под баром, левый край = левому
                    краю триггера. Белая, 3px gold-bright сверху, мягкая тень. */}
                <div
                  id={panelId}
                  data-mega-panel={group.label}
                  class={`absolute left-0 top-full z-50 hidden border-t-[3px] border-gold-bright bg-white p-7 pt-6 shadow-[0_22px_44px_rgba(40,34,20,0.16)] [border-radius:0_0_6px_6px] ${twoCols ? 'min-w-[480px]' : 'min-w-[320px]'}`}
                  role="region"
                  aria-label={`${group.label} menu`}
                >
                  <div class="mb-4 flex items-center justify-between gap-8">
                    <span class="whitespace-nowrap font-heading text-[18px] uppercase tracking-[0.06em] text-gold">
                      {group.label}
                    </span>
                    <img
                      src="/assets/images/star-sign.svg"
                      alt=""
                      width="26"
                      height="30"
                      class="h-[26px] w-auto opacity-80"
                      aria-hidden="true"
                    />
                  </div>
                  <ul class={`grid gap-y-0.5 ${twoCols ? 'grid-cols-[max-content_max-content] gap-x-12' : 'grid-cols-1'}`}>
                    {group.items?.map((item) => {
                      const current = isItemCurrent(item.href);
                      return (
                        <li>
                          <a
                            href={item.href}
                            class={`block whitespace-nowrap rounded px-2.5 py-2 font-sans text-[15px] text-[#26221a] outline-none transition-colors hover:bg-cream hover:text-gold focus-visible:bg-cream focus-visible:text-gold ${current ? 'font-semibold text-gold' : ''}`}
                            aria-current={current ? 'page' : undefined}
                          >
                            {item.label}
                          </a>
                        </li>
                      );
                    })}
                  </ul>
                </div>
              </li>
            );
          })}
        </ul>
      </nav>

      {/* CTA — прижат вправо */}
      <a
        href={bookingCta.href}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-gold ml-auto shrink-0 whitespace-nowrap text-[14px] tracking-[0.1em]"
      >
        {bookingCta.label}
      </a>
    </div>
  </div>
</div>

{/* === MOBILE MENU (< lg) — двухуровневый drill-down (Вариант C) ===
   НЕ ИЗМЕНЯЛОСЬ относительно сессии 14. lg:!hidden — на десктопе скрыто. */}
<div
  id="mobile-menu"
  class="fixed inset-0 z-50 hidden flex-col overflow-hidden bg-cream lg:!hidden"
  aria-hidden="true"
>
  {/* --- LEVEL 1 --- */}
  <div
    data-mobile-panel="l1"
    class="absolute inset-0 flex translate-x-0 flex-col transform-gpu will-change-transform transition-transform duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] motion-reduce:transition-none"
    style="background: radial-gradient(ellipse 70% 90% at 20% 35%, #f0eadc 0%, #ddc8a0 70%, #c9b187 100%);"
  >
    {/* top-bar: лого слева + ✕ справа */}
    <div class="flex shrink-0 items-center justify-between px-[7.55%] pb-6 pt-8">
      <a href="/" class="block" aria-label="IDEAL Medical and Wellness — home">
        <img
          src="/assets/images/logo-ideal.svg"
          alt="IDEAL Medical and Wellness"
          width="194"
          height="62"
          class="h-auto w-[160px]"
        />
      </a>
      <button
        type="button"
        data-mobile-close
        class="-mr-1 block p-1 text-gold-bright transition-opacity hover:opacity-70"
        aria-label="Close menu"
      >
        <svg width="30" height="30" viewBox="0 0 42 42" fill="none" aria-hidden="true">
          <path d="M2 2 L40 40 M40 2 L2 40" stroke="currentColor" stroke-width="2" />
        </svg>
      </button>
    </div>

    {/* 3 категории — drill-in по тапу */}
    <nav class="flex-1 overflow-y-auto overscroll-contain px-[7.55%]" aria-label="Mobile menu">
      <ul class="border-t border-gold/20">
        {mainNav.map((group: NavGroup) => (
          <li class="border-b border-gold/20">
            <button
              type="button"
              data-mobile-drill={group.label}
              class="flex min-h-[44px] w-full items-center justify-between gap-4 py-5 text-left font-heading text-[32px] uppercase leading-tight text-gold transition-opacity hover:opacity-70"
            >
              <span>{group.label}</span>
              <svg class="shrink-0 text-gold-bright" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
          </li>
        ))}
      </ul>
    </nav>

    {/* CTA закреплён внизу (L1) */}
    <div class="shrink-0 px-[7.55%] pb-8 pt-6">
      <a
        href={bookingCta.href}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-gold w-full"
      >
        {bookingCta.label}
      </a>
    </div>
  </div>

  {/* --- LEVEL 2 --- (z-10: поверх L1 во время slide) */}
  <div
    data-mobile-panel="l2"
    class="absolute inset-0 z-10 flex translate-x-full flex-col transform-gpu will-change-transform transition-transform duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] motion-reduce:transition-none"
    style="background: radial-gradient(ellipse 70% 90% at 20% 35%, #f0eadc 0%, #ddc8a0 70%, #c9b187 100%);"
    inert
  >
    {/* top-bar: ‹ Back слева + ✕ справа */}
    <div class="flex shrink-0 items-center justify-between px-[7.55%] pb-6 pt-8">
      <button
        type="button"
        data-mobile-back
        class="-ml-1 flex items-center gap-1 p-1 font-sans text-[15px] uppercase tracking-[0.12em] text-gold transition-opacity hover:opacity-70"
        aria-label="Back to main menu"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span>Back</span>
      </button>
      <button
        type="button"
        data-mobile-close
        class="-mr-1 block p-1 text-gold-bright transition-opacity hover:opacity-70"
        aria-label="Close menu"
      >
        <svg width="30" height="30" viewBox="0 0 42 42" fill="none" aria-hidden="true">
          <path d="M2 2 L40 40 M40 2 L2 40" stroke="currentColor" stroke-width="2" />
        </svg>
      </button>
    </div>

    {/* Списки разделов — виден активный (data-mobile-cat). Зона свайпа-Back. */}
    <div data-mobile-swipe class="flex-1 overflow-y-auto overscroll-contain px-[7.55%]">
      {mainNav.map((group: NavGroup) => (
        <div data-mobile-cat={group.label} class="hidden">
          {/* некликабельная метка-заголовок раздела (focus при drill-in) */}
          <p
            data-mobile-label
            tabindex="-1"
            class="pb-5 pt-2 font-sans text-[13px] uppercase tracking-[0.18em] text-gold/70 outline-none"
          >
            {group.label}
          </p>
          <ul class="flex flex-col gap-1 pb-2">
            {group.items?.map((item) => {
              const current = isItemCurrent(item.href);
              return (
                <li>
                  <a
                    href={item.href}
                    class={`flex min-h-[44px] items-center gap-3 py-3 font-sans text-[20px] transition-opacity hover:opacity-70
                            ${current ? 'font-semibold text-gold' : 'text-gold'}`}
                    aria-current={current ? 'page' : undefined}
                  >
                    {/* слот-точка фиксированной ширины → текст всех пунктов выровнен,
                        точка-индикатор видна только у текущей страницы */}
                    <span
                      class={`h-2 w-2 shrink-0 rounded-full ${current ? 'bg-gold-bright' : 'bg-transparent'}`}
                      aria-hidden="true"
                    ></span>
                    <span>{item.label}</span>
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))}
    </div>

    {/* CTA закреплён внизу И на L2 (в один тап на обоих уровнях) */}
    <div class="shrink-0 px-[7.55%] pb-8 pt-6">
      <a
        href={bookingCta.href}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-gold w-full"
      >
        {bookingCta.label}
      </a>
    </div>
  </div>
</div>

<style>
  /* --- Desktop nav: sticky + auto-hide + scrolled shadow --- */
  #desktop-nav {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    will-change: transform;
  }
  #desktop-nav.is-hidden {
    transform: translateY(-100%);
  }
  #desktop-nav.is-scrolled {
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.06);
  }
  /* Подчёркивание-индикатор: для открытого И для активной категории. */
  .mega-trigger::after {
    content: "";
    position: absolute;
    left: 0;
    right: 14px;
    bottom: -2px;
    height: 2px;
    background: var(--mega-underline, #d1a42b);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.18s ease;
  }
  .mega-trigger[data-open]::after,
  .mega-trigger[data-active]::after {
    transform: scaleX(1);
  }
  .mega-trigger[data-open],
  .mega-trigger[data-active] {
    color: #d1a42b;
  }
  .mega-trigger[data-open] .mega-caret {
    transform: rotate(180deg);
  }
  @media (prefers-reduced-motion: reduce) {
    #desktop-nav,
    .mega-trigger::after,
    .mega-caret {
      transition: none;
    }
  }
</style>

<script>
  // ===== Открытие/закрытие МОБИЛЬНОГО меню (burger) =====
  const toggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  let savedScrollY = 0;

  function lockScroll() {
    // body{overflow:hidden} не блокирует iOS Safari — фиксируем body со сдвигом.
    savedScrollY = window.scrollY || window.pageYOffset || 0;
    document.body.style.position = 'fixed';
    document.body.style.top = `-${savedScrollY}px`;
    document.body.style.left = '0';
    document.body.style.right = '0';
    document.body.style.width = '100%';
    document.body.style.overflow = 'hidden';
  }

  function unlockScroll() {
    document.body.style.position = '';
    document.body.style.top = '';
    document.body.style.left = '';
    document.body.style.right = '';
    document.body.style.width = '';
    document.body.style.overflow = '';
    window.scrollTo(0, savedScrollY);
  }

  function openMenu() {
    if (!toggle || !mobileMenu) return;
    toggle.setAttribute('aria-expanded', 'true');
    lockScroll();
    mobileMenu.classList.remove('hidden');
    mobileMenu.classList.add('flex');
    mobileMenu.setAttribute('aria-hidden', 'false');
    setMobileLevel(null); // всегда с корня (L1)
  }

  function closeMenu() {
    if (!toggle || !mobileMenu) return;
    const active = document.activeElement;
    if (active instanceof HTMLElement && mobileMenu.contains(active)) {
      active.blur();
    }
    toggle.setAttribute('aria-expanded', 'false');
    unlockScroll();
    toggle.focus({ preventScroll: true });
    mobileMenu.classList.add('hidden');
    mobileMenu.classList.remove('flex');
    mobileMenu.setAttribute('aria-hidden', 'true');
    setMobileLevel(null);
  }

  toggle?.addEventListener('click', openMenu);

  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    if (mobileMenu?.getAttribute('aria-hidden') === 'false') closeMenu();
  });

  // ===== МОБИЛЬНЫЙ drill-down (< lg) — без изменений =====
  const mPanelL1 = mobileMenu?.querySelector<HTMLElement>('[data-mobile-panel="l1"]');
  const mPanelL2 = mobileMenu?.querySelector<HTMLElement>('[data-mobile-panel="l2"]');
  let activeCategory: string | null = null;
  let lastDrillBtn: HTMLElement | null = null;

  function setMobileLevel(category: string | null) {
    activeCategory = category;
    const atL2 = category !== null;

    mobileMenu?.querySelectorAll<HTMLElement>('[data-mobile-cat]').forEach((block) => {
      block.classList.toggle('hidden', block.dataset.mobileCat !== category);
    });
    if (atL2 && mPanelL2) {
      const scroller = mPanelL2.querySelector<HTMLElement>('[data-mobile-swipe]');
      if (scroller) scroller.scrollTop = 0;
    }

    if (mPanelL1 && mPanelL2) {
      mPanelL1.classList.toggle('-translate-x-1/4', atL2);
      mPanelL1.classList.toggle('translate-x-0', !atL2);
      mPanelL2.classList.toggle('translate-x-0', atL2);
      mPanelL2.classList.toggle('translate-x-full', !atL2);
      mPanelL1.toggleAttribute('inert', atL2);
      mPanelL2.toggleAttribute('inert', !atL2);
    }
  }

  function mobileDrillIn(category: string, sourceBtn: HTMLElement) {
    lastDrillBtn = sourceBtn;
    setMobileLevel(category);
    const label = mobileMenu?.querySelector<HTMLElement>(
      `[data-mobile-cat="${category}"] [data-mobile-label]`
    );
    label?.focus({ preventScroll: true });
  }

  function mobileBack() {
    setMobileLevel(null);
    lastDrillBtn?.focus({ preventScroll: true });
  }

  mobileMenu?.querySelectorAll<HTMLElement>('[data-mobile-drill]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.mobileDrill;
      if (cat) mobileDrillIn(cat, btn);
    });
  });
  mobileMenu?.querySelectorAll<HTMLElement>('[data-mobile-back]').forEach((btn) => {
    btn.addEventListener('click', mobileBack);
  });
  mobileMenu?.querySelectorAll<HTMLElement>('[data-mobile-close]').forEach((btn) => {
    btn.addEventListener('click', closeMenu);
  });

  const swipeZone = mobileMenu?.querySelector<HTMLElement>('[data-mobile-swipe]');
  let touchStartX = 0;
  let touchStartY = 0;
  let tracking = false;
  swipeZone?.addEventListener(
    'touchstart',
    (e) => {
      if (activeCategory === null) return;
      const t = e.touches[0];
      touchStartX = t.clientX;
      touchStartY = t.clientY;
      tracking = true;
    },
    { passive: true }
  );
  swipeZone?.addEventListener(
    'touchend',
    (e) => {
      if (!tracking || activeCategory === null) return;
      tracking = false;
      const t = e.changedTouches[0];
      const dx = t.clientX - touchStartX;
      const dy = t.clientY - touchStartY;
      if (dx > 60 && Math.abs(dx) > Math.abs(dy) * 1.5) mobileBack();
    },
    { passive: true }
  );

  mobileMenu?.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab' || !mobileMenu) return;
    const focusables = Array.from(
      mobileMenu.querySelectorAll<HTMLElement>(
        'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'
      )
    ).filter((el) => el.offsetParent !== null && !el.closest('[inert]'));
    if (focusables.length === 0) return;
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  });

  // ===== ДЕСКТОП-панель: мега-меню (hover + click + клавиатура) =====
  const desktopNav = document.getElementById('desktop-nav');
  let openLabel: string | null = null;
  let hoverTimer: number | undefined;
  const CLOSE_DELAY = 140;

  function setTrigger(label: string, open: boolean) {
    const trigger = desktopNav?.querySelector<HTMLElement>(`[data-mega-trigger="${label}"]`);
    const panel = desktopNav?.querySelector<HTMLElement>(`[data-mega-panel="${label}"]`);
    if (!trigger || !panel) return;
    trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
    if (open) trigger.setAttribute('data-open', 'true');
    else trigger.removeAttribute('data-open');
    panel.classList.toggle('hidden', !open);
  }

  function openPanel(label: string) {
    if (openLabel && openLabel !== label) setTrigger(openLabel, false);
    setTrigger(label, true);
    openLabel = label;
  }

  function closeAllPanels() {
    if (!openLabel) return;
    setTrigger(openLabel, false);
    openLabel = null;
  }

  desktopNav?.querySelectorAll<HTMLElement>('[data-mega-group]').forEach((group) => {
    const label = group.dataset.megaGroup!;
    const trigger = group.querySelector<HTMLElement>('[data-mega-trigger]');

    // Hover: вход в зону (триггер ИЛИ панель) открывает; выход — закрывает с задержкой.
    group.addEventListener('mouseenter', () => {
      window.clearTimeout(hoverTimer);
      openPanel(label);
    });
    group.addEventListener('mouseleave', () => {
      window.clearTimeout(hoverTimer);
      hoverTimer = window.setTimeout(closeAllPanels, CLOSE_DELAY);
    });

    // Click/Enter/Space — toggle (touch + клавиатура).
    trigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      if (openLabel === label) closeAllPanels();
      else openPanel(label);
    });
  });

  // Клик снаружи панели — закрыть.
  document.addEventListener('click', (e) => {
    if (!openLabel || !desktopNav) return;
    if (!desktopNav.contains(e.target as Node)) closeAllPanels();
  });

  // Фокус ушёл из открытой группы — закрыть (Tab за пределы панели).
  document.addEventListener('focusin', (e) => {
    if (!openLabel || !desktopNav) return;
    const grp = desktopNav.querySelector<HTMLElement>(`[data-mega-group="${openLabel}"]`);
    if (grp && !grp.contains(e.target as Node)) closeAllPanels();
  });

  // Esc — закрыть и вернуть фокус на триггер.
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape' || !openLabel || !desktopNav) return;
    const trigger = desktopNav.querySelector<HTMLElement>(`[data-mega-trigger="${openLabel}"]`);
    closeAllPanels();
    trigger?.focus();
  });

  // ===== ДЕСКТОП-панель: sticky + auto-hide при скролле =====
  let lastY = window.scrollY;
  let ticking = false;
  const TOP_ZONE = 8;     // у самого верха всегда видна
  const HIDE_AFTER = 140; // прячем только глубже этого порога

  function onScroll() {
    const y = window.scrollY;
    desktopNav?.classList.toggle('is-scrolled', y > TOP_ZONE);
    if (y <= TOP_ZONE) {
      desktopNav?.classList.remove('is-hidden');
    } else if (y > lastY + 4 && y > HIDE_AFTER) {
      // скролл вниз → спрятать (и закрыть открытую панель)
      desktopNav?.classList.add('is-hidden');
      closeAllPanels();
    } else if (y < lastY - 4) {
      // скролл вверх → показать
      desktopNav?.classList.remove('is-hidden');
    }
    lastY = y;
    ticking = false;
  }
  window.addEventListener(
    'scroll',
    () => {
      if (!ticking) {
        window.requestAnimationFrame(onScroll);
        ticking = true;
      }
    },
    { passive: true }
  );
</script>
