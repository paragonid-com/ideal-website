---
/**
 * Header — единый компонент для всех страниц сайта.
 *
 * Состоит из трёх частей:
 *   1. Top bar — лого слева + иконка-burger справа.
 *      Лежит поверх контента страницы (absolute, не fixed),
 *      так как на Hero контент сам отрисовывает фон под шапкой.
 *   2. Overlay-меню (#overlay-menu) — ДЕСКТОПНОЕ (`lg+`), full-screen.
 *      Внутри: лого, X-кнопка закрытия, 3 раскрывающихся раздела,
 *      CTA-кнопка BOOK APPOINTMENT, нижний блок Address/Quick Links/Subscribe.
 *      На мобиле force-hidden (`max-lg:!hidden`) — НЕ показывается.
 *   3. Mobile-меню (#mobile-menu) — МОБИЛЬНОЕ (`< lg`), двухуровневый
 *      drill-down (Вариант C): L1 = 3 категории, тап → L2 выезжает справа
 *      со списком пунктов раздела. CTA закреплён на обоих уровнях.
 *      На десктопе force-hidden (`lg:!hidden`).
 *      Бургер один; openMenu/closeMenu открывают/закрывают ОБА overlay,
 *      видимость решает CSS-гейт по брейкпоинту (без JS-детекта вьюпорта).
 *
 * Источник в Figma:
 *   menu-1 (1:1963), menu-2 (1:2012), menu-3 (1:3813), menu-4 (1:3757)
 *   лого    — узел 1:268 (Group 321)
 *   burger  — узел 1:144 (Group 6)
 *
 * Поведение подменю (см. JS-блок ниже):
 *   - При открытии overlay показывается раздел активной страницы;
 *     если её нет (главная) — первый раздел (Wellness Services) как fallback,
 *     чтобы UI не выглядел сломанным. Это отклонение от Figma menu-1
 *     (где справа пусто), сделано из-за UX (см. HANDOFF).
 *   - Hover на заголовок (desktop) — временный preview, mouseleave
 *     возвращает к "sticky" (последнее click'нутое или server default).
 *   - Click на заголовок (touch и desktop) — меняет sticky.
 *     Touch-friendly: на iPad/телефонах нет hover, работает только click.
 *   - Орнамент-цветочек возле раскрытого раздела (узел Figma 1:1983).
 *
 * Sub-навигация (отдельная фича поверх Figma): внутри подменю текущий
 * пункт помечен `aria-current="page"` + `font-semibold`. Применяется
 * к любой странице, которая есть в навигации.
 */

import { mainNav, bookingCta, type NavGroup } from '../data/navigation.ts';
import FooterBlock from './FooterBlock.astro';

// Определяем, какой раздел и пункт меню соответствуют текущей странице.
// Используется для sub-навигации:
//   - При открытии меню автоматически раскрывается секция, содержащая
//     текущую страницу.
//   - Возле заголовка раздела показывается орнамент-индикатор.
//   - Текущий пункт в подменю помечается как "current"
//     (визуально жирнее + aria-current="page").
//
// Нормализуем pathname: убираем trailing slash, чтобы '/services/weight-loss'
// и '/services/weight-loss/' считались одной страницей.
const rawPath = Astro.url.pathname;
const currentPath = rawPath.length > 1 && rawPath.endsWith('/')
  ? rawPath.slice(0, -1)
  : rawPath;

function isItemCurrent(href: string): boolean {
  const normalized = href.length > 1 && href.endsWith('/') ? href.slice(0, -1) : href;
  return normalized === currentPath;
}

function isGroupActive(group: NavGroup): boolean {
  // Раздел активен, если содержит пункт-current,
  // ИЛИ если сам раздел является ссылкой на текущую страницу.
  if (group.href && isItemCurrent(group.href)) return true;
  return Boolean(group.items?.some((item) => isItemCurrent(item.href)));
}

// Состояние навигации использует две разные концепции:
//
// activeGroupLabel — раздел, **реально содержащий текущую страницу**.
//   Используется для sub-навигации: орнамент-индикатор и aria-current="page"
//   на конкретной ссылке внутри подменю. Если страница не в меню (`/`,
//   /aboutus и т.п.) — undefined, орнамент не показываем.
//
// defaultOpenLabel — какой подменю-список открыть при открытии overlay.
//   Если есть реальная активная страница — открываем её раздел. Если нет
//   (домашняя) — fallback на первый раздел (Wellness Services), чтобы
//   справа не пустовало. Это отклонение от Figma menu-1 (там в дефолте
//   пусто), но без него UX сломан. См. HANDOFF.
//
// data-nav-active атрибут используется JS для возврата к default state
// после mouseleave с nav — поэтому ставится по defaultOpenLabel.
// aria-current="true" и орнамент — только по activeGroupLabel.
const activeGroupLabel = mainNav.find(isGroupActive)?.label;
const defaultOpenLabel = activeGroupLabel ?? mainNav[0].label;
---

{/* === TOP BAR (на каждой странице) === */}
<header
  class="absolute inset-x-0 top-0 z-40 mx-auto flex max-w-design items-center justify-between px-[7.55%] pt-8"
>
  <a href="/" class="block" aria-label="IDEAL Medical and Wellness — home">
    <img
      src="/assets/images/logo-ideal.svg"
      alt="IDEAL Medical and Wellness"
      width="194"
      height="62"
      class="h-auto w-[194px]"
    />
  </a>

  <button
    id="menu-toggle"
    type="button"
    class="block rounded-full bg-black/35 p-3 text-white backdrop-blur-sm transition-colors hover:bg-black/50 [filter:drop-shadow(0_2px_4px_rgba(0,0,0,0.3))]"
    aria-label="Open menu"
    aria-controls="overlay-menu mobile-menu"
    aria-expanded="false"
  >
    {/* Burger из 4 линий — нестандартный (3 — обычный), взято 1:1 из Figma узел 1:144.
        Цвет в оригинале золотой, но на cream-DNA hero главной он становится
        невидим. Чтобы гарантировать контраст на любом фоне (cream/white/dark),
        burger белый, помещён в полупрозрачную тёмную круглую подложку. */}
    <svg
      width="32"
      height="38"
      viewBox="0 0 64.4344 124.434"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <path d="M0 52.2172H64.4344" stroke="currentColor" stroke-width="6" stroke-linecap="round" />
      <path d="M0 32.2172H64.4344" stroke="currentColor" stroke-width="6" stroke-linecap="round" />
      <path d="M0 72.2172H64.4344" stroke="currentColor" stroke-width="6" stroke-linecap="round" />
      <path d="M0 92.2172H64.4344" stroke="currentColor" stroke-width="6" stroke-linecap="round" />
    </svg>
  </button>
</header>

{/* === OVERLAY MENU (ДЕСКТОП, lg+) ===
   max-lg:!hidden — на мобиле не показывается никогда (даже когда JS вешает
   `flex` при открытии): !important перекрывает .flex. Мобильный путь — ниже,
   отдельный #mobile-menu. */}
<div
  id="overlay-menu"
  class="fixed inset-0 z-50 hidden flex-col overflow-y-auto bg-cream max-lg:!hidden"
  aria-hidden="true"
>
  {/* Фон-градиент — на основе того, что виден на скриншотах menu-1..4.
     Без отдельного фото — чистый CSS градиент в кремово-золотых тонах.
     Сделан мягче исходного, чтобы gold-текст не растворялся
     в правой тёмной части (раньше доходило до #b5946a, теперь #c9b187). */}
  <div
    class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(ellipse 70% 90% at 20% 35%, #f0eadc 0%, #ddc8a0 70%, #c9b187 100%);"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 flex min-h-full flex-col">
    {/* Верх overlay: лого + крестик */}
    <div class="flex items-start justify-between px-[7.55%] pt-8">
      <a href="/" class="block" aria-label="IDEAL Medical and Wellness — home">
        <img
          src="/assets/images/logo-ideal.svg"
          alt="IDEAL Medical and Wellness"
          width="194"
          height="62"
          class="h-auto w-[194px]"
        />
      </a>
      <button
        id="menu-close"
        type="button"
        class="block text-gold-bright transition-opacity hover:opacity-70"
        aria-label="Close menu"
      >
        <svg width="42" height="42" viewBox="0 0 42 42" fill="none" aria-hidden="true">
          <path d="M2 2 L40 40 M40 2 L2 40" stroke="currentColor" stroke-width="2" />
        </svg>
      </button>
    </div>

    {/* Центр overlay: основные пункты + подменю + CTA.
        Маркер data-nav-hover-zone — это горячая зона для hover: пока мышь
        внутри этого контейнера (на заголовках ИЛИ внутри подменю, ИЛИ в
        пустом пространстве между ними), временный hover-preview сохраняется.
        Выход за пределы возвращает к sticky состоянию. */}
    <div class="flex flex-1 items-start px-[7.55%] pt-[120px] max-lg:pt-10">
      <div class="flex w-full max-w-content gap-12 max-lg:flex-col max-lg:gap-6" data-nav-hover-zone>
        {/* Основные пункты */}
        <nav class="flex flex-col gap-1" aria-label="Main navigation">
          <ul class="flex flex-col gap-1">
            {mainNav.map((group: NavGroup) => {
              const isActive = group.label === activeGroupLabel;
              const isDefaultOpen = group.label === defaultOpenLabel;
              return (
                <li class="group/item" data-nav-group={group.label}>
                  <button
                    type="button"
                    class="inline-flex items-center gap-4 font-heading text-[34px] md:text-[44px] lg:text-[64px] uppercase leading-tight text-gold transition-opacity hover:opacity-70 [text-shadow:0_1px_0_rgba(255,255,255,0.4)]"
                    data-nav-target={group.label}
                    data-nav-active={isDefaultOpen ? 'true' : undefined}
                    aria-current={isActive ? 'true' : undefined}
                  >
                    <span>{group.label}</span>
                    {/* Орнамент-индикатор активного раздела (узел Figma 1:1983).
                        Показывается только для реально активной страницы
                        (sub-навигация). На главной — не показываем ни для одного
                        раздела, хотя defaultOpenLabel = Wellness Services
                        (чтобы юзер не думал, будто он на странице Wellness).
                        JS ниже переключает opacity при hover. */}
                    <img
                      src="/assets/images/star-sign.svg"
                      alt=""
                      width="33"
                      height="39"
                      class={`h-[39px] w-[33px] flex-shrink-0 ${isActive ? 'opacity-100' : 'opacity-0'}`}
                      data-nav-ornament={group.label}
                      aria-hidden="true"
                    />
                  </button>
                </li>
              );
            })}
          </ul>

          {/* CTA BOOK APPOINTMENT. min-w чтобы соответствовать ширине в Figma
              (282px по узлу 1:2010), но позволить расти если нужно. */}
          <a
            href={bookingCta.href}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-gold mt-12 self-start lg:min-w-[282px] max-lg:w-full max-lg:mt-8 whitespace-nowrap"
          >
            {bookingCta.label}
          </a>
        </nav>

        {/* Подменю справа от пунктов. Открыто по умолчанию для defaultOpenLabel
            (= активный раздел текущей страницы, либо первый раздел как fallback
            для главной). При hover/click на другом разделе — переключается.

            min-h-[489px] — высота вертикальной линии-разделителя из Figma
            (узел 1:3785, Line 1 = 1×489). Совпадает с высотой подменю
            Wellness Services (9 items × 42px line-height + 8 × gap-2). Без этого
            при переключении с 9-пунктового Wellness на 2-3-пунктовые Aesthetic/
            About контейнер сжимается, линия укорачивается, и нижний футер
            "прыгает" вверх на 30+px. */}
        <div class="flex-1 lg:border-l lg:border-gold/40 lg:pl-12 lg:min-h-[489px]">
          {mainNav.map((group: NavGroup) => {
            const isDefaultOpen = group.label === defaultOpenLabel;
            return (
              <ul
                class={`flex-col gap-2 ${isDefaultOpen ? 'flex' : 'hidden'}`}
                data-nav-panel={group.label}
              >
                {group.items?.map((item) => {
                  const current = isItemCurrent(item.href);
                  return (
                    <li>
                      <a
                        href={item.href}
                        class={`font-sans text-[20px] lg:text-[28px] transition-opacity hover:opacity-70
                                ${current ? 'text-gold font-semibold' : 'text-gold'}`}
                        aria-current={current ? 'page' : undefined}
                      >
                        {item.label}
                      </a>
                    </li>
                  );
                })}
              </ul>
            );
          })}
        </div>
      </div>
    </div>

    {/* Низ overlay: компактный футер */}
    <div class="px-[7.55%] pb-12 pt-16">
      <FooterBlock variant="compact" />
    </div>
  </div>
</div>

{/* === MOBILE MENU (< lg) — двухуровневый drill-down (Вариант C) ===
   Два уровня — состояние ОДНОГО overlay (URL не меняется):
     L1 (data-mobile-panel="l1") — 3 категории, тап → drill-in.
     L2 (data-mobile-panel="l2") — метка раздела + пункты, выезжает справа.
   У каждой панели свой НЕПРОЗРАЧНЫЙ градиент-фон, иначе при slide
   просвечивают друг через друга (словлено на прототипе).
   lg:!hidden — на десктопе не показывается (там #overlay-menu выше). */}
<div
  id="mobile-menu"
  class="fixed inset-0 z-50 hidden h-[100dvh] flex-col overflow-hidden lg:!hidden"
  style="background: radial-gradient(ellipse 70% 90% at 20% 35%, #f0eadc 0%, #ddc8a0 70%, #c9b187 100%);"
  aria-hidden="true"
>
  {/* --- LEVEL 1 --- */}
  <div
    data-mobile-panel="l1"
    class="absolute inset-0 flex translate-x-0 flex-col transition-transform duration-[340ms] ease-out motion-reduce:transition-none"
    style="background: radial-gradient(ellipse 70% 90% at 20% 35%, #f0eadc 0%, #ddc8a0 70%, #c9b187 100%);"
  >
    {/* top-bar: лого слева + ✕ справа */}
    <div class="flex shrink-0 items-center justify-between px-[7.55%] pb-6 pt-8">
      <a href="/" class="block" aria-label="IDEAL Medical and Wellness — home">
        <img
          src="/assets/images/logo-ideal.svg"
          alt="IDEAL Medical and Wellness"
          width="194"
          height="62"
          class="h-auto w-[160px]"
        />
      </a>
      <button
        type="button"
        data-mobile-close
        class="-mr-1 block p-1 text-gold-bright transition-opacity hover:opacity-70"
        aria-label="Close menu"
      >
        <svg width="30" height="30" viewBox="0 0 42 42" fill="none" aria-hidden="true">
          <path d="M2 2 L40 40 M40 2 L2 40" stroke="currentColor" stroke-width="2" />
        </svg>
      </button>
    </div>

    {/* 3 категории — drill-in по тапу */}
    <nav class="flex-1 overflow-y-auto overscroll-contain px-[7.55%]" aria-label="Mobile menu">
      <ul class="border-t border-gold/20">
        {mainNav.map((group: NavGroup) => (
          <li class="border-b border-gold/20">
            <button
              type="button"
              data-mobile-drill={group.label}
              class="flex min-h-[44px] w-full items-center justify-between gap-4 py-5 text-left font-heading text-[32px] uppercase leading-tight text-gold transition-opacity hover:opacity-70"
            >
              <span>{group.label}</span>
              <svg class="shrink-0 text-gold-bright" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
          </li>
        ))}
      </ul>
    </nav>

    {/* CTA закреплён внизу (L1) */}
    <div class="shrink-0 px-[7.55%] pb-8 pt-6">
      <a
        href={bookingCta.href}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-gold w-full"
      >
        {bookingCta.label}
      </a>
    </div>
  </div>

  {/* --- LEVEL 2 --- (z-10: поверх L1 во время slide) */}
  <div
    data-mobile-panel="l2"
    class="absolute inset-0 z-10 flex translate-x-full flex-col transition-transform duration-[340ms] ease-out motion-reduce:transition-none"
    style="background: radial-gradient(ellipse 70% 90% at 20% 35%, #f0eadc 0%, #ddc8a0 70%, #c9b187 100%);"
    inert
  >
    {/* top-bar: ‹ Back слева + ✕ справа */}
    <div class="flex shrink-0 items-center justify-between px-[7.55%] pb-6 pt-8">
      <button
        type="button"
        data-mobile-back
        class="-ml-1 flex items-center gap-1 p-1 font-sans text-[15px] uppercase tracking-[0.12em] text-gold transition-opacity hover:opacity-70"
        aria-label="Back to main menu"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span>Back</span>
      </button>
      <button
        type="button"
        data-mobile-close
        class="-mr-1 block p-1 text-gold-bright transition-opacity hover:opacity-70"
        aria-label="Close menu"
      >
        <svg width="30" height="30" viewBox="0 0 42 42" fill="none" aria-hidden="true">
          <path d="M2 2 L40 40 M40 2 L2 40" stroke="currentColor" stroke-width="2" />
        </svg>
      </button>
    </div>

    {/* Списки разделов — виден активный (data-mobile-cat). Зона свайпа-Back. */}
    <div data-mobile-swipe class="flex-1 overflow-y-auto overscroll-contain px-[7.55%]">
      {mainNav.map((group: NavGroup) => (
        <div data-mobile-cat={group.label} class="hidden">
          {/* некликабельная метка-заголовок раздела (focus при drill-in) */}
          <p
            data-mobile-label
            tabindex="-1"
            class="pb-5 pt-2 font-sans text-[13px] uppercase tracking-[0.18em] text-gold/70 outline-none"
          >
            {group.label}
          </p>
          <ul class="flex flex-col gap-1 pb-2">
            {group.items?.map((item) => {
              const current = isItemCurrent(item.href);
              return (
                <li>
                  <a
                    href={item.href}
                    class={`flex min-h-[44px] items-center gap-3 py-3 font-sans text-[20px] transition-opacity hover:opacity-70
                            ${current ? 'font-semibold text-gold' : 'text-gold'}`}
                    aria-current={current ? 'page' : undefined}
                  >
                    {/* слот-точка фиксированной ширины → текст всех пунктов выровнен,
                        точка-индикатор видна только у текущей страницы */}
                    <span
                      class={`h-2 w-2 shrink-0 rounded-full ${current ? 'bg-gold-bright' : 'bg-transparent'}`}
                      aria-hidden="true"
                    ></span>
                    <span>{item.label}</span>
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))}
    </div>

    {/* CTA закреплён внизу И на L2 (в один тап на обоих уровнях) */}
    <div class="shrink-0 px-[7.55%] pb-8 pt-6">
      <a
        href={bookingCta.href}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-gold w-full"
      >
        {bookingCta.label}
      </a>
    </div>
  </div>
</div>

<script>
  // Управление overlay-меню — minimal vanilla JS, без зависимостей.
  const toggle = document.getElementById('menu-toggle');
  const close = document.getElementById('menu-close');
  const overlay = document.getElementById('overlay-menu');       // десктоп (lg+)
  const mobileMenu = document.getElementById('mobile-menu');     // мобильный drill-down (< lg)

  // Текущее "запомненное" состояние подменю. Изначально = серверный default
  // (data-nav-active="true" на одном из заголовков). При hover временно
  // показываем другой раздел, на mouseleave возвращаемся к запомненному.
  // При click — меняем запомненное на новое.
  function getServerDefault(): string | undefined {
    const el = document.querySelector<HTMLElement>('[data-nav-target][data-nav-active="true"]');
    return el?.dataset.navTarget;
  }
  let stickySection: string | undefined = getServerDefault();

  // --- Открытие/закрытие управляет ОБОИМИ overlay (#overlay-menu для lg+,
  //     #mobile-menu для < lg). Видимость решает CSS-гейт по брейкпоинту,
  //     поэтому JS-детект вьюпорта не нужен — открываем оба, видно нужный. ---
  function openMenu() {
    if (!toggle) return;
    toggle.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';

    if (overlay) {
      overlay.classList.remove('hidden');
      overlay.classList.add('flex');
      overlay.setAttribute('aria-hidden', 'false');
      // Десктоп: показываем sticky (последнее выбранное или server default).
      showPanel(stickySection);
    }
    if (mobileMenu) {
      mobileMenu.classList.remove('hidden');
      mobileMenu.classList.add('flex');
      mobileMenu.setAttribute('aria-hidden', 'false');
      setMobileLevel(null); // всегда с корня (L1) — последний раздел не запоминаем
    }
  }

  function closeMenu() {
    if (!toggle) return;
    // Снять фокус с элемента внутри overlay перед aria-hidden=true
    // (иначе браузер ругается на aria-hidden у предка фокуса).
    const active = document.activeElement;
    if (
      active instanceof HTMLElement &&
      (overlay?.contains(active) || mobileMenu?.contains(active))
    ) {
      active.blur();
    }
    toggle.focus();
    toggle.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';

    if (overlay) {
      overlay.classList.add('hidden');
      overlay.classList.remove('flex');
      overlay.setAttribute('aria-hidden', 'true');
    }
    if (mobileMenu) {
      mobileMenu.classList.add('hidden');
      mobileMenu.classList.remove('flex');
      mobileMenu.setAttribute('aria-hidden', 'true');
      setMobileLevel(null); // сброс на L1 для следующего открытия
    }
  }

  toggle?.addEventListener('click', openMenu);
  close?.addEventListener('click', closeMenu);

  // Esc — закрыть (любой из overlay открыт). На L2 Esc закрывает целиком
  // (не Back) — по утверждённой спеке.
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    const open =
      overlay?.getAttribute('aria-hidden') === 'false' ||
      mobileMenu?.getAttribute('aria-hidden') === 'false';
    if (open) closeMenu();
  });

  // ===== МОБИЛЬНЫЙ drill-down (< lg) =====
  const mPanelL1 = mobileMenu?.querySelector<HTMLElement>('[data-mobile-panel="l1"]');
  const mPanelL2 = mobileMenu?.querySelector<HTMLElement>('[data-mobile-panel="l2"]');
  let activeCategory: string | null = null;     // null = L1, иначе ярлык раздела (L2)
  let lastDrillBtn: HTMLElement | null = null;   // категория-источник (фокус при Back)

  // Переключение уровня: null → L1, иначе → L2 выбранного раздела.
  function setMobileLevel(category: string | null) {
    activeCategory = category;
    const atL2 = category !== null;

    if (mPanelL1 && mPanelL2) {
      // L1 — лёгкий параллакс влево; L2 — выезжает справа.
      mPanelL1.classList.toggle('-translate-x-1/4', atL2);
      mPanelL1.classList.toggle('translate-x-0', !atL2);
      mPanelL2.classList.toggle('translate-x-0', atL2);
      mPanelL2.classList.toggle('translate-x-full', !atL2);
      // Фокус-разделение: неактивная панель inert (вне tab-порядка и от AT) —
      // иначе её фокусируемые элементы остаются в обходе Tab, хоть и за экраном.
      mPanelL1.toggleAttribute('inert', atL2);
      mPanelL2.toggleAttribute('inert', !atL2);
    }
    // На L2 показываем список ровно активного раздела.
    mobileMenu?.querySelectorAll<HTMLElement>('[data-mobile-cat]').forEach((block) => {
      block.classList.toggle('hidden', block.dataset.mobileCat !== category);
    });
  }

  function mobileDrillIn(category: string, sourceBtn: HTMLElement) {
    lastDrillBtn = sourceBtn;
    setMobileLevel(category);
    // Фокус → некликабельная метка раздела (tabindex=-1, принимает focus().
    const label = mobileMenu?.querySelector<HTMLElement>(
      `[data-mobile-cat="${category}"] [data-mobile-label]`
    );
    label?.focus();
  }

  function mobileBack() {
    setMobileLevel(null);
    lastDrillBtn?.focus(); // фокус → категория-источник
  }

  // L1: тап категории → drill-in
  mobileMenu?.querySelectorAll<HTMLElement>('[data-mobile-drill]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.mobileDrill;
      if (cat) mobileDrillIn(cat, btn);
    });
  });
  // L2: ‹ Back → обратно на L1
  mobileMenu?.querySelectorAll<HTMLElement>('[data-mobile-back]').forEach((btn) => {
    btn.addEventListener('click', mobileBack);
  });
  // ✕ (оба уровня) → закрыть
  mobileMenu?.querySelectorAll<HTMLElement>('[data-mobile-close]').forEach((btn) => {
    btn.addEventListener('click', closeMenu);
  });

  // Свайп вправо в зоне списка L2 = Back (v1). Порог 60px, горизонталь > вертикали.
  const swipeZone = mobileMenu?.querySelector<HTMLElement>('[data-mobile-swipe]');
  let touchStartX = 0;
  let touchStartY = 0;
  let tracking = false;
  swipeZone?.addEventListener(
    'touchstart',
    (e) => {
      if (activeCategory === null) return;
      const t = e.touches[0];
      touchStartX = t.clientX;
      touchStartY = t.clientY;
      tracking = true;
    },
    { passive: true }
  );
  swipeZone?.addEventListener(
    'touchend',
    (e) => {
      if (!tracking || activeCategory === null) return;
      tracking = false;
      const t = e.changedTouches[0];
      const dx = t.clientX - touchStartX;
      const dy = t.clientY - touchStartY;
      if (dx > 60 && Math.abs(dx) > Math.abs(dy) * 1.5) mobileBack();
    },
    { passive: true }
  );

  // Focus-trap внутри мобильного меню (Tab по кругу). Неактивная панель inert,
  // поэтому в обход попадают только видимые фокусируемые элементы активной.
  mobileMenu?.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab' || !mobileMenu) return;
    const focusables = Array.from(
      mobileMenu.querySelectorAll<HTMLElement>(
        'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'
      )
    ).filter((el) => el.offsetParent !== null && !el.closest('[inert]'));
    if (focusables.length === 0) return;
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  });

  // Hover/focus/click по главному пункту → показать соответствующий подменю-список
  // + показать орнамент рядом с этим пунктом.
  // - hover/focus: временный show (mouseleave возвращает к sticky)
  // - click: сохранить новый sticky (touch-friendly — на iPad/телефонах нет hover)
  document.querySelectorAll<HTMLElement>('[data-nav-target]').forEach((btn) => {
    const target = btn.dataset.navTarget;
    btn.addEventListener('mouseenter', () => showPanel(target));
    btn.addEventListener('focus', () => showPanel(target));
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      stickySection = target;
      showPanel(target);
    });
  });

  // При уходе курсора из hover-zone (= общий контейнер заголовков + подменю)
  // возвращаемся к sticky выбору. Слушаем именно общий контейнер, а не <nav>,
  // потому что юзер часто двигает мышь от заголовка к пунктам подменю,
  // пересекая визуально пустое пространство (вертикальную линию + padding).
  // Если слушать <nav>, mouseleave срабатывает в этой пустой зоне и сбрасывает
  // подменю до того, как мышь успеет дойти до пунктов.
  // На touch-устройствах mouseleave обычно не срабатывает — sticky уже обновлён
  // в click handler выше, и подменю остаётся в выбранном состоянии.
  const hoverZone = document.querySelector<HTMLElement>('[data-nav-hover-zone]');
  hoverZone?.addEventListener('mouseleave', () => showPanel(stickySection));

  function showPanel(name?: string) {
    // Панели
    document.querySelectorAll<HTMLElement>('[data-nav-panel]').forEach((p) => {
      const match = !!name && p.dataset.navPanel === name;
      p.classList.toggle('flex', match);
      p.classList.toggle('hidden', !match);
    });
    // Орнамент — показываем при hover/click на любой раздел.
    // SSR-орнамент (для реально активной страницы) остаётся постоянно.
    // На главной activeGroupLabel = undefined, орнамент при hover тоже временный.
    document.querySelectorAll<HTMLElement>('[data-nav-ornament]').forEach((o) => {
      const match = !!name && o.dataset.navOrnament === name;
      o.classList.toggle('opacity-100', match);
      o.classList.toggle('opacity-0', !match);
    });
  }
</script>
