---
/**
 * Testimonials — "What Our Clients Say": карусель отзывов по 2 на странице.
 *
 * Отзывы реальные, со старого сайта idealmedwell.com. Дословные цитаты —
 * НЕ редактировать (включая "Dr Ksenia/Dr Ken": это слова клиента).
 *
 * Карусель: показываем ПО 2 отзыва за раз (6 отзывов → 3 страницы).
 * Переключение через display (hidden), НЕ через absolute-наложение —
 * поэтому высота секции подстраивается под контент и текст никогда не
 * налезает на индикаторы. Авто-смена 8с, клик по точкам, пауза при
 * hover/focus, уважает prefers-reduced-motion.
 */
import Container from '../Container.astro';
import TrustBadges from '../TrustBadges.astro';

const testimonials = [
  {
    quote:
      'Ideal Medical and Wellness completely transformed how I approach my health. Their personalized care has helped me regain energy, clarity, and balance. I now feel more in control of my wellness journey than ever before. The team really takes the time to understand your unique needs and tailors treatments that fit your life. I couldn\u2019t be happier with the results!',
    author: 'Emily R.',
  },
  {
    quote:
      'I recently visited Ideal Medical and Wellness Center and had an outstanding experience. The staff was incredibly professional and attentive, making sure all my needs were met. The facility itself is modern, clean, and well-equipped with the latest medical technology. I was particularly impressed by the thoroughness of the doctors and the personalized care I received. They took the time to explain everything in detail and made me feel comfortable throughout my visit. I highly recommend this center to anyone looking for top-notch medical and wellness services.',
    author: 'Marian S.',
  },
  {
    quote:
      'I am extremely blessed to have met these two amazing doctors who have helped me tremendously when other doctors could not. Dr Ksenia and Dr Ken are both extremely knowledgeable and they take their time to understand all your needs so they can help you completely until you are well. They are doctors to my husband and my children as well. The staff are wonderful and friendly and make you feel very comfortable. If I could give 1000 stars I would!',
    author: 'Kim D.',
  },
  {
    quote:
      'The entire team at Ideal Medical and Wellness are fantastic. When it comes to your health, communication is key and they are the best. They make the process easy and continue to be a true partner in your treatment long after your first visit. I highly recommend them!',
    author: 'Diz R.',
  },
  {
    quote:
      'Ideal Medical and Wellness has been instrumental in helping me bounce back after my stage 4 cancer battle. Their personalized care was exactly what I needed during my recovery. From day one, the team listened carefully to my unique health challenges and created a comprehensive wellness plan that focused on my physical and emotional healing. The staff\u2019s expertise, combined with their genuine compassion, made all the difference.',
    author: 'Kyle R.',
  },
  {
    quote:
      'Nothing but an amazing experience here, I am extremely thankful to have found and dealt with them, they truly care about their patients here. Dr Ksenia and Ken are very knowledgeable and have a lot of experience behind them. They truly strive for the best for their patients and are passionate about helping.',
    author: 'Isaac G.',
  },
];

// Группируем по 2 отзыва на страницу
const pages = [];
for (let i = 0; i < testimonials.length; i += 2) {
  pages.push(testimonials.slice(i, i + 2));
}
---

<section
  class="w-full bg-cream py-24"
  data-section="testimonials"
>
  <Container>
    <h2 class="text-center font-heading text-h1 uppercase text-gold">
      What Our Clients Say
    </h2>

    <div
      class="relative mt-16"
      data-carousel
      role="group"
      aria-roledescription="carousel"
      aria-label="Client testimonials"
    >
      {/* Стрелки навигации по бокам (как в Figma). Скрыты на мобильных —
          там листание точками/свайпом. Подключены к JS карусели ниже. */}
      <button
        type="button"
        data-prev
        aria-label="Previous testimonials"
        class="absolute left-0 top-[40%] z-10 hidden -translate-y-1/2 p-2 text-gold transition-opacity hover:opacity-60 md:block"
      >
        <svg width="22" height="44" viewBox="0 0 22 44" fill="none" aria-hidden="true">
          <path d="M18 4 L5 22 L18 40" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
      <button
        type="button"
        data-next
        aria-label="Next testimonials"
        class="absolute right-0 top-[40%] z-10 hidden -translate-y-1/2 p-2 text-gold transition-opacity hover:opacity-60 md:block"
      >
        <svg width="22" height="44" viewBox="0 0 22 44" fill="none" aria-hidden="true">
          <path d="M4 4 L17 22 L4 40" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>

      {pages.map((pair, p) => (
        <div
          data-page
          data-index={p}
          class={`grid grid-cols-1 gap-12 md:grid-cols-2 ${p === 0 ? '' : 'hidden'}`}
        >
          {pair.map((t) => (
            <figure class="flex flex-col items-center text-center">
              <span class="font-heading text-[80px] leading-none text-gold" aria-hidden="true">
                &ldquo;&rdquo;
              </span>
              <blockquote class="mt-4 max-w-[610px] font-sans text-[18px] leading-relaxed text-gold">
                {t.quote}
              </blockquote>
              <figcaption class="mt-6 font-sans text-[18px] uppercase tracking-wider text-gold">
                {t.author}
              </figcaption>
            </figure>
          ))}
        </div>
      ))}

      {/* Индикаторы — по одному на страницу (пару отзывов) */}
      <div class="mt-16 flex justify-center gap-2" role="tablist" aria-label="Choose testimonials page">
        {pages.map((_, p) => (
          <button
            type="button"
            data-dot
            data-index={p}
            role="tab"
            aria-label={`Show testimonials page ${p + 1} of ${pages.length}`}
            aria-selected={p === 0 ? 'true' : 'false'}
            class="h-[3px] w-[70px] bg-gold/40 aria-selected:bg-gold transition-colors"
          ></button>
        ))}
      </div>
    </div>

    <div class="mt-12 flex flex-col items-center">
      <TrustBadges standalone={false} />
    </div>
  </Container>
</section>

<script>
  document.querySelectorAll('[data-carousel]').forEach((root) => {
    const pages = Array.from(root.querySelectorAll('[data-page]'));
    const dots = Array.from(root.querySelectorAll('[data-dot]'));
    const prevBtn = root.querySelector('[data-prev]');
    const nextBtn = root.querySelector('[data-next]');
    if (pages.length <= 1) return;

    let current = 0;
    let timer;
    const INTERVAL = 8000;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function show(next) {
      const n = ((next % pages.length) + pages.length) % pages.length;
      pages.forEach((pg, i) => pg.classList.toggle('hidden', i !== n));
      dots.forEach((d, i) => d.setAttribute('aria-selected', i === n ? 'true' : 'false'));
      current = n;
    }
    function start() {
      if (reduceMotion) return;
      stop();
      timer = window.setInterval(() => show(current + 1), INTERVAL);
    }
    function stop() {
      if (timer) window.clearInterval(timer);
    }

    dots.forEach((dot, i) =>
      dot.addEventListener('click', () => {
        show(i);
        start();
      })
    );

    prevBtn?.addEventListener('click', () => {
      show(current - 1);
      start();
    });
    nextBtn?.addEventListener('click', () => {
      show(current + 1);
      start();
    });

    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);
    root.addEventListener('focusin', stop);
    root.addEventListener('focusout', start);

    start();
  });
</script>
