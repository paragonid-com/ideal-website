---
/**
 * BrandStrip — ряд логотипов препаратов на БЕЛОЙ полосе.
 * Между Discover (cream) и Signature Services (cream): белый фон образует
 * отдельную полосу, как в макете.
 *
 * Источник Figma (HOME): 1:210 Tesamorelin, 1:211 Ozempic,
 * 1:216 NAD+, 1:179 TESTOSTERONE, 1:217 Mounjaro.
 * Логотипы выровнены по близкой визуальной высоте и равномерно распределены.
 *
 * NAD+ и TESTOSTERONE — текст (sans-serif в макете); Tesamorelin, Ozempic,
 * Mounjaro — PNG (обрезаны по контенту, прозрачный фон, читаются и на белом).
 *
 * ⚠️ Ozempic® и Mounjaro® — товарные знаки. Использование требует
 * юридической проверки. См. docs/stock-photo-inventory.md.
 */
import Container from '../Container.astro';

// Высоты подобраны под макет так, чтобы визуальная высота начертаний была
// примерно одинаковой. У двухстрочных логотипов (Ozempic — лого+подпись,
// Mounjaro — иконка+слово) высота больше, у одностройчного Tesamorelin меньше.
const logos = [
  { name: 'Tesamorelin', src: '/assets/images/brand-tesamorelin.png', cls: 'h-[28px] md:h-[32px]' },
  { name: 'Ozempic',     src: '/assets/images/brand-ozempic.png',     cls: 'h-[46px] md:h-[56px]', trademark: true },
];
const logosRight = [
  { name: 'Mounjaro',    src: '/assets/images/brand-mounjaro.png',    cls: 'h-[56px] md:h-[66px]', trademark: true },
];
---

<section class="w-full bg-white py-12 md:py-14" data-section="brand-strip">
  <Container>
    <div
      class="flex flex-wrap items-center justify-center gap-x-10 gap-y-8 md:justify-between md:gap-x-8"
      data-todo="trademark-review"
    >
      {logos.map((b) => (
        <img
          src={b.src}
          alt={b.name}
          class={`${b.cls} w-auto object-contain`}
          loading="lazy"
          data-trademark={b.trademark ? 'yes' : undefined}
        />
      ))}

      {/* NAD+ — bold sans, dark. Плюс слегка приподнят как в макете. */}
      <span class="font-sans text-[34px] md:text-[42px] font-bold leading-none text-[#222]">
        NAD<sup class="text-[0.62em] top-[-0.45em] relative font-semibold">+</sup>
      </span>

      {/* TESTOSTERONE — bold sans с разрядкой, dark. */}
      <span class="font-sans text-[26px] md:text-[29px] font-bold tracking-[0.02em] leading-none text-[#222]">
        TESTOSTERONE
      </span>

      {logosRight.map((b) => (
        <img
          src={b.src}
          alt={b.name}
          class={`${b.cls} w-auto object-contain`}
          loading="lazy"
          data-trademark={b.trademark ? 'yes' : undefined}
        />
      ))}
    </div>
  </Container>
</section>
