---
/**
 * BrandStrip — row of treatment-category labels on a white band between
 * Discover (cream) and Signature Services (cream).
 *
 * Brand Rx logos (Ozempic®, Mounjaro®, Tesamorelin) were removed: trademark
 * use, off-label implication (Ozempic/Mounjaro are diabetes brands, not the
 * weight-loss-approved Wegovy/Zepbound), and restricted-drug ad policy.
 * Replaced with non-branded service categories.
 */
import Container from '../Container.astro';

const labelsLeft = ['GLP-1 Therapy', 'Peptide Therapy'];
const labelsRight = ['Testosterone', 'IV Therapy'];
const labelCls =
  'font-sans text-[22px] md:text-[28px] font-bold uppercase tracking-[0.02em] leading-none text-[#222]';
---

<section class="w-full bg-white py-12 md:py-14" data-section="brand-strip">
  <Container>
    <div
      class="flex flex-wrap items-center justify-center gap-x-10 gap-y-6 md:justify-between md:gap-x-8"
    >
      {labelsLeft.map((l) => <span class={labelCls}>{l}</span>)}

      {/* NAD+ — bold sans, dark, slightly raised plus as in the design. */}
      <span class="font-sans text-[34px] md:text-[42px] font-bold leading-none text-[#222]">
        NAD<sup class="text-[0.62em] top-[-0.45em] relative font-semibold">+</sup>
      </span>

      {labelsRight.map((l) => <span class={labelCls}>{l}</span>)}
    </div>
  </Container>
</section>
