---
/**
 * WhoWeAre — секция с тремя портретами команды клиники.
 *
 * Источник: узлы 1:103 (заголовок WHO WE ARE), 1:135 (длинный параграф),
 *           1:248/48/49 (три портрета), 1:180-1:185 (имена и должности)
 */
import Container from '../Container.astro';

const team = [
  {
    name: 'Ksenia Petrushkina, PA-C, MPAS',
    title: 'Owner & Director of Operations',
    photo: '/assets/images/team-ksenia.webp',
  },
  {
    name: 'Kenneth Persy',
    title: 'Owner & Wellness Expert',
    photo: '/assets/images/team-kenneth.webp',
  },
  {
    name: 'Laudin Percy',
    title: 'Owner',
    photo: '/assets/images/team-laudin.webp',
  },
];

const aboutText = `Ideal Medical & Wellness is a physician-supervised medical and wellness practice in Aventura, Florida, serving patients across South Florida. We offer a comprehensive range of care — hormone optimization and BHRT, medical weight loss, peptide therapy, IV therapy, and advanced aesthetic device treatments — and we combine clinical rigor with a concierge experience. Every treatment begins with diagnostics, not assumptions, and is managed by a clinician who knows your case. Whether your goal is anti-aging, weight loss, or long-term metabolic health, our team builds a plan around your labs, your goals, and your schedule.`;
---

<section
  class="w-full bg-cream py-24"
  data-section="who-we-are"
>
  <Container>
    <div class="relative">
      <h2 class="font-heading text-h1 uppercase text-gold">Who We Are</h2>

      {/* Звезда из Figma (узел 1:236) — в правом верхнем углу контейнера на одной
          линии с H2. Figma-координаты: x=1732, y=3184, размер 42.57×50. */}
      <img
        src="/assets/images/star-sign.svg"
        alt=""
        width="43"
        height="50"
        class="absolute right-0 top-0 h-[50px] w-[43px]"
        aria-hidden="true"
      />
    </div>

    <p class="mt-8 max-w-[902px] font-sans text-body-lg leading-relaxed text-gold">
      {aboutText}
    </p>

    {/* Портреты: каждый ≈400px как в Figma (узлы 1:248/48/49 = 390-400×600),
        выровнены влево с отступом ~40px, ряд НЕ растягивается на всю ширину
        контейнера. Это убирает апскейл низкого разрешения (kenneth/laudin
        исходники ~274px) и искажение. */}
    <ul class="mt-16 grid max-w-[1273px] grid-cols-1 gap-x-10 gap-y-12 md:grid-cols-3">
      {team.map((member) => (
        <li>
          <div class="aspect-[400/600] overflow-hidden bg-gold/10">
            <img
              src={member.photo}
              alt={`Portrait of ${member.name}`}
              class="h-full w-full object-cover"
              loading="lazy"
            />
          </div>
          <h3 class="mt-6 font-heading text-[32px] uppercase text-gold">
            {member.name}
          </h3>
          <p
            class="mt-1 font-sans text-[18px] uppercase tracking-wider text-gold"
          >
            {member.title}
          </p>
        </li>
      ))}
    </ul>
  </Container>
</section>
