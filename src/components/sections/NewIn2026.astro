---
/**
 * NewIn2026 — узкая тёмная полоса-анонс новой услуги.
 *
 * Источник: узлы 1:311 (tag "NEW IN 2026"), 1:254 (Strengthen Your Mind),
 *           1:13 (Image 110 — dark BG), 1:1776 (мозг brain image)
 *
 * Структура: справа фон с золотистой текстурой + изображение мозга поверх,
 * слева текст. Узкая высота (~250-300px).
 */
import Container from '../Container.astro';
---

<section
  class="group relative w-full overflow-hidden min-h-[248px] flex items-center"
  style="background: linear-gradient(90deg, #1a141f 0%, #2c1f15 55%, #3d2918 100%);"
  data-section="new-in-2026"
>
  {/* Изображение мозга-головы — правый край. Чёрный фон картинки убирается
      через mix-blend-screen, остаётся свечение нейросети (как в Figma).
      Крупнее и ярче прежнего варианта. */}
  <img
      width="3000"
      height="3236"
    src="/assets/images/new2026-brain.webp"
    alt=""
    class="pointer-events-none absolute right-[1%] top-1/2 h-[150%] w-auto -translate-y-1/2 object-contain opacity-95 mix-blend-screen"
    aria-hidden="true"
  />

  {/* Растянутая ссылка — вся полоса кликабельна и ведёт на страницу EXOMIND.
      aria-label даёт скринридеру осмысленный текст вместо «New in 2026 EXOMIND…». */}
  <a
    href="/services/exomind"
    class="absolute inset-0 z-20"
    aria-label="EXOMIND — new in 2026. Learn more"
  ></a>

  <Container class="relative z-10 py-12">
    <div class="flex flex-col items-start gap-4 md:flex-row md:items-center md:gap-12 transition-opacity duration-200 group-hover:opacity-90">
      <p class="font-heading text-[40px] uppercase tracking-wider text-cream">
        New in 2026
      </p>
      {/* EXOMIND — брендовый wordmark (геометрический sans): EXO тонким,
          MIND жирным. В Figma это вектор; ближайший доступный шрифт — Manrope. */}
      <h2
        class="text-[48px] uppercase leading-none text-cream"
        data-trademark="btl"
      >
        <span class="font-sans font-light tracking-wide">Exo</span><span class="font-sans font-bold tracking-wide">Mind</span>
      </h2>
      {/* Strengthen Your Mind — Optima/Marcellus (как в Figma), не курсив. */}
      <p class="font-heading text-[30px] not-italic text-cream">
        Strengthen Your Mind
      </p>
    </div>
  </Container>
</section>
