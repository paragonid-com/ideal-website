---
/**
 * AdvancedTreatments — секция с 4 карточками BTL-аппаратов.
 *
 * Источник: узлы 1:150 (заголовок), 1:94 (eyebrow), 1:85/88/91/95 (категории),
 *           1:84/98/99/100 (бренды), 1:114/119/125/130 (описания)
 *
 * ⚠️ В Figma:
 * - опечатка "MENTALL WELLNESS" (двойная L) — оставлено как в макете
 * - все 4 фото — BTL marketing assets, нужно подтверждение партнёрства с BTL
 * - "Discover" eyebrow на каждой карточке — без ссылки, оставлен пока статичным
 */
import Container from '../Container.astro';

const treatments = [
  {
    category: 'Facial Rejuvenation',
    brand: 'EMFACE',
    description:
      'Needle free facial treatment to lift, tone, and smooth skin by strengthening facial muscles and improving skin quality.',
    photo: '/assets/images/treatment-emface.webp',
    href: '/services/emface',
  },
  {
    category: 'Body Sculpting',
    brand: 'EMSCULPT NEO',
    description:
      'High intensity muscle stimulation with radio frequency to build muscle and reduce fat in targeted areas without surgery or downtime.',
    photo: '/assets/images/treatment-emsculpt.webp',
    href: '/services/emsculpt',
  },
  {
    // Помечено для финального ревью — см. docs/site-issues.md
    category: 'Mental Wellness',
    brand: 'EXOMIND',
    description:
      'Advanced neuromodulation therapy to improve mood focus, stress resilience, and emotional balance.',
    photo: '/assets/images/treatment-exomind.webp',
    href: '/services/exomind',
  },
  {
    category: 'Sexual Health',
    brand: 'EMSELLA',
    description:
      'Non invasive pelvic floor strengthening to improve bladder control, core stability, and intimate wellness.',
    photo: '/assets/images/treatment-emsella.webp',
    href: '/services/sexualhealth',
  },
];
---

<section
  class="w-full bg-[#f4f1e8] py-24"
  data-section="advanced-treatments"
>
  <Container>
    <div class="text-center">
      <h2 class="font-heading text-h1 uppercase leading-tight text-gold">
        Advanced<br />
        <span class="relative inline-block">
          Non &ndash; Invasive Treatments
          {/* Звезда из Figma (узел 1:242) — inline сразу после слова TREATMENTS.
              Figma-координаты: x=1547, y=4500, размер 42.57×50. */}
          <img
            src="/assets/images/star-sign.svg"
            alt=""
            width="43"
            height="50"
            class="absolute left-full top-1/2 -translate-y-1/2 ml-2 h-[50px] w-[43px] max-lg:hidden"
            aria-hidden="true"
          />
        </span>
      </h2>
      <p class="mt-4 font-sans text-[18px] uppercase tracking-wider text-[#5a4f33]">
        Now offered at Ideal Medical
      </p>
    </div>

    {/* Карточки центрированы; ширина изображения ≈ как в Signature Services
        (4 колонки в ряду шириной max-w-[1300px] → ~307px, как 5 колонок
        Signature в полной ширине). */}
    <ul class="mx-auto mt-16 grid max-w-[1300px] grid-cols-1 gap-x-6 gap-y-12 sm:grid-cols-2 lg:grid-cols-4">
      {treatments.map((t) => (
        <li>
          <a
            href={t.href}
            class="group block"
            data-trademark="btl"
          >
            {/* Подпись — двухстрочная, шрифтом-заголовком (как в Signature
                Services). Figma: Optima/Marcellus 33px, gold. Все категории —
                из двух слов, делим по первому пробелу. */}
            <p class="font-heading text-[24px] uppercase leading-tight text-gold xl:text-[30px]">
              {t.category.split(' ')[0]}<br />{t.category.split(' ').slice(1).join(' ')}
            </p>
            <div class="relative mt-4 aspect-[400/600] overflow-hidden bg-gold/10">
              <img
                src={t.photo}
                alt={`${t.brand} — ${t.category}`}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              {/* Полоса "Discover" во всю ширину низа фото (как в Figma):
                  светлое золото #dbba5f + тёмно-золотой текст Marcellus.
                  Скрыта, проявляется при наведении на карточку. */}
              <div class="absolute inset-x-0 bottom-0 flex h-[52px] items-center bg-[#dbba5f] pl-4 opacity-0 transition-opacity duration-200 group-hover:opacity-100">
                <span class="font-heading text-[22px] uppercase tracking-[0.1em] text-gold">
                  Discover
                </span>
              </div>
            </div>
            <h3
              class="mt-4 font-heading text-[30px] uppercase text-gold xl:text-[33px]"
              data-todo={t.todo}
            >
              {t.brand}
            </h3>
            <p class="mt-2 font-sans text-[18px] leading-relaxed text-[#5a4f33]">
              {t.description}
            </p>
          </a>
        </li>
      ))}
    </ul>
  </Container>
</section>
