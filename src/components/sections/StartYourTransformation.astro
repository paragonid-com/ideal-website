---
/**
 * StartYourTransformation — двухчастная секция:
 *
 * Часть A: форма "START YOUR WELLNESS TRANSFORMATION" слева,
 *          информация о клинике справа (с placeholder для Lorem Ipsum)
 *
 * Часть B: "Ready to start your transformation today?" — фото здания слева,
 *          CTA и адрес справа, под ними — Google Maps embed
 *
 * Источник: узлы 1:1366 (заголовок Start), 1:1371-1:1390 (поля формы),
 *           1:251 (Ready), 1:255 (BOOK APPOIMENT — опечатка из Figma),
 *           1:264 (We are located), 1:296/1444 (адрес),
 *           1:310 (Image 109 — building photo), 1:1393 (Lorem Ipsum placeholder)
 *
 * ⚠️ Опечатка "APPOIMENT" в Figma сохранена. Также Lorem Ipsum text
 * под формой требует замены на реальный текст от заказчика.
 */
import Container from '../Container.astro';
import { bookingCta } from '../../data/navigation.ts';

const address = {
  name: 'Ideal Medical and Wellness',
  street: '2999 NE 191 Street',
  city: 'Aventura, FL 33180',
  phone: '(305) 650.1884',
};
---

{/* ЧАСТЬ A — форма + копирайт-текст */}
<section
  class="w-full bg-cream py-24"
  data-section="start-transformation-form"
>
  <Container>
    <div class="grid grid-cols-1 gap-12 md:grid-cols-2">
      <div>
        <h2 class="font-heading text-h1 uppercase leading-tight text-gold">
          Start Your<br />
          Wellness<br />
          Transformation
        </h2>
      </div>

      <form
        class="grid grid-cols-1 gap-x-8 gap-y-6 md:grid-cols-2"
        data-todo="form-submission-endpoint"
      >
        <label class="block">
          <span class="font-sans text-[18px] text-gold">First Name (Required)</span>
          <input
            type="text"
            name="firstName"
            required
            class="mt-2 w-full border-b border-gold bg-transparent py-2 font-sans text-gold focus:outline-none"
          />
        </label>
        <label class="block">
          <span class="font-sans text-[18px] text-gold">Last Name (Required)</span>
          <input
            type="text"
            name="lastName"
            required
            class="mt-2 w-full border-b border-gold bg-transparent py-2 font-sans text-gold focus:outline-none"
          />
        </label>
        {/* Email и Phone — full-width в Figma (узлы 1:1793, 1:1794: линии w=914) */}
        <label class="block md:col-span-2">
          <span class="font-sans text-[18px] text-gold">Email (Required)</span>
          <input
            type="email"
            name="email"
            required
            class="mt-2 w-full border-b border-gold bg-transparent py-2 font-sans text-gold focus:outline-none"
          />
        </label>
        <label class="block md:col-span-2">
          <span class="font-sans text-[18px] text-gold">Phone (Required)</span>
          <input
            type="tel"
            name="phone"
            required
            class="mt-2 w-full border-b border-gold bg-transparent py-2 font-sans text-gold focus:outline-none"
          />
        </label>
        <label class="block">
          <span class="font-sans text-[18px] text-gold">Date of Birth (Required)</span>
          <input
            type="date"
            name="dob"
            required
            class="mt-2 w-full border-b border-gold bg-transparent py-2 font-sans text-gold focus:outline-none"
          />
        </label>
        <fieldset class="block">
          <legend class="font-sans text-[18px] text-gold">Contact Preferences</legend>
          <div class="mt-3 flex gap-6">
            <label class="flex items-center gap-2 font-sans text-[18px] text-gold">
              <input type="checkbox" name="contactPref" value="sms" />
              SMS
            </label>
            <label class="flex items-center gap-2 font-sans text-[18px] text-gold">
              <input type="checkbox" name="contactPref" value="email" />
              Email
            </label>
          </div>
        </fieldset>

        <div class="md:col-span-2">
          <button type="submit" class="btn-gold w-[195px]">SUBMIT</button>
        </div>

        {/* Lorem Ipsum placeholder — узел 1:1393 — требует замены на реальный
           disclaimer / privacy notice от заказчика */}
        <p
          class="md:col-span-2 font-sans text-[14px] leading-relaxed text-gold/70"
          data-todo="replace-lorem-ipsum-disclaimer"
        >
          Lorem Ipsum in dolor metLorem Ipsum in dolor met Lorem Ipsum
          in dolor metLorem Ipsum in dolor metLorem Ipsum in dolor met
          metLorem Ipsum in dolor met
        </p>
      </form>
    </div>
  </Container>
</section>

{/* ЧАСТЬ B — Ready to start (CTA + здание + карта) */}
<section
  class="relative w-full"
  data-section="start-transformation-cta"
>
  {/* Фото здания — слева на весь блок */}
  <div class="grid grid-cols-1 md:grid-cols-2">
    <div class="relative aspect-[802/707] md:aspect-auto">
      <img
        src="/assets/images/building-clinic.webp"
        alt="Ideal Medical and Wellness building in Aventura, FL"
        class="absolute inset-0 h-full w-full object-cover"
        loading="lazy"
      />
    </div>

    <div
      class="flex flex-col justify-center px-[7.55%] py-16"
      style="background: linear-gradient(to bottom right, #d4c3a3, #b5946a);"
    >
      <h2 class="font-heading text-h1 uppercase leading-tight text-gold">
        Ready to Start Your<br />
        Transformation Today?
      </h2>

      {/* В Figma — "BOOK APPOIMENT" (без второй n). Оставлено как в макете. */}
      <a
        href={bookingCta.href}
        data-todo="booking-system"
        class="btn-gold mt-8 w-[270px]"
      >
        BOOK APPOIMENT
      </a>

      <p class="mt-12 font-heading text-[36px] uppercase leading-tight text-gold">
        We are located in the<br />
        heart of Aventura, Florida
      </p>

      <address class="mt-8 not-italic font-sans text-[18px] leading-relaxed text-gold">
        <p class="font-heading text-[24px] uppercase">Address</p>
        <p class="mt-2">{address.name}</p>
        <p>{address.street}</p>
        <p>{address.city}</p>
        <p class="mt-4">
          <a href={`tel:${address.phone.replace(/[^\d+]/g, '')}`} class="hover:underline">
            {address.phone}
          </a>
        </p>
      </address>
    </div>
  </div>

  {/* Google Maps embed под блоком — на всю ширину */}
  <div class="aspect-[1920/400] w-full" data-todo="confirm-map-coordinates">
    <iframe
      title="Map showing Ideal Medical and Wellness location"
      src={`https://www.google.com/maps?q=${encodeURIComponent(
        address.street + ', ' + address.city
      )}&output=embed`}
      width="100%"
      height="100%"
      style="border:0;"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
  </div>
</section>
