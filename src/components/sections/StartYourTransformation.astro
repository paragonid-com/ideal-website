---
/**
 * StartYourTransformation — двухчастная секция:
 *
 * Часть A: форма "START YOUR WELLNESS TRANSFORMATION" слева,
 *          информация о клинике справа (с placeholder для Lorem Ipsum)
 *
 * Часть B: "Ready to start your transformation today?" — фото здания слева,
 *          CTA и адрес справа, под ними — Google Maps embed
 *
 * Источник: узлы 1:1366 (заголовок Start), 1:1371-1:1390 (поля формы),
 *           1:251 (Ready), 1:255 (BOOK APPOINTMENT — в Figma была опечатка
 *           "APPOIMENT", исправлена), 1:264 (We are located),
 *           1:296/1444 (адрес), 1:310 (Image 109 — building photo),
 *           1:1393 (был Lorem Ipsum — заменён на consent-текст)
 *
 * ⚠️ Текст согласия под формой — нейтральный плейсхолдер; заказчику нужно
 * утвердить финальную формулировку под свою privacy-политику.
 */
import Container from '../Container.astro';
import { bookingCta } from '../../data/navigation.ts';
import { SITE } from '../../data/site';
import HoursWidget from '../HoursWidget.astro';

interface Props {
  /** Какие части показывать: обе, только форму, или только CTA-баннер.
   *  Дефолт 'both' — обратная совместимость со старыми вызовами. */
  show?: 'both' | 'form' | 'cta';
}
const { show = 'both' } = Astro.props;
const showForm = show === 'both' || show === 'form';
const showCta = show === 'both' || show === 'cta';

const address = {
  name: SITE.legalName,
  street: SITE.address.street,
  suite: SITE.address.suite,
  city: `${SITE.address.city}, ${SITE.address.region} ${SITE.address.postalCode}`,
  phone: SITE.phoneDisplay,
};

// Ссылки «открыть в картах» — строятся из адреса клиники.
const mapQuery = encodeURIComponent(
  `${address.name}, ${address.street}, ${address.suite}, ${address.city}`
);
const googleMapsUrl = `https://www.google.com/maps/search/?api=1&query=${mapQuery}`;
const appleMapsUrl = `https://maps.apple.com/?q=${mapQuery}`;
---

{showForm && (
<section
  class="w-full bg-cream py-8"
  data-section="start-transformation-form"
>
  <Container>
    <div class="grid grid-cols-1 items-start gap-x-16 gap-y-8 lg:grid-cols-[42fr_58fr]">
      <div>
        <h2 class="font-heading text-h1 uppercase leading-tight text-gold">
          Start Your<br />
          Wellness<br />
          Transformation
        </h2>
      </div>

      {/* Форма GoHighLevel (LeadConnector), embed-код из GHL-дашборда.
         Заявки уходят прямо в GHL CRM; поля/валидация/consent-текст
         настраиваются в самой форме внутри GHL, не здесь.
         form_embed.js авто-ресайзит iframe под высоту контента;
         min-height — фолбэк до загрузки скрипта. is:inline — чтобы Astro
         не бандлил сторонний лоадер (как у чат-виджета в BaseLayout). */}
      <div>
        <iframe
          src="https://api.leadconnectorhq.com/widget/form/NScQLS1yP9E4TAglifYM"
          style="width:100%;min-height:712px;border:none;border-radius:8px"
          id="inline-NScQLS1yP9E4TAglifYM"
          data-layout="{'id':'INLINE'}"
          data-trigger-type="alwaysShow"
          data-trigger-value=""
          data-activation-type="alwaysActivated"
          data-activation-value=""
          data-deactivation-type="neverDeactivate"
          data-deactivation-value=""
          data-form-name="IdealWebsite - Main Form"
          data-height="712"
          data-layout-iframe-id="inline-NScQLS1yP9E4TAglifYM"
          data-form-id="NScQLS1yP9E4TAglifYM"
          title="IdealWebsite - Main Form"
        ></iframe>
        <script is:inline src="https://link.msgsndr.com/js/form_embed.js"></script>
      </div>
    </div>
  </Container>
</section>
)}

{showCta && (
<section
  class="relative w-full"
  data-section="start-transformation-cta"
>
  {/* Фото здания — слева, у́же текстовой панели (Figma: фото 42% / панель 58%) */}
  <div class="grid grid-cols-1 lg:grid-cols-[42fr_58fr]">
    <div class="relative aspect-[802/707]">
      <img
      width="2124"
      height="1414"
        src="/assets/images/building-clinic.webp"
        alt="Ideal Medical and Wellness building in Aventura, FL"
        class="absolute inset-0 h-full w-full object-cover"
        loading="lazy"
      />
    </div>

    <div
      class="relative flex flex-col justify-center bg-[#f4f1e8] px-[7.55%] py-6"
    >
      <h2 class="font-heading text-[24px] sm:text-[30px] md:text-[34px] lg:text-[34px] xl:text-[42px] 2xl:text-[52px] uppercase leading-tight text-gold">
        <span class="relative inline-block">
          Ready to Start Your
          {/* Звезда из Figma (узел 1:258) — inline в конце первой строки H2.
              Figma-координаты: x=1723, y=7675, размер 42.57×50. */}
          <img
            src="/assets/images/star-sign.svg"
            alt=""
            width="43"
            height="50"
            class="absolute left-full top-1/2 -translate-y-1/2 ml-6 h-[50px] w-[43px] max-lg:hidden"
            aria-hidden="true"
          />
        </span><br />
        Transformation Today?
      </h2>

      {/* В Figma была опечатка "BOOK APPOIMENT" (без второй n) — исправлено
          на "BOOK APPOINTMENT". */}
      <a
        href={bookingCta.href}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-gold mt-5 w-fit min-w-[270px] self-start whitespace-nowrap"
      >
        BOOK APPOINTMENT
      </a>

      {/* Figma узел 1:264: Manrope Regular 35px, БЕЗ uppercase, #8d7431.
          Иконки карт (Figma 1:267) — справа на той же строке, чтобы не плодить
          лишний ряд (на мобильном падают под текст). */}
      <div class="mt-5 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between sm:gap-6">
        <p class="font-sans text-[22px] sm:text-[28px] md:text-[35px] leading-tight text-gold">
          We are located in the<br />
          heart of Aventura, Florida
        </p>
        {/* Иконки на белом фоне — убираем фон через mix-blend-multiply на кремовой панели. */}
        <div class="flex items-end gap-4">
          <a
            href={googleMapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Open location in Google Maps"
          >
            <img
              src="/assets/images/google-maps-icon.png"
              alt="Google Maps"
              width="170"
              height="169"
              class="h-11 w-auto mix-blend-multiply transition-transform hover:scale-105"
              loading="lazy"
            />
          </a>
          <a
            href={appleMapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Open location in Apple Maps"
          >
            <img
              src="/assets/images/apple-maps-icon.png"
              alt="Apple Maps"
              width="157"
              height="156"
              class="h-11 w-auto mix-blend-multiply transition-transform hover:scale-105"
              loading="lazy"
            />
          </a>
        </div>
      </div>

      <div class="mt-5 flex flex-col gap-8 sm:flex-row sm:flex-wrap sm:gap-x-12 sm:gap-y-6">
        <address class="not-italic font-sans text-[18px] leading-snug text-[#5a4f33]">
          <p class="font-heading text-[24px] uppercase text-gold">Address</p>
          <p class="mt-2">{address.name}</p>
          <p>{address.street}</p>
          <p>{address.suite}</p>
          <p>{address.city}</p>
          <p class="mt-3">
            <a href={SITE.telHref} class="hover:underline">
              {address.phone}
            </a>
          </p>
        </address>

        <HoursWidget />
      </div>
    </div>
  </div>

  {/* Google Maps embed под блоком — на всю ширину */}
  <div class="aspect-[4/3] md:aspect-[1920/400] w-full" data-todo="confirm-map-coordinates">
    <iframe
      title="Map showing Ideal Medical and Wellness location"
      src={`https://www.google.com/maps?q=${encodeURIComponent(
        address.street + ', ' + address.city
      )}&output=embed`}
      width="100%"
      height="100%"
      style="border:0; filter: sepia(0.55) saturate(1.35) hue-rotate(-12deg) brightness(1.04) contrast(0.9);"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
  </div>
</section>
)}