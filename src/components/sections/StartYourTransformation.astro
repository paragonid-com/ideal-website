---
/**
 * StartYourTransformation — двухчастная секция:
 *
 * Часть A: форма "START YOUR WELLNESS TRANSFORMATION" слева,
 *          информация о клинике справа (с placeholder для Lorem Ipsum)
 *
 * Часть B: "Ready to start your transformation today?" — фото здания слева,
 *          CTA и адрес справа, под ними — Google Maps embed
 *
 * Источник: узлы 1:1366 (заголовок Start), 1:1371-1:1390 (поля формы),
 *           1:251 (Ready), 1:255 (BOOK APPOINTMENT — в Figma была опечатка
 *           "APPOIMENT", исправлена), 1:264 (We are located),
 *           1:296/1444 (адрес), 1:310 (Image 109 — building photo),
 *           1:1393 (был Lorem Ipsum — заменён на consent-текст)
 *
 * ⚠️ Текст согласия под формой — нейтральный плейсхолдер; заказчику нужно
 * утвердить финальную формулировку под свою privacy-политику.
 */
import Container from '../Container.astro';
import { bookingCta } from '../../data/navigation.ts';

interface Props {
  /** Какие части показывать: обе, только форму, или только CTA-баннер.
   *  Дефолт 'both' — обратная совместимость со старыми вызовами. */
  show?: 'both' | 'form' | 'cta';
}
const { show = 'both' } = Astro.props;
const showForm = show === 'both' || show === 'form';
const showCta = show === 'both' || show === 'cta';

const address = {
  name: 'Ideal Medical and Wellness',
  street: '2999 NE 191 Street',
  city: 'Aventura, FL 33180',
  phone: '(305) 650-1884',
};

// Ссылки «открыть в картах» — строятся из адреса клиники.
const mapQuery = encodeURIComponent(
  `${address.name}, ${address.street}, ${address.city}`
);
const googleMapsUrl = `https://www.google.com/maps/search/?api=1&query=${mapQuery}`;
const appleMapsUrl = `https://maps.apple.com/?q=${mapQuery}`;
---

{showForm && (
<section
  class="w-full bg-cream py-28"
  data-section="start-transformation-form"
>
  <Container>
    <div class="grid grid-cols-1 items-start gap-x-16 gap-y-12 lg:grid-cols-[42fr_58fr]">
      <div>
        <h2 class="font-heading text-h1 uppercase leading-tight text-gold">
          Start Your<br />
          Wellness<br />
          Transformation
        </h2>
      </div>

      <form
        class="grid grid-cols-1 gap-x-8 gap-y-10 md:grid-cols-2"
        data-todo="form-submission-endpoint"
      >
        <label class="block">
          <span class="font-sans text-[18px] text-gold">First Name (Required)</span>
          <input
            type="text"
            name="firstName"
            required
            class="mt-2 w-full border-b border-gold bg-transparent py-2 font-sans text-gold focus:outline-none"
          />
        </label>
        <label class="block">
          <span class="font-sans text-[18px] text-gold">Last Name (Required)</span>
          <input
            type="text"
            name="lastName"
            required
            class="mt-2 w-full border-b border-gold bg-transparent py-2 font-sans text-gold focus:outline-none"
          />
        </label>
        {/* Email и Phone — full-width в Figma (узлы 1:1793, 1:1794: линии w=914) */}
        <label class="block md:col-span-2">
          <span class="font-sans text-[18px] text-gold">Email (Required)</span>
          <input
            type="email"
            name="email"
            required
            class="mt-2 w-full border-b border-gold bg-transparent py-2 font-sans text-gold focus:outline-none"
          />
        </label>
        <label class="block md:col-span-2">
          <span class="font-sans text-[18px] text-gold">Phone (Required)</span>
          <input
            type="tel"
            name="phone"
            required
            class="mt-2 w-full border-b border-gold bg-transparent py-2 font-sans text-gold focus:outline-none"
          />
        </label>
        <label class="block">
          <span class="font-sans text-[18px] text-gold">Date of Birth (Required)</span>
          <input
            type="date"
            name="dob"
            required
            class="mt-2 w-full border-b border-gold bg-transparent py-2 font-sans text-gold focus:outline-none"
          />
        </label>
        <fieldset class="block">
          <legend class="font-sans text-[18px] text-gold">Contact Preferences</legend>
          <div class="mt-3 flex gap-6">
            <label class="flex items-center gap-2 font-sans text-[18px] text-gold">
              <input type="checkbox" name="contactPref" value="sms" />
              SMS
            </label>
            <label class="flex items-center gap-2 font-sans text-[18px] text-gold">
              <input type="checkbox" name="contactPref" value="email" />
              Email
            </label>
          </div>
        </fieldset>

        <div class="md:col-span-2">
          <button type="submit" class="btn-gold w-[195px]">SUBMIT</button>
        </div>

        {/* Согласие на обработку/связь, включая автоматизированные и
           AI-инструменты. Единый источник — применяется на всех страницах
           с этой формой. ⚠️ Черновик: финальную формулировку должен утвердить
           юрист клиники под её privacy-политику и применимое право (TCPA и др.). */}
        <p
          class="md:col-span-2 font-sans text-[14px] leading-relaxed text-gold/70"
          data-todo="confirm-consent-disclaimer-text"
        >
          By submitting this form, you consent to be contacted by Ideal Medical
          and Wellness by phone, text message (SMS), and email regarding your
          inquiry, including through automated technology and AI-assisted tools
          used to schedule, respond to, and follow up on your request. Consent
          is not a condition of purchasing any goods or services. Message and
          data rates may apply and message frequency may vary; reply STOP to
          opt out at any time. AI-assisted communications are reviewed under the
          supervision of our clinical team and do not constitute medical advice.
          We respect your privacy, handle your information in accordance with
          our Privacy Policy, and will never sell your information to third
          parties.
        </p>
      </form>
    </div>
  </Container>
</section>
)}

{showCta && (
<section
  class="relative w-full"
  data-section="start-transformation-cta"
>
  {/* Фото здания — слева, у́же текстовой панели (Figma: фото 42% / панель 58%) */}
  <div class="grid grid-cols-1 lg:grid-cols-[42fr_58fr]">
    <div class="relative aspect-[802/707] lg:aspect-auto">
      <img
      width="2124"
      height="1414"
        src="/assets/images/building-clinic.webp"
        alt="Ideal Medical and Wellness building in Aventura, FL"
        class="absolute inset-0 h-full w-full object-cover"
        loading="lazy"
      />
    </div>

    <div
      class="relative flex flex-col justify-center bg-[#f4f1e8] px-[7.55%] py-16"
    >
      <h2 class="font-heading text-h1 uppercase leading-tight text-gold">
        <span class="relative inline-block">
          Ready to Start Your
          {/* Звезда из Figma (узел 1:258) — inline в конце первой строки H2.
              Figma-координаты: x=1723, y=7675, размер 42.57×50. */}
          <img
            src="/assets/images/star-sign.svg"
            alt=""
            width="43"
            height="50"
            class="absolute left-full top-1/2 -translate-y-1/2 ml-2 h-[50px] w-[43px] max-lg:hidden"
            aria-hidden="true"
          />
        </span><br />
        Transformation Today?
      </h2>

      {/* В Figma была опечатка "BOOK APPOIMENT" (без второй n) — исправлено
          на "BOOK APPOINTMENT". */}
      <a
        href={bookingCta.href}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-gold mt-8 w-fit min-w-[270px] self-start whitespace-nowrap"
      >
        BOOK APPOINTMENT
      </a>

      <p class="mt-12 font-heading text-[26px] md:text-[36px] uppercase leading-tight text-gold">
        We are located in the<br />
        heart of Aventura, Florida
      </p>

      <div class="mt-8 flex flex-wrap items-end justify-between gap-8">
        <address class="not-italic font-sans text-[18px] leading-relaxed text-gold">
          <p class="font-heading text-[24px] uppercase">Address</p>
          <p class="mt-2">{address.name}</p>
          <p>{address.street}</p>
          <p>{address.city}</p>
          <p class="mt-4">
            <a href={`tel:${address.phone.replace(/[^\d+]/g, '')}`} class="hover:underline">
              {address.phone}
            </a>
          </p>
        </address>

        {/* Ссылки на карты (Figma узел 1:267, Image 108). Иконки на белом фоне —
            убираем фон через mix-blend-multiply на кремовой панели. */}
        <div class="flex items-end gap-4">
          <a
            href={googleMapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Open location in Google Maps"
          >
            <img
              src="/assets/images/google-maps-icon.png"
              alt="Google Maps"
              width="170"
              height="169"
              class="h-12 w-auto mix-blend-multiply transition-transform hover:scale-105"
              loading="lazy"
            />
          </a>
          <a
            href={appleMapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Open location in Apple Maps"
          >
            <img
              src="/assets/images/apple-maps-icon.png"
              alt="Apple Maps"
              width="157"
              height="156"
              class="h-12 w-auto mix-blend-multiply transition-transform hover:scale-105"
              loading="lazy"
            />
          </a>
        </div>
      </div>
    </div>
  </div>

  {/* Google Maps embed под блоком — на всю ширину */}
  <div class="aspect-[4/3] md:aspect-[1920/400] w-full" data-todo="confirm-map-coordinates">
    <iframe
      title="Map showing Ideal Medical and Wellness location"
      src={`https://www.google.com/maps?q=${encodeURIComponent(
        address.street + ', ' + address.city
      )}&output=embed`}
      width="100%"
      height="100%"
      style="border:0; filter: sepia(0.55) saturate(1.35) hue-rotate(-12deg) brightness(1.04) contrast(0.9);"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
  </div>
</section>
)}