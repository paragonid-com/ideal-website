---
/**
 * Our Signature Services — заголовок + ряд из 5 карточек услуг.
 *
 * Source в Figma (file jmzQqLFWpZXSII6xTkgCgu):
 *   - Заголовок секции: 1:149 (h2), 1:155 (lead), 1:230 (орнамент справа)
 *   - 5 фоновых VECTOR'ов с image fill (scaleMode=CROP, scalingFactor=0.5):
 *     1:352 Medical Weight Loss, 1:351 Hormone, 1:536 Peptide,
 *     1:353 Sexual Health, 1:350 IV Therapy — все 291×436
 *   - 3 предметных overlay'я (поверх фона):
 *     - Hormone Group 380 (1:354): 288×243 at (3.5, 94) в карточке
 *       → top:21.5% left:1.2% w:99% h:55.7%
 *     - Peptide Group 310 (1:537): 245×402 at (26.6, 7.3)
 *       → top:1.7% left:9.1% w:84% h:92.2%
 *     - IV Therapy Group 402 (1:482): 448×322 at (-22, 68)
 *       → точные Figma-значения: top:15.6% left:-7.5% w:153.4% h:73.85%.
 *         Но overlay-файл `service-iv-therapy-overlay.webp` после очистки
 *         alpha-bbox имеет тесный crop вокруг пакетов (~468×573, aspect 0.82),
 *         поэтому используется упрощённая модель: top + height + autoCenterX
 *         — overlay растягивается по высоте и центрируется по X.
 *
 * Особенность: фоновые фото у Weight Loss и Sexual Health имеют исходный
 * aspect ratio близкий к карточке (≈0.67), но содержат много фоновых полей.
 * В Figma эффект zoom 2× получается из `scalingFactor: 0.5`. У нас —
 * через CSS `transform: scale()` и `object-position`. См. поля
 * `imageScale` и `imagePosition` ниже.
 */
import Container from '../Container.astro';

interface Service {
  titleLines: [string, string];
  href: string;
  image: string;
  /**
   * Доп. zoom фонового фото (CSS transform: scale).
   * В Figma фоновые фото у Weight Loss / Sexual Health имеют
   * `scaleMode: CROP` + `scalingFactor: 0.5`, что эквивалентно
   * увеличению в ~2× относительно cover. Наши webp экспортированы
   * с исходным aspect карточки (=0.67), поэтому без CSS-зума показывают
   * слишком много пустого фона. Дефолт: 1 (без зума).
   */
  imageScale?: number;
  /**
   * object-position для фонового фото. По умолчанию center.
   */
  imagePosition?: string;
  overlay?: {
    src: string;
    alt: string;
    /** Точные процентные координаты относительно карточки 291×436 из Figma */
    top: string;
    left?: string;
    width?: string;
    height: string;
    /** Если true — горизонтально центрировать overlay через transform: translateX(-50%).
        Использовать, когда overlay-картинка имеет естественные пропорции и нет смысла
        задавать абсолютные left/width — пусть растягивается по height, центрируется сама. */
    autoCenterX?: boolean;
  };
}

const services: Service[] = [
  {
    titleLines: ['Medical', 'Weight Loss'],
    href: '/services/weight-loss',
    image: '/assets/images/service-weight-loss.webp',
    // webp уже содержит фигуру целиком в правильном aspect — нужен лишь
    // лёгкий зум, чтобы не было пустых полей по бокам. Top-anchor чтобы
    // голову не подрезало.
    imageScale: 1.05,
    imagePosition: 'center top',
  },
  {
    titleLines: ['Hormone', 'Optimization'],
    href: '/services/hormone',
    image: '/assets/images/service-hormone.webp',
    overlay: {
      src: '/assets/images/service-hormone-overlay.webp',
      alt: 'Estrogen Cream and Testosterone vials',
      top: '21.5%',
      left: '1.2%',
      width: '99%',
      height: '55.7%',
    },
  },
  {
    titleLines: ['Peptide', 'Therapy'],
    href: '/services/peptide',
    image: '/assets/images/service-peptide.webp',
    overlay: {
      src: '/assets/images/service-peptide-overlay.webp',
      alt: 'Peptide therapy injector pens',
      top: '1.7%',
      left: '9.1%',
      width: '84%',
      height: '92.2%',
    },
  },
  {
    titleLines: ['Sexual', 'Health'],
    href: '/services/sexualhealth',
    image: '/assets/images/service-sexual-health.webp',
    // В исходном webp лицо смещено правее центра — небольшой zoom
    // + position 75% выводит лицо примерно в центр кадра карточки.
    imageScale: 1.3,
    imagePosition: '75% center',
  },
  {
    titleLines: ['IV', 'Therapy'],
    href: '/services/ivtherapy',
    image: '/assets/images/service-iv-therapy.webp',
    overlay: {
      src: '/assets/images/service-iv-therapy-overlay.webp',
      alt: 'NAD+ and Radiant AF IV bags',
      // Overlay-файл обрезан по alpha-bbox (~468×573), пакеты заполняют
      // практически весь кадр без лишних полей. Задаём только высоту +
      // авто-центрирование по X — пропорция сохраняется естественно.
      top: '15%',
      height: '70%',
      autoCenterX: true,
    },
  },
];
---

<section class="w-full bg-cream py-24" data-section="signature-services">
  <Container>
    <div class="relative text-center">
      <div class="relative inline-block">
        <h2 class="font-heading text-h1 uppercase text-gold">
          Our Signature Services
        </h2>
        {/* Звезда из Figma (узел 1:230) — сразу после слова SERVICES, как в макете.
            Figma-размер 42.57×50. Прижата к правому краю H2 (left-full),
            слегка приподнята (-top). */}
        <img
          src="/assets/images/star-sign.svg"
          alt=""
          width="43"
          height="50"
          class="absolute left-full top-0 ml-2 h-[50px] w-[43px] max-lg:hidden"
          aria-hidden="true"
        />
      </div>
      <p class="mx-auto mt-8 max-w-[821px] font-sans text-body-lg leading-relaxed text-gold">
        Explore our range of specialized treatments designed to enhance
        your well-being. Each service at Ideal Medical and Wellness is
        tailored to meet the unique needs of our clients, ensuring
        optimal results and satisfaction.
      </p>
    </div>

    <ul class="mt-16 grid grid-cols-2 gap-x-6 gap-y-12 md:grid-cols-3 lg:grid-cols-5">
      {services.map((s) => (
        <li class="flex flex-col">
          <a href={s.href} class="group flex h-full flex-col">
            <h3 class="mb-4 h-[68px] font-heading text-[24px] uppercase leading-[34px] text-gold tracking-wide">
              {s.titleLines[0]}<br />{s.titleLines[1]}
            </h3>

            <div class="relative overflow-hidden aspect-[291/436] bg-gold/10">
              <img
                src={s.image}
                alt=""
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-[var(--scale-hover)]"
                style={`object-position: ${s.imagePosition ?? 'center'}; transform: scale(${s.imageScale ?? 1}); --scale-hover: ${((s.imageScale ?? 1) * 1.05).toFixed(3)};`}
                loading="lazy"
              />
              {s.overlay && (
                <img
                  src={s.overlay.src}
                  alt={s.overlay.alt}
                  class="absolute object-contain pointer-events-none"
                  style={
                    s.overlay.autoCenterX
                      ? `top: ${s.overlay.top}; left: 50%; transform: translateX(-50%); height: ${s.overlay.height}; width: auto; max-width: none;`
                      : `top: ${s.overlay.top}; left: ${s.overlay.left}; width: ${s.overlay.width}; height: ${s.overlay.height};`
                  }
                  loading="lazy"
                />
              )}
            </div>

            <div class="flex h-[48px] w-full items-center bg-gold pl-4 transition-opacity group-hover:opacity-80">
              <span class="font-sans text-[14px] uppercase tracking-[0.15em] text-cream">
                Discover
              </span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </Container>
</section>
