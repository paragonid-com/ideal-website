---
/**
 * Discover Personalized Excellence — двухколоночный блок.
 * Слева — фото команды клиники у ресепшн (реальное фото, не стоковое).
 * Справа — заголовок + параграф.
 *
 * Источник: узлы 1:60 (фото), 1:79 (заголовок), 1:108 (текст)
 */
---

<section
  class="relative w-full bg-cream"
  data-section="discover"
>
  <div class="mx-auto grid w-full max-w-design grid-cols-1 lg:grid-cols-[52fr_48fr] lg:items-stretch">
    {/* Левая колонка — фото. В Figma фото ≈52% ширины и задаёт высоту всей
        секции (секция начинается с верха фото и заканчивается его низом).
        На lg фото тянется на всю высоту ряда (object-cover, лёгкая боковая
        обрезка). На мобиле — собственный аспект 3:2. */}
    <div class="relative aspect-[2054/1368] w-full lg:aspect-auto">
      <img
        src="/assets/images/team-reception.webp"
        alt="The IDEAL Medical and Wellness team at our Aventura reception"
        width="2054"
        height="1368"
        class="absolute inset-0 block h-full w-full object-cover"
        loading="lazy"
      />
    </div>

    {/* Правая колонка (≈48%) — текст, вертикально центрирован в высоте фото */}
    <div class="relative flex flex-col justify-center px-[7.55%] py-8">
      <div class="relative">
        {/* Звезда из Figma (узел 1:224) — верх-право заголовка. */}
        <img
          src="/assets/images/star-sign.svg"
          alt=""
          width="43"
          height="50"
          class="absolute right-0 top-1 h-[50px] w-[43px]"
          aria-hidden="true"
        />
        <h2 class="font-heading text-h1 uppercase leading-tight text-gold">
          Discover<br />
          Personalized<br />
          Excellence<br />
          in Wellness
        </h2>
      </div>

      <p class="mt-6 max-w-[523px] font-sans text-body-lg leading-relaxed text-[#5a4f33]">
        At Ideal Medical &amp; Wellness, care is concierge by design:
        one team that knows your history, plans built around your
        goals and schedule, and results you can both feel and measure.
        We start with diagnostics &mdash; not assumptions &mdash; and
        adjust as your labs and progress tell us what is working.
      </p>
    </div>
  </div>
  </div>
</section>
